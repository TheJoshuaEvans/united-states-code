{"tag":"section","attrib":{"id":"id1222e472-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s903"},"text":null,"children":[{"tag":"num","attrib":{"value":"903"},"text":"§ 903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional Record: daily and permanent forms","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The public proceedings of each House of Congress as reported by the Official Reporters, shall be printed in the Congressional Record, which shall be issued in daily form during each session and shall be revised, printed, and bound promptly, as directed by the Joint Committee on Printing, in permanent form, for distribution during and after the close of each session of Congress. The daily and the permanent Record shall bear the same date, which shall be that of the actual day’s proceedings reported. The “usual number” of the Congressional Record may not be printed.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id1222e473-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1256"},"text":"82 Stat. 1256","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1222e474-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id1222e475-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 182a (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s14"},"text":"Jan. 12, 1895, ch. 23, § 14","children":[],"tail":", as added "},{"tag":"ref","attrib":{"href":"/us/act/1936-06-20/ch630"},"text":"June 20, 1936, ch. 630","children":[],"tail":", title II, § 2, "},{"tag":"ref","attrib":{"href":"/us/stat/49/1546"},"text":"49 Stat. 1546","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
