{"tag":"section","attrib":{"id":"id1222e452-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s740"},"text":null,"children":[{"tag":"num","attrib":{"value":"740"},"text":"§ 740.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senate Service Department and House Publications Distribution Service; superintendents","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There shall be a Senate Service Department and a House of Representatives Publications Distribution Service in the charge of superintendents, appointed respectively by the Sergeant at Arms of the Senate and Chief Administrative Officer of the House of Representatives, together with the necessary assistants. Reports or documents to be distributed for the Senators and Representatives shall be folded and distributed from the Senate Service Department and House of Representatives Publications Distribution Service, unless otherwise ordered, and the respective superintendent shall notify each Senator and Representative in writing once every sixty days of the number and character of publications on hand and assigned to him for use and distribution.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id1222e453-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1255"},"text":"82 Stat. 1255","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s223/6"},"text":"Pub. L. 104–186, title II, § 223(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1751"},"text":"110 Stat. 1751","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1222e454-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id1222e455-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 166 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s71"},"text":"Jan. 12, 1895, ch. 23, § 71","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/612"},"text":"28 Stat. 612","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-07-02/ch455"},"text":"July 2, 1954, ch. 455","children":[],"tail":", title I, § 101, "},{"tag":"ref","attrib":{"href":"/us/stat/68/397"},"text":"68 Stat. 397","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“House of Representatives Publications Distribution Service” is substituted for “House Folding Room” because of the change of name under authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/652"},"text":"Public Law 88–652","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1222e456-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id1222e457-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":" substituted “Chief Administrative Officer of the House of Representatives” for “Doorkeeper of the House”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
