{"tag":"section","attrib":{"id":"id121bb8ca-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s315"},"text":null,"children":[{"tag":"num","attrib":{"value":"315"},"text":"§ 315.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Branches of Government Publishing Office; limitations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Money appropriated by any Act may not be used for maintaining more than one branch of the Government Publishing Office in any one building occupied by an executive department of the Government, and a branch of the Government Publishing Office may not be established unless specifically authorized by law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id121bb8cb-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1242"},"text":"82 Stat. 1242","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/b"},"text":"Pub. L. 113–235, div. H, title I, § 1301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id121bb8cc-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id121bb8cd-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 61 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1914-08-01/ch223/s1"},"text":"Aug. 1, 1914, ch. 223, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/38/673"},"text":"38 Stat. 673","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id121bb8ce-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id121bb8cf-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Government Publishing Office” substituted for “Government Printing Office” in section catchline and text on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/b"},"text":"section 1301(b) of Pub. L. 113–235","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s301"},"text":"section 301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
