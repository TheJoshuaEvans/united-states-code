{"tag":"section","attrib":{"id":"id1259d2d8-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3556"},"text":null,"children":[{"tag":"num","attrib":{"value":"3556"},"text":"§ 3556.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal information security incident center","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1259d2d9-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3556/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Secretary shall ensure the operation of a central Federal information security incident center to—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1259d2da-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3556/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide timely technical assistance to operators of agency information systems regarding security incidents, including guidance on detecting and handling information security incidents;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d2db-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3556/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compile and analyze information about incidents that threaten information security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d2dc-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3556/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" inform operators of agency information systems about current and potential information security threats, and vulnerabilities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d2dd-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3556/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide, as appropriate, intelligence and other information about cyber threats, vulnerabilities, and incidents to agencies to assist in risk assessments conducted under section 3554(b); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d2de-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3556/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with the National Institute of Standards and Technology, agencies or offices operating or exercising control of national security systems (including the National Security Agency), and such other agencies or offices in accordance with law and as directed by the President regarding information security incidents and related matters.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1259d2df-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3556/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Security Systems","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each agency operating or exercising control of a national security system shall share information about information security incidents, threats, and vulnerabilities with the Federal information security incident center to the extent consistent with standards and guidelines for national security systems, issued in accordance with law and as directed by the President.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1259d2e0-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/283/s2/a"},"text":"Pub. L. 113–283, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3084"},"text":"128 Stat. 3084","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1259d2e1-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1259d2e2-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id1259d2e3-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to this section were contained in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3546"},"text":"section 3546 of this title","children":[],"tail":" prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/113/283"},"text":"Pub. L. 113–283","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
