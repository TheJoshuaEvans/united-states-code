{"tag":"section","attrib":{"id":"id123f9379-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2302"},"text":null,"children":[{"tag":"num","attrib":{"value":"2302"},"text":"§ 2302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Authority of the Board; seal; services; bylaws; rules; regulations; employees","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In carrying out the purposes of this chapter, the Board—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id123f937a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2302/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may adopt an official seal, which shall be judicially noticed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id123f937b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2302/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may utilize on a reimbursable basis the services and personnel of the National Archives and Records Administration necessary (as determined by the Archivist) to assist the Board in the administration of the trust fund, and in the preparation and publication of special works and collections of sources and preparation, duplication, editing, and release of historical photographic materials and sound recordings, and may utilize on a reimbursable basis the services and personnel of other Federal agencies for such purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id123f937c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2302/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may adopt bylaws, rules, and regulations necessary for the administration of its functions under this chapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id123f937d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2302/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may, subject to the laws and regulations governing appointments in the civil service, appoint and fix the compensation of such personnel as may be necessary to carry out its functions.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id123f937e-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1292"},"text":"82 Stat. 1292","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/tII/s202/a"},"text":"Pub. L. 98–497, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2293"},"text":"98 Stat. 2293","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id123f937f-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id123f9380-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 300hh (","children":[{"tag":"ref","attrib":{"href":"/us/act/1941-07-09/ch284/s8"},"text":"July 9, 1941. ch. 284, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/55/582"},"text":"55 Stat. 582","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id123f9381-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id123f9382-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The laws governing appointments in the civil service, referred to in par. (4), are set out in Title 5, Government Organization and Employees. See, particularly, section 3301 et seq. of Title 5.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id123f9383-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" amended section generally. Prior to amendment, section read as follows: “In carrying out the purposes of this chapter, the Board may—"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(1) adopt an official seal, which shall be judicially noticed;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(2) appoint, or authorize the Chairman to appoint, without regard to the civil-service laws, necessary employees, and fix their duties; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“(3) adopt bylaws, rules, and regulations necessary for the administration of its functions under this chapter.”","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id123f9384-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id123f9385-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-04-01"},"text":"Apr. 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/s301"},"text":"section 301 of Pub. L. 98–497","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s2102"},"text":"section 2102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
