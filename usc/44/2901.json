{"tag":"section","attrib":{"id":"id1241dd65-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2901"},"text":null,"children":[{"tag":"num","attrib":{"value":"2901"},"text":"§ 2901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this chapter, and chapters 21, 25, 31, and 33 of this title—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1241dd66-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2901/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “records” has the meaning given it by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3301"},"text":"section 3301 of this title","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1241dd67-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2901/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “records management” means the planning, controlling, directing, organizing, training, promoting, and other managerial activities involved with respect to records creation, records maintenance and use, and records disposition in order to achieve adequate and proper documentation of the policies and transactions of the Federal Government and effective and economical management of agency operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1241dd68-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2901/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “records creation” means the production or reproduction of any record;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1241dd69-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2901/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “records maintenance and use” means any activity involving—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1241dd6a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2901/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" location of records of a Federal agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1241dd6b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2901/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" storage, retrieval, and handling of records kept at office file locations by or for a Federal agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1241dd6c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2901/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" processing of mail by a Federal agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1241dd6d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2901/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" selection and utilization of equipment and supplies associated with records and copying;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1241dd6e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2901/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “records disposition” means any activity with respect to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1241dd6f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2901/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disposal of temporary records no longer necessary for the conduct of business by destruction or donation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1241dd70-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2901/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer of records to Federal agency storage facilities or records centers;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1241dd71-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2901/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer to the National Archives of the United States of records determined to have sufficient historical or other value to warrant continued preservation; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1241dd72-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2901/5/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transfer of records from one Federal agency to any other Federal agency;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1241dd73-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2901/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “records center” means an establishment maintained and operated by the Archivist or by another Federal agency primarily for the storage, servicing, security, and processing of records which need to be preserved for varying periods of time and need not be retained in office equipment or space;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1241dd74-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2901/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “records management study” means an investigation and analysis of any Federal agency records, or records management practices or programs (whether manual or automated), with a view toward rendering findings and recommendations with respect thereto;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1241dd75-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2901/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “inspection” means reviewing any Federal agency’s records or records management practices or programs with respect to effectiveness and compliance with records management laws and making necessary recommendations for correction or improvement of records management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1241dd76-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2901/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “servicing” means making available for use information in records and other materials in the custody of the Archivist, or in a records center—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1241dd77-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2901/9/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by furnishing the records or other materials, or information from them, or copies or reproductions thereof, to any Federal agency for official use, or to the public; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1241dd78-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2901/9/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by making and furnishing authenticated or unauthenticated copies or reproductions of the records or other materials;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1241dd79-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2901/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “unauthenticated copies” means exact copies or reproductions of records or other materials that are not certified as such under seal and that need not be legally accepted as evidence;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1241dd7a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2901/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “National Archives of the United States” means those official records which have been determined by the Archivist of the United States to have sufficient historical or other value to warrant their continued preservation by the Federal Government, and which have been accepted by the Archivist for deposit in the Archivist’s custody;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1241dd7b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2901/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Archivist” means the Archivist of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1241dd7c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2901/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “executive agency” shall have the meaning given such term by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s102"},"text":"section 102 of title 40","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1241dd7d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2901/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Federal agency” means any executive agency or any establishment in the legislative or judicial branch of the Government (except the Supreme Court, the Senate, the House of Representatives, and the Architect of the Capitol and any activities under the direction of the Architect of the Capitol);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1241dd7e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2901/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “electronic messages” means electronic mail and other electronic messaging systems that are used for purposes of communicating between individuals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1241dd7f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2901/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “electronic records management system” means software designed to manage electronic records, including by—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1241dd80-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2901/16/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" categorizing and locating records;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1241dd81-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2901/16/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring that records are retained as long as necessary;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1241dd82-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2901/16/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifying records that are due for disposition; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1241dd83-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2901/16/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring the storage, retrieval, and disposition of records.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1241dd84-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/575/s2/a/1"},"text":"Pub. L. 94–575, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2723"},"text":"90 Stat. 2723","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/tI/s107/b/13"},"text":"Pub. L. 98–497, title I, § 107(b)(13)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2287"},"text":"98 Stat. 2287","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s3"},"text":"Pub. L. 107–217, § 3","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(2), "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1301"},"text":"116 Stat. 1301","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/187/s8/6"},"text":"Pub. L. 113–187, § 8(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-11-26"},"text":"Nov. 26, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2012"},"text":"128 Stat. 2012","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/116/283/dH/tXCVI/s9602/b/5"},"text":"Pub. L. 116–283, div. H, title XCVI, § 9602(b)(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2021-01-01"},"text":"Jan. 1, 2021","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/134/4829"},"text":"134 Stat. 4829","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1241dd85-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1241dd86-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id1241dd87-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2901, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1295"},"text":"82 Stat. 1295","children":[],"tail":", related to definitions, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/94/575/s2/a/1"},"text":"Pub. L. 94–575, § 2(a)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id1241dd88-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2021—Pars. (15), (16). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/116/283"},"text":"Pub. L. 116–283","children":[],"tail":" added pars. (15) and (16) and struck out former par. (15) which defined “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Par. (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/187"},"text":"Pub. L. 113–187","children":[],"tail":" substituted “the Archivist’s” for “his”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2002—Par. (13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/217"},"text":"Pub. L. 107–217","children":[],"tail":" substituted “"},{"tag":"ref","attrib":{"href":"/us/usc/t40/s102"},"text":"section 102 of title 40","children":[],"tail":"” for “section 3(a) of the Federal Property and Administrative Services Act of 1949 ("},{"tag":"ref","attrib":{"href":"/us/usc/t40/s472/a"},"text":"40 U.S.C. 472(a)","children":[],"tail":")”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497/s107/b/13/A"},"text":"Pub. L. 98–497, § 107(b)(13)(A)","children":[],"tail":", struck out reference to chapter 27 in provisions preceding par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497/s107/b/13/B"},"text":"Pub. L. 98–497, § 107(b)(13)(B)","children":[],"tail":", inserted “in order to achieve adequate and proper documentation of the policies and transactions of the Federal Government and effective and economical management of agency operations”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (6), (9), (11). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497/s107/b/13/C"},"text":"Pub. L. 98–497, § 107(b)(13)(C)","children":[],"tail":", substituted “Archivist” for “Administrator”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (12). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497/s107/b/13/D"},"text":"Pub. L. 98–497, § 107(b)(13)(D)","children":[],"tail":", substituted “Archivist” and “Archivist of the United States” for “Administrator” and “Administrator of General Services”, respectively. See par. (15) of this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (13). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497/s107/b/13/D"},"text":"Pub. L. 98–497, § 107(b)(13)(D)","children":[],"tail":", struck out references to “Federal agency” and to subsec. (b) of section 3 of the Federal Property and Administrative Services Act of 1949. See par. (14) of this section."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Pars. (14), (15). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497/s107/b/13/D"},"text":"Pub. L. 98–497, § 107(b)(13)(D)","children":[],"tail":", added pars. (14) and (15)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id1241dd89-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id1241dd8a-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-04-01"},"text":"Apr. 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/s301"},"text":"section 301 of Pub. L. 98–497","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s2102"},"text":"section 2102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id1241dd8b-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Records Center Revolving Fund","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/106/58/tIV"},"text":"Pub. L. 106–58, title IV","children":[],"tail":", [(a)–(e)], "},{"tag":"date","attrib":{"date":"1999-09-29"},"text":"Sept. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/460"},"text":"113 Stat. 460","children":[],"tail":", 461, as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/108/383/s3"},"text":"Pub. L. 108–383, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2218"},"text":"118 Stat. 2218","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/108/383/s3"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment of Fund","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is hereby established in the Treasury a revolving fund to be available for expenses (including expenses for uniforms or allowances for uniforms as authorized by subchapter I of chapter 59 of title 5 [United States Code]) and equipment necessary to provide for storage and related services for all temporary and pre-archival Federal records, which are to be stored or stored at Federal National and Regional Records Centers by agencies and other instrumentalities of the Federal Government. The Fund shall be available without fiscal year limitation for expenses necessary for operation of these activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Start-Up Capital.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is appropriated $22,000,000 as initial capitalization of the Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition, the initial capital of the Fund shall include the fair and reasonable value at the Fund’s inception of the inventories, equipment, receivables, and other assets, less the liabilities, transferred to the Fund. The Archivist of the United States is authorized to accept inventories, equipment, receivables and other assets from other Federal entities that were used to provide for storage and related services for temporary and pre-archival Federal records.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"“(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"User Charges","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Fund shall be credited with user charges received from other Federal Government accounts as payment for providing personnel, storage, materials, supplies, equipment, and services as authorized by subsection (a). Such payments may be made in advance or by way of reimbursement. The rates charged will return in full the expenses of operation, including reserves for accrued annual leave, worker’s compensation, depreciation of capitalized equipment and shelving, and amortization of information technology software and systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"“(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Funds Returned to Miscellaneous Receipts of the Department of the Treasury.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In addition to funds appropriated to and assets transferred to the Fund in subsection (b), an amount not to exceed 4 percent of the total annual income may be retained in the Fund as an operating reserve or for the replacement or acquisition of capital equipment, including shelving, and the improvement and implementation of the financial management, information technology, and other support systems of the National Archives and Records Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds in excess of the 4 percent at the close of each fiscal year shall be returned to the Treasury of the United States as miscellaneous receipts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"“(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reporting Requirement","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The National Archives and Records Administration shall provide quarterly reports to the Committees on Appropriations and Governmental Affairs of the Senate, and the Committees on Appropriations and Government Reform [now Committee on Oversight and Accountability] of the House of Representatives on the operation of the Records Center Revolving Fund.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id1241dd8c-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Federal Records Management Provisions Without Effect on Authorities and Responsibilities of Administrator of General Services, Joint Committee, or Government Publishing Office","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/575/s5"},"text":"Pub. L. 94–575, § 5","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2727"},"text":"90 Stat. 2727","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/b"},"text":"Pub. L. 113–235, div. H, title I, § 1301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/235/dH/tI/s1301/b"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of this Act [see Short Title of 1976 Amendment note set out under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s101"},"text":"section 101 of this title","children":[],"tail":"] relating to the authority of the Administrator of General Services do not limit or repeal additional authorities provided by statute or otherwise recognized by law."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The provisions of this Act do not limit or repeal the authority or responsibilities of the Joint Committee on Printing or the Government Publishing Office under chapters 1 through 19 of title 44, United States Code.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
