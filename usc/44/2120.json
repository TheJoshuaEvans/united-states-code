{"tag":"section","attrib":{"id":"id123ab2b4-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2120"},"text":null,"children":[{"tag":"num","attrib":{"value":"2120"},"text":"§ 2120.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Online access of founding fathers documents","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Archivist may enter into a cooperative agreement to provide online access to the published volumes of the papers of—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id123ab2b5-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2120/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" George Washington;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id123ab2b6-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2120/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Alexander Hamilton;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id123ab2b7-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2120/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Thomas Jefferson;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id123ab2b8-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2120/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Benjamin Franklin;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id123ab2b9-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2120/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" John Adams;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id123ab2ba-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2120/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" James Madison; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id123ab2bb-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2120/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other prominent historical figures, as determined appropriate by the Archivist of the United States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id123ab2bc-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/404/s4/a"},"text":"Pub. L. 110–404, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4283"},"text":"122 Stat. 4283","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id123ab2bd-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id123ab2be-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id123ab2bf-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transfer of Funds","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/404/s4/b"},"text":"Pub. L. 110–404, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4283"},"text":"122 Stat. 4283","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/404/s4/b"},"text":"\n","children":[{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Archivist of the United States, in the role as chairman of the National Historical Publications and Records Commission may enter into cooperative agreements pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s6305"},"text":"section 6305 of title 31","children":[],"tail":", United States Code, that involve the transfer of funds from the National Historical Publications and Records Commission to State and local governments, tribal governments, other public entities, educational institutions, or private nonprofit organizations for the public purpose of carrying out "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s2120"},"text":"section 2120 of title 44","children":[],"tail":", United States Codes [sic]."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Report","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than December 31st of each year, the Archivist of the United States shall submit to the Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Oversight and Government Reform [now Committee on Oversight and Accountability] of the House of Representatives a report on the provisions, amount, and duration of each cooperative agreement entered into as authorized by paragraph (1) during the preceding fiscal year.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
