{"tag":"section","attrib":{"id":"id122c8198-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1509"},"text":null,"children":[{"tag":"num","attrib":{"value":"1509"},"text":"§ 1509.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Costs of publication, etc.","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id122c8199-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1509/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The cost of publishing the Federal Register and the Code of Federal Regulations, and, except as provided in subsection (b), other expenses incurred by the Government Publishing Office in carrying out the duties placed upon it by this chapter shall be charged to the revolving fund provided in section 309. Reimbursements for such costs and expenses shall be made by the Federal agencies and credited, together with all receipts, as provided in section 309(b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id122c819a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1509/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The cost of publishing all other publications of the Federal Register program, and other expenses incurred by the Government Publishing Office in connection with such publications, shall be borne by the appropriations to the Government Publishing Office and the appropriations are made available, and are authorized to be increased by additional sums necessary for the purposes, the increases to be based upon estimates submitted by the Director of the Government Publishing Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id122c819b-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1277"},"text":"82 Stat. 1277","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/95/94/tIV/s408/a/1"},"text":"Pub. L. 95–94, title IV, § 408(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-05"},"text":"Aug. 5, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/683"},"text":"91 Stat. 683","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/b"},"text":"Pub. L. 113–235, div. H, title I, § 1301(b)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/267/s2/a/3"},"text":"Pub. L. 118–267, § 2(a)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2983"},"text":"138 Stat. 2983","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122c819c-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122c819d-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 309 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-07-26/ch417/s9"},"text":"July 26, 1935, ch. 417, § 9","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/502"},"text":"49 Stat. 502","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"A reference to section 10 of Act ","children":[{"tag":"date","attrib":{"date":"1934-06-19"},"text":"June 19, 1934","children":[],"tail":" is deleted because of the repeal of that section by Act "},{"tag":"date","attrib":{"date":"1949-06-30"},"text":"June 30, 1949","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id122c819e-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id122c819f-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/267"},"text":"Pub. L. 118–267","children":[],"tail":" substituted “publishing” for “printing, reprinting, wrapping, binding, and distributing” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/c/1"},"text":"Pub. L. 113–235, § 1301(c)(1)","children":[],"tail":", substituted “Director of the Government Publishing Office” for “Public Printer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1977—","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/94"},"text":"Pub. L. 95–94","children":[],"tail":" substituted “Costs of publication, etc.” for “Cost of publication; appropriations authorized; penalty mail privilege” in section catchline, added subsec. (a), designated former first paragraph as subsec. (b) and inserted provision restricting coverage to the other publications of the Federal Register program and struck out provision requiring payments for the Federal Register to be covered into the Treasury as miscellaneous receipts and former second paragraph relating to penalty mail privileges for the Federal Register."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id122c81a0-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id122c81a1-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Government Publishing Office” substituted for “Government Printing Office” wherever appearing in text on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/b"},"text":"section 1301(b) of Pub. L. 113–235","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s301"},"text":"section 301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id122c81a2-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1977 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/94/tIV/s408/b"},"text":"Pub. L. 95–94, title IV, § 408(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1977-08-05"},"text":"Aug. 5, 1977","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/91/683"},"text":"91 Stat. 683","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/94/tIV/s408/b"},"text":"“The amendments made by subsection (a) [amending this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1977-10-01"},"text":"October 1, 1977","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
