{"tag":"section","attrib":{"id":"id125761cf-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3552"},"text":null,"children":[{"tag":"num","attrib":{"value":"3552"},"text":"§ 3552.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id125761d0-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3552/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Except as provided under subsection (b), the definitions under section 3502 shall apply to this subchapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id125761d1-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3552/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Additional Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id125761d2-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3552/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “binding operational directive” means a compulsory direction to an agency that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id125761d3-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3552/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is for purposes of safeguarding Federal information and information systems from a known or reasonably suspected information security threat, vulnerability, or risk;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125761d4-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3552/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be in accordance with policies, principles, standards, and guidelines issued by the Director; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125761d5-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3552/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may be revised or repealed by the Director if the direction issued on behalf of the Director is not in accordance with policies and principles developed by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125761d6-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3552/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “incident” means an occurrence that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id125761d7-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3552/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" actually or imminently jeopardizes, without lawful authority, the integrity, confidentiality, or availability of information or an information system; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125761d8-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3552/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" constitutes a violation or imminent threat of violation of law, security policies, security procedures, or acceptable use policies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125761d9-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3552/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “information security” means protecting information and information systems from unauthorized access, use, disclosure, disruption, modification, or destruction in order to provide—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id125761da-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3552/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrity, which means guarding against improper information modification or destruction, and includes ensuring information nonrepudiation and authenticity;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125761db-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3552/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" confidentiality, which means preserving authorized restrictions on access and disclosure, including means for protecting personal privacy and proprietary information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125761dc-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3552/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" availability, which means ensuring timely and reliable access to and use of information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125761dd-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3552/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “information technology” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s11101"},"text":"section 11101 of title 40","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125761de-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3552/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “intelligence community” has the meaning given that term in section 3(4) of the National Security Act of 1947 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t50/s3003/4"},"text":"50 U.S.C. 3003(4)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125761df-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3552/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id125761e0-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3552/b/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The term “national security system” means any information system (including any telecommunications system) used or operated by an agency or by a contractor of an agency, or other organization on behalf of an agency—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id125761e1-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3552/b/6/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the function, operation, or use of which—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id125761e2-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3552/b/6/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involves intelligence activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id125761e3-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3552/b/6/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involves cryptologic activities related to national security;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id125761e4-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3552/b/6/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involves command and control of military forces;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id125761e5-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3552/b/6/A/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" involves equipment that is an integral part of a weapon or weapons system; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id125761e6-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3552/b/6/A/i/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subject to subparagraph (B), is critical to the direct fulfillment of military or intelligence missions; or","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id125761e7-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3552/b/6/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is protected at all times by procedures established for information that have been specifically authorized under criteria established by an Executive order or an Act of Congress to be kept classified in the interest of national defense or foreign policy.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125761e8-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3552/b/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Subparagraph (A)(i)(V) does not include a system that is to be used for routine administrative and business applications (including payroll, finance, logistics, and personnel management applications).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125761e9-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3552/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The term “Secretary” means the Secretary of Homeland Security.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id125761ea-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/283/s2/a"},"text":"Pub. L. 113–283, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3074"},"text":"128 Stat. 3074","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id125761eb-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id125761ec-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id125761ed-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to this section were contained in sections 3532 and 3542 of this title prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/283"},"text":"Pub. L. 113–283","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
