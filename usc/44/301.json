{"tag":"section","attrib":{"id":"id1216fd4e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s301"},"text":null,"children":[{"tag":"num","attrib":{"value":"301"},"text":"§ 301.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director of the Government Publishing Office: appointment","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1216fd4f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s301/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The President of the United States shall nominate and, by and with the advice and consent of the Senate, appoint a suitable person to take charge of and manage the Government Publishing Office. The title shall be Director of the Government Publishing Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1216fd50-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s301/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall be appointed for a term of 10 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1216fd51-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s301/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An individual appointed to the position of Director, by and with the advice and consent of the Senate, may be reappointed to that position in accordance with subsections (a) and (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1216fd52-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1239"},"text":"82 Stat. 1239","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/310/tII/s210/a/1"},"text":"Pub. L. 92–310, title II, § 210(a)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1972-06-06"},"text":"June 6, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/204"},"text":"86 Stat. 204","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/b"},"text":"Pub. L. 113–235, div. H, title I, § 1301(b)","children":[],"tail":", (c), (g), "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":", 2538; "},{"tag":"ref","attrib":{"href":"/us/pl/117/213/s1/a"},"text":"Pub. L. 117–213, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-10-17"},"text":"Oct. 17, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2251"},"text":"136 Stat. 2251","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1216fd53-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id1216fd54-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 31 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s17"},"text":"Jan. 12, 1895, ch. 23, § 17","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/603"},"text":"28 Stat. 603","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1917-06-12/ch27/s1"},"text":"June 12, 1917, ch. 27, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/40/173"},"text":"40 Stat. 173","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1923-02-20/ch98"},"text":"Feb. 20, 1923, ch. 98","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/1278"},"text":"42 Stat. 1278","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1925-03-04/ch549/s1"},"text":"Mar. 4, 1925, ch. 549, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/1299"},"text":"43 Stat. 1299","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1928-05-29/ch909"},"text":"May 29, 1928, ch. 909","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/45/1006"},"text":"45 Stat. 1006","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Changes are made in phraseology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1216fd55-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id1216fd56-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/213"},"text":"Pub. L. 117–213","children":[],"tail":" designated existing provisions as subsec. (a) and added subsecs. (b) and (c)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/g"},"text":"Pub. L. 113–235, § 1301(g)","children":[],"tail":", struck out “, who must be a practical printer and versed in the art of bookbinding,” after “suitable person” and substituted “The” for “His”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/c"},"text":"Pub. L. 113–235, § 1301(c)","children":[],"tail":", substituted “Director of the Government Publishing Office” for “Public Printer” in section catchline and text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/310"},"text":"Pub. L. 92–310","children":[],"tail":" struck out “; bond” in section catchline, and provisions from text which required the Public Printer to give a bond in the sum of $25,000."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id1216fd57-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id1216fd58-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/d"},"text":"Pub. L. 113–235, div. H, title I, § 1301(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/113/235/dH/tI/s1301/d"},"text":"“Any reference in any law other than in title 44, United States Code, or in any rule, regulation, certificate, directive, instruction, or other official paper in force on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":"] to the Public Printer shall be considered to refer and apply to the Director of the Government Publishing Office.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id1216fd59-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Application of 2022 Amendment to Incumbent","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/213/s1/b"},"text":"Pub. L. 117–213, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-10-17"},"text":"Oct. 17, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/2251"},"text":"136 Stat. 2251","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/117/213/s1/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“If there is an individual serving in the position of Director of the Government Publishing Office, by and with the advice and consent of the Senate, on the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2022-10-17"},"text":"Oct. 17, 2022","children":[],"tail":"]—"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the amendments made by subsection (a) [amending this section] shall apply with respect to the appointment of such individual; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term of the individual for purposes of subsection (b) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s301"},"text":"section 301 of title 44","children":[],"tail":", United States Code, as added by subsection (a), shall be considered to have started on the date on which the individual assumed the office of Director of the Government Publishing Office.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
