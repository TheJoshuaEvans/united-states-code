{"tag":"section","attrib":{"id":"id122a103d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1501"},"text":null,"children":[{"tag":"num","attrib":{"value":"1501"},"text":"§ 1501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"As used in this chapter, unless the context otherwise requires—","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"“document” means a Presidential proclamation or Executive order and an order, regulation, rule, certificate, code of fair competition, license, notice, or similar instrument, issued, prescribed, or promulgated by a Federal agency;","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"“Federal agency” or “agency” means the President of the United States, or an executive department, independent board, establishment, bureau, agency, institution, commission, or separate office of the administrative branch of the Government of the United States but not the legislative or judicial branches of the Government;","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"“person” means an individual, partnership, association, or corporation;","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"“publish” means to circulate for sale or distribution to the public, as determined by the Administrative Committee of the Federal Register; and","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"“National Archives of the United States” has the same meaning as in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s2901/11"},"text":"section 2901(11) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id122a103e-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","chil