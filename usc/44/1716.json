{"tag":"section","attrib":{"id":"id122ecb13-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1716"},"text":null,"children":[{"tag":"num","attrib":{"value":"1716"},"text":"§ 1716.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public documents for legations and consulates of United States","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Only books published by the Government, and usually known by the name of “Public Documents,” may be supplied to a legation or consulate of the United States as are first designated by the Secretary of State, by an order to be recorded in the State Department, as suitable for and required by the legation and consulate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id122ecb14-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1281"},"text":"82 Stat. 1281","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122ecb15-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122ecb16-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 91a (R.S. § 504).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
