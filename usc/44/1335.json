{"tag":"section","attrib":{"id":"id122a100b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1335"},"text":null,"children":[{"tag":"num","attrib":{"value":"1335"},"text":"§ 1335.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Naval Observatory Observations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In addition to the usual number of the Observations of the Naval Observatory, one thousand eight hundred copies shall be printed: three hundred for the Senate, seven hundred for the House of Representatives, and eight hundred for distribution by the Naval Observatory; and of the astronomical appendixes to the Observations, one thousand two hundred separate copies, and of the meteorological and magnetic observations one thousand separate copies, for distribution by the Naval Observatory.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id122a100c-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1271"},"text":"82 Stat. 1271","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122a100d-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122a100e-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 279 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s73"},"text":"Jan. 12, 1895, ch. 23, § 73","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/613"},"text":"28 Stat. 613","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
