{"tag":"section","attrib":{"id":"id123f93b5-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2501"},"text":null,"children":[{"tag":"num","attrib":{"value":"2501"},"text":"§ 2501.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Creation; composition; appointment and tenure; meetings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id123f93b6-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2501/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The National Historical Publications and Records Commission shall consist of 15 members as follows:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id123f93b7-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2501/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the following ex officio members:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id123f93b8-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2501/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Archivist of the United States, who shall be chairman;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123f93b9-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2501/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Librarian of Congress (or an alternate designated by the Librarian);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123f93ba-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2501/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one Senator, appointed by the President of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123f93bb-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2501/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one Representative, appointed by the Speaker of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123f93bc-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2501/a/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one member of the judicial branch of the Government, appointed by the Chief Justice of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123f93bd-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2501/a/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one representative of the Department of State to be appointed by the Secretary of State; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123f93be-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2501/a/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" one representative of the Department of Defense to be appointed by the Secretary of Defense;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id123f93bf-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2501/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" one member from each of the following organizations, appointed by the governing council or board of the respective organization:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id123f93c0-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2501/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the American Historical Association;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123f93c1-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2501/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Organization of American Historians;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123f93c2-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2501/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Society of American Archivists;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123f93c3-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2501/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the American Association for State and Local History;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123f93c4-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2501/a/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Association for Documentary Editing; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123f93c5-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2501/a/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the National Association for Government Archives and Records Administrators; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id123f93c6-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2501/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" two other members, outstanding in the fields of the social or physical sciences, the arts, or archival or library science, appointed by the President of the United States.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id123f93c7-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2501/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id123f93c8-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2501/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The members appointed under subsection (a) shall be appointed for not more than 2 terms of 4 years, except that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id123f93c9-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2501/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a member appointed under subsection (a)(1)(D) shall be appointed for not more than 4 terms of 2 years; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123f93ca-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2501/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Archivist and the Librarian of Congress are permanent ex officio members.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id123f93cb-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2501/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A member may continue to serve after the expiration of a term until a successor has been appointed, but not to exceed one year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id123f93cc-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2501/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Commission shall meet at least annually and at call of the Chairman.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id123f93cd-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2501/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Recusal","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Members of the Commission shall recuse themselves from voting on any matter that poses, or could potentially pose, a conflict of interest, including a matter that could benefit them or an entity they represent.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id123f93ce-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1293"},"text":"82 Stat. 1293","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/92/546/s1/a"},"text":"Pub. L. 92–546, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-10-25"},"text":"Oct. 25, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/1155"},"text":"86 Stat. 1155","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/93/536/s1/b"},"text":"Pub. L. 93–536, § 1(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1974-12-22"},"text":"Dec. 22, 1974","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/88/1735"},"text":"88 Stat. 1735","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/96/98/s2/b"},"text":"Pub. L. 96–98, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1979-11-01"},"text":"Nov. 1, 1979","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/93/731"},"text":"93 Stat. 731","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/tI/s107/b/9"},"text":"Pub. L. 98–497, title I, § 107(b)(9)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2287"},"text":"98 Stat. 2287","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/100/365/s2/a"},"text":"Pub. L. 100–365, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-07-13"},"text":"July 13, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/823"},"text":"102 Stat. 823","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/404/s3/a/1"},"text":"Pub. L. 110–404, § 3(a)(1)","children":[],"tail":", (b)(1), "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4282"},"text":"122 Stat. 4282","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id123f93cf-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id123f93d0-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., §§ 391 (part), 393(a) (","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title I, § 104, "},{"tag":"ref","attrib":{"href":"/us/stat/63/381"},"text":"63 Stat. 381","children":[],"tail":", and title V, § 503(a) as added "},{"tag":"ref","attrib":{"href":"/us/act/1950-09-05/ch849/s6/d"},"text":"Sept. 5, 1950, ch. 849, § 6(d)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/583"},"text":"64 Stat. 583","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section incorporates only the last sentence of paragraph (b) of former section 391. The balance of that section will be found in sections 1506, 2102, 2301, and 2902 of the revision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id123f93d1-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id123f93d2-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/404/s3/a/1/A"},"text":"Pub. L. 110–404, § 3(a)(1)(A)","children":[],"tail":", inserted “not more than 2” after “subsection (a) shall be appointed for” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b)(1)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/404/s3/a/1/B"},"text":"Pub. L. 110–404, § 3(a)(1)(B)","children":[],"tail":", substituted “not more than 4 terms” for “a term”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/404/s3/b/1"},"text":"Pub. L. 110–404, § 3(b)(1)","children":[],"tail":", added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1988—","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/365"},"text":"Pub. L. 100–365","children":[],"tail":" substituted “appointment and tenure; meetings” for “appointment and tenure” in section catchline, and amended text generally, revising and restating as subsecs. (a) to (c) provisions formerly contained in a single undesignated paragraph."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" struck out “The authority of the Administrator of General Services under "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s754"},"text":"section 754 of title 40","children":[],"tail":" to regroup, transfer, and distribute functions within the General Services Administration does not extend to the Commission or its functions.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1979—","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/98"},"text":"Pub. L. 96–98","children":[],"tail":" inserted “and Records” after “Publications”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1974—","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/536"},"text":"Pub. L. 93–536","children":[],"tail":" inserted provision relating to appointment and term of two members of Society of American Archivists, and two members of American Association for State and Local History."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1972—","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/546"},"text":"Pub. L. 92–546","children":[],"tail":" provided for two additional members of the Organization of American Historians to be appointed for terms of four years by Executive Board of Organization, one to be appointed for a term of two years and his successors for a term of four years."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id123f93d3-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id123f93d4-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2008 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/404/s3/a/2"},"text":"Pub. L. 110–404, § 3(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4282"},"text":"122 Stat. 4282","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/404/s3/a/2"},"text":"“The restrictions on the terms of members of the National Historical Publications and Records Commission provided in the amendments made by paragraph (1) [amending this section] shall apply to members serving on or after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/110/404/s3/b/2"},"text":"Pub. L. 110–404, § 3(b)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4283"},"text":"122 Stat. 4283","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/110/404/s3/b/2"},"text":"“The requirement of recusal provided in the amendment made by paragraph (1) [amending this section] shall apply to members of the National Historical Publications and Records Commission serving on or after the date of enactment of this Act [","children":[{"tag":"date","attrib":{"date":"2008-10-13"},"text":"Oct. 13, 2008","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id123f93d5-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1988 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/365/s2/b"},"text":"Pub. L. 100–365, § 2(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-07-13"},"text":"July 13, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/824"},"text":"102 Stat. 824","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/365/s2/b"},"text":"\n","children":[{"tag":"inline","attrib":{},"text":"“The amendment made by this section [amending this section] shall be effective on ","children":[{"tag":"date","attrib":{"date":"1989-01-01"},"text":"January 1, 1989","children":[],"tail":", and shall apply to the appointment of any member on the expiration of a predecessor’s term as follows:"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"“(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The next two members appointed to such Commission after such date shall be appointed pursuant to section 2501(a)(2)(E) and (F) of title 44, United States Code, as amended by this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"“(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding section 2501(b)(1), the first members appointed pursuant to section 2501(a)(2)(B) and (C) after ","children":[{"tag":"date","attrib":{"date":"1991-01-01"},"text":"January 1, 1991","children":[],"tail":", shall be appointed for terms of one year.”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id123f93d6-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-04-01"},"text":"Apr. 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/s301"},"text":"section 301 of Pub. L. 98–497","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s2102"},"text":"section 2102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
