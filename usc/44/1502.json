{"tag":"section","attrib":{"id":"id122a1045-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1502"},"text":null,"children":[{"tag":"num","attrib":{"value":"1502"},"text":"§ 1502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Custody and publishing of Federal documents; appointment of Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Archivist of the United States, acting through the Office of the Federal Register, is charged with the custody and, together with the Director of the Government Publishing Office, with the prompt and uniform publishing of the documents required or authorized to be published by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s1505"},"text":"section 1505 of this title","children":[],"tail":". There shall be at the head of the Office a director, appointed by, and who shall act under the general direction of, the Archivist of the United States in carrying out this chapter and the regulations prescribed under it."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id122a1046-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1273"},"text":"82 Stat. 1273","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/tI/s107/b/3"},"text":"Pub. L. 98–497, title I, § 107(b)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2287"},"text":"98 Stat. 2287","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/c/1"},"text":"Pub. L. 113–235, div. H, title I, § 1301(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/267/s2/a/1"},"text":"Pub. L. 118–267, § 2(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2983"},"text":"138 Stat. 2983","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122a1047-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122a1048-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 301 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-07-26/ch417/s1"},"text":"July 26, 1935, ch. 417, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/500"},"text":"49 Stat. 500","children":[],"tail":"; 1939 Reorg. Plan No. II, § 202, eff. "},{"tag":"date","attrib":{"date":"1939-07-01"},"text":"July 1, 1939","children":[],"tail":", 4 F.R. 2732, "},{"tag":"ref","attrib":{"href":"/us/stat/53/1435"},"text":"53 Stat. 1435","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title I, § 104(a), "},{"tag":"ref","attrib":{"href":"/us/stat/63/381"},"text":"63 Stat. 381","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id122a1049-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id122a104a-e3ef-