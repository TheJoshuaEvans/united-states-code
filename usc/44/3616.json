{"tag":"section","attrib":{"id":"id1260d843-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616"},"text":null,"children":[{"tag":"num","attrib":{"value":"3616"},"text":"§ 3616.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal Secure Cloud Advisory Committee","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1260d844-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment, Purposes, and Duties.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id1260d845-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"There is established a Federal Secure Cloud Advisory Committee (referred to in this section as the “Committee”) to ensure effective and ongoing coordination of agency adoption, use, authorization, monitoring, acquisition, and security of cloud computing products and services to enable agency mission and administrative priorities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1260d846-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of the Committee are the following:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1260d847-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" To examine the operations of FedRAMP and determine ways that authorization processes can continuously be improved, including the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id1260d848-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/a/2/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Measures to increase agency reuse of FedRAMP authorizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1260d849-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/a/2/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Proposed actions that can be adopted to reduce the burden, confusion, and cost associated with FedRAMP authorizations for cloud service providers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1260d84a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/a/2/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Measures to increase the number of FedRAMP authorizations for cloud computing products and services offered by small businesses concerns (as defined by section 3(a) of the Small Business Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632/a"},"text":"15 U.S.C. 632(a)","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1260d84b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/a/2/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Proposed actions that can be adopted to reduce the burden and cost of FedRAMP authorizations for agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1260d84c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Collect information and feedback on agency compliance with and implementation of FedRAMP requirements.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1260d84d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Serve as a forum that facilitates communication and collaboration among the FedRAMP stakeholder community.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1260d84e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Duties","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The duties of the Committee include providing advice and recommendations to the Administrator, the FedRAMP Board, and agencies on technical, financial, programmatic, and operational matters regarding secure adoption of cloud computing products and services.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1260d84f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Members.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id1260d850-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Composition","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Committee shall be comprised of not more than 15 members who are qualified representatives from the public and private sectors, appointed by the Administrator, in consultation with the Director, as follows:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1260d851-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator or the Administrator’s designee, who shall be the Chair of the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1260d852-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At least 1 representative each from the Cybersecurity and Infrastructure Security Agency and the National Institute of Standards and Technology.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1260d853-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At least 2 officials who serve as the Chief Information Security Officer within an agency, who shall be required to maintain such a position throughout the duration of their service on the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1260d854-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/b/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At least 1 official serving as Chief Procurement Officer (or equivalent) in an agency, who shall be required to maintain such a position throughout the duration of their service on the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1260d855-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/b/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At least 1 individual representing an independent assessment service.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1260d856-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/b/1/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At least 5 representatives from unique businesses that primarily provide cloud computing services or products, including at least 2 representatives from a small business concern (as defined by section 3(a) of the Small Business Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632/a"},"text":"15 U.S.C. 632(a)","children":[],"tail":"))."}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1260d857-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/b/1/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" At least 2 other representatives of the Federal Government as the Administrator determines necessary to provide sufficient balance, insights, or expertise to the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1260d858-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deadline for appointment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each member of the Committee shall be appointed not later than 90 days after the date of enactment of this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1260d859-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Period of appointment; vacancies.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1260d85a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each non-Federal member of the Committee shall be appointed for a term of 3 years, except that the initial terms for members may be staggered 1-, 2-, or 3-year terms to establish a rotation in which one-third of the members are selected each year. Any such member may be appointed for not more than 2 consecutive terms.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1260d85b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Vacancies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any vacancy in the Committee shall not affect its powers, but shall be filled in the same manner in which the original appointment was made. Any member appointed to fill a vacancy occurring before the expiration of the term for which the member’s predecessor was appointed shall be appointed only for the remainder of that term. A member may serve after the expiration of that member’s term until a successor has taken office.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1260d85c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Meetings and Rules of Procedures.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id1260d85d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Meetings","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee shall hold not fewer than 3 meetings in a calendar year, at such time and place as determined by the Chair.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1260d85e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Initial meeting","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 120 days after the date of enactment of this section, the Committee shall meet and begin the operations of the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1260d85f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Rules of procedure","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee may establish rules for the conduct of the business of the Committee if such rules are not inconsistent with this section or other applicable law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1260d860-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Employee Status.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id1260d861-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member of the Committee (other than a member who is appointed to the Committee in connection with another Federal appointment) shall not be considered an employee of the Federal Government by reason of any service as such a member, except for the purposes of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5703"},"text":"section 5703 of title 5","children":[],"tail":", relating to travel expenses."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1260d862-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Pay not permitted","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"A member of the Committee covered by paragraph (1) may not receive pay by reason of service on the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1260d863-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Applicability to the Federal Advisory Committee Act","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Section 14 of the Federal Advisory Committee Act (5 U.S.C. App.) ","children":[{"tag":"ref","attrib":{"idref":"fn002045"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002045"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" shall not apply to the Committee."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1260d864-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Detail of Employees","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Any Federal Government employee may be detailed to the Committee without reimbursement from the Committee, and such detailee shall retain the rights, status, and privileges of his or her regular employment without interruption.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1260d865-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Postal Services","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee may use the United States mails in the same manner and under the same conditions as agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1260d866-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id1260d867-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Interim reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Committee may submit to the Administrator and Congress interim reports containing such findings, conclusions, and recommendations as have been agreed to by the Committee.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1260d868-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3616/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Not later than 540 days after the date of enactment of this section, and annually thereafter, the Committee shall submit to the Administrator and Congress a report containing such findings, conclusions, and recommendations as have been agreed to by the Committee.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1260d869-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLIX/s5921/b"},"text":"Pub. L. 117–263, div. E, title LIX, § 5921(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3456"},"text":"136 Stat. 3456","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1260d86a-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id1260d86b-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For repeal of section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5921/d/1"},"text":"section 5921(d)(1) of Pub. L. 117–263","children":[],"tail":", see Effective Date of Repeal note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1260d86c-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id1260d86d-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in subsecs. (b)(2), (c)(2), and (h)(2), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 14 of the Federal Advisory Committee Act, referred to in subsec. (e), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/463/s14"},"text":"section 14 of Pub. L. 92–463","children":[],"tail":", which was set out in the Appendix to Title 5, Government Organization and Employees, and was repealed and restated as "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s1013"},"text":"section 1013 of Title 5","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":", §§ 3(a), 7, "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4204"},"text":"136 Stat. 4204","children":[],"tail":", 4361."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id1260d86e-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id1260d86f-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of Repeal","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLIX/s5921/d/1"},"text":"Pub. L. 117–263, div. E, title LIX, § 5921(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3458"},"text":"136 Stat. 3458","children":[],"tail":", provided that the repeal of this section is effective on the date that is 5 years after "},{"tag":"date","attrib"