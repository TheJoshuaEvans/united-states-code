{"tag":"section","attrib":{"id":"id12444f36-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3104"},"text":null,"children":[{"tag":"num","attrib":{"value":"3104"},"text":"§ 3104.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Certifications and determinations on transferred records","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"An official of the Government who is authorized to certify to facts on the basis of records in such official’s custody, may certify to facts on the basis of records that have been transferred by such official or such official’s predecessors to the Archivist, and may authorize the Archivist to certify to facts and to make administrative determinations on the basis of records transferred to the Archivist, notwithstanding any other law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id12444f37-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1298"},"text":"82 Stat. 1298","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/tI/s107/b/21"},"text":"Pub. L. 98–497, title I, § 107(b)(21)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2290"},"text":"98 Stat. 2290","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/187/s8/10"},"text":"Pub. L. 113–187, § 8(10)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-11-26"},"text":"Nov. 26, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2012"},"text":"128 Stat. 2012","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id12444f38-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id12444f39-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 396(d) (","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title V, § 506(d), as added "},{"tag":"ref","attrib":{"href":"/us/act/1950-09-05/ch849/s6/d"},"text":"Sept. 5, 1950, ch. 849, § 6(d)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/583"},"text":"64 Stat. 583","children":[],"tail":", and amended "},{"tag":"date","attrib":{"date":"1964-02-05"},"text":"Feb. 5, 1964","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/88/265"},"text":"Pub. L. 88–265","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/78/8"},"text":"78 Stat. 8","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id12444f3a-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id12444f3b-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/187"},"text":"Pub. L. 113–187","children":[],"tail":" substituted “such official’s custody” for “his custody” and “such official or such official’s predecessors” for “him or his predecessors”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"