{"tag":"section","attrib":{"id":"id12209a50-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s737"},"text":null,"children":[{"tag":"num","attrib":{"value":"737"},"text":"§ 737.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Binding for Senate library","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of the Senate may make requisition upon the Director of the Government Publishing Office for the binding for the Senate library of books he considers necessary, at a cost not to exceed $200 per year.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id12209a51-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1254"},"text":"82 Stat. 1254","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/c/1"},"text":"Pub. L. 113–235, div. H, title I, § 1301(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id12209a52-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id12209a53-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 168 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-03-02/ch189/s1"},"text":"Mar. 2, 1895, ch. 189, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/958"},"text":"28 Stat. 958","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id12209a54-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id12209a55-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235"},"text":"Pub. L. 113–235","children":[],"tail":" substituted “Director of the Government Publishing Office” for “Public Printer”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
