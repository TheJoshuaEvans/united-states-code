{"tag":"section","attrib":{"id":"id12255504-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1113"},"text":null,"children":[{"tag":"num","attrib":{"value":"1113"},"text":"§ 1113.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports: exclusion of irrelevant matter","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Executive officers, before transmitting their annual reports, shall carefully examine them and all accompanying documents, and exclude all matter, including engravings, maps, drawings, and illustrations, except such as they certify in their letters transmitting the reports are necessary and relate entirely to the transaction of the public business.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id12255505-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1263"},"text":"82 Stat. 1263","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id12255506-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id12255507-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 219 (part) (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s94"},"text":"Jan. 12, 1895, ch. 23, § 94","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/623"},"text":"28 Stat. 623","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section incorporates only the second clause of former section 219. The balance will be found in section 1102 of the revision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
