{"tag":"section","attrib":{"id":"id122ecb42-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1901"},"text":null,"children":[{"tag":"num","attrib":{"value":"1901"},"text":"§ 1901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definition of Government publication","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"“Government publication” as used in this chapter, means informational matter which is published as an individual document at Government expense, or as required by law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id122ecb43-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1283"},"text":"82 Stat. 1283","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122ecb44-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122ecb45-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 81a (","children":[{"tag":"ref","attrib":{"href":"/us/pl/87/579/s1"},"text":"Pub. L. 87–579, § 1","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1962-08-09"},"text":"Aug. 9, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/352"},"text":"76 Stat. 352","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
