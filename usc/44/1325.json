{"tag":"section","attrib":{"id":"id12279fd7-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1325"},"text":null,"children":[{"tag":"num","attrib":{"value":"1325"},"text":"§ 1325.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Labor Statistics, Bureau of: report of Commissioner","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In addition to the usual number of the report of the Commissioner of Labor Statistics, twenty-five thousand copies shall be printed: five thousand for the Senate, ten thousand for the House of Representatives, and ten thousand for distribution by the Commissioner.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id12279fd8-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1269"},"text":"82 Stat. 1269","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id12279fd9-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id12279fda-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 271 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s73"},"text":"Jan. 12, 1895, ch. 23, § 73","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/614"},"text":"28 Stat. 614","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1913-03-04/ch141/s3"},"text":"Mar. 4, 1913, ch. 141, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/37/737"},"text":"37 Stat. 737","children":[],"tail":")."}],"t