{"tag":"section","attrib":{"id":"id12279fc3-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1321"},"text":null,"children":[{"tag":"num","attrib":{"value":"1321"},"text":"§ 1321.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Hydrographic Surveys; foreign surveys","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Appropriations made for the preparation or publication of foreign hydrographic surveys may be applicable only upon approval by the Secretary of the Navy, after a report from three competent naval officers that the original data for proposed charts justify their publication. The Secretary of the Navy shall order a board of three naval officers to examine and report upon the data before he approves an application of moneys to the preparation or publication of charts or hydrographic surveys.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id12279fc4-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1269"},"text":"82 Stat. 1269","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id12279fc5-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id12279fc6-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 265 (R.S. § 3686; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s78"},"text":"Jan. 12, 1895, ch. 23, § 78","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/621"},"text":"28 Stat. 621","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
