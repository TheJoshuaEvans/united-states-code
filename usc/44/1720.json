{"tag":"section","attrib":{"id":"id122ecb2c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1720"},"text":null,"children":[{"tag":"num","attrib":{"value":"1720"},"text":"§ 1720.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Documents not needed by departments to be turned over to Superintendent of Documents","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Public documents accumulating in the several executive departments, bureaus, and offices, not needed for official use, shall be turned over to the Superintendent of Documents annually for distribution or sale.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id122ecb2d-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1282"},"text":"82 Stat. 1282","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122ecb2e-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122ecb2f-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 78 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s67"},"text":"Jan. 12, 1895, ch. 23, § 67","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/611"},"text":"28 Stat. 611","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
