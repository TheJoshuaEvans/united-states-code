{"tag":"section","attrib":{"id":"id12444f78-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3303"},"text":null,"children":[{"tag":"num","attrib":{"value":"3303"},"text":"§ 3303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lists and schedules of records to be submitted to the Archivist by head of each Government agency","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The head of each agency of the United States Government shall submit to the Archivist, under regulations promulgated as provided by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3302"},"text":"section 3302 of this title","children":[],"tail":"—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id12444f79-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3303/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lists of any records in the custody of the agency that have been photographed, microphotographed, or digitized under the regulations and that, as a consequence, do not appear to have sufficient value to warrant their further preservation by the Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id12444f7a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3303/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" lists of other records in the custody of the agency not needed by it in the transaction of its current business and that do not appear to have sufficient administrative, legal, research, or other value to warrant their further preservation by the Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id12444f7b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3303/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" schedules proposing the disposal after the lapse of specified periods of time of records of a specified form or character that either have accumulated in the custody of the agency or may accumulate after the submission of the schedules and apparently will not after the lapse of the period specified have sufficient administrative, legal, research, or other value to warrant their further preservation by the Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id12444f7c-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1299"},"text":"82 Stat. 1299","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/tI/s107/b/23"},"text":"Pub. L. 98–497, title I, § 107(b)(23)","children":[],"tail":", (25)(A), "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2290"},"text":"98 Stat. 2290","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/187/s5/c"},"text":"Pub. L. 113–187, § 5(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-11-26"},"text":"Nov. 26, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2010"},"text":"128 Stat. 2010","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id12444f7d-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id12444f7e-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 368 (","children":[{"tag":"ref","attrib"