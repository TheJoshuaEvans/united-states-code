{"tag":"section","attrib":{"id":"id1222e465-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s901"},"text":null,"children":[{"tag":"num","attrib":{"value":"901"},"text":"§ 901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional Record: arrangement, style, contents, and indexes","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Joint Committee on Printing shall control the arrangement and style of the Congressional Record, and while providing that it shall be substantially a verbatim report of proceedings, shall take all needed action for the reduction of unnecessary bulk. It shall provide for the publication of an index of the Congressional Record semimonthly during and at the close of sessions of Congress.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id1222e466-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1255"},"text":"82 Stat. 1255","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1222e467-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id1222e468-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 181 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s13"},"text":"Jan. 12, 1895, ch. 23, § 13","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/603"},"text":"28 Stat. 603","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
