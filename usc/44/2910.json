{"tag":"section","attrib":{"id":"id12444efa-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2910"},"text":null,"children":[{"tag":"num","attrib":{"value":"2910"},"text":"§ 2910.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of Freedmen’s Bureau records","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Archivist shall preserve the records of the Bureau of Refugees, Freedmen, and Abandoned Lands, commonly referred to as the “Freedmen’s Bureau”, by using—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id12444efb-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2910/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" microfilm technology for preservation of the documents comprising these records so that they can be maintained for future generations; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id12444efc-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2910/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results of the pilot project with the University of Florida to create future partnerships with Howard University and other institutions for the purposes of indexing these records and making them more easily accessible to the public, including historians, genealogists, and students, and for any other purposes determined by the Archivist.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id12444efd-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/444/s2/a"},"text":"Pub. L. 106–444, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-11-06"},"text":"Nov. 6, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1929"},"text":"114 Stat. 1929","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id12444efe-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id12444eff-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id12444f00-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2910, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1297"},"text":"82 Stat. 1297","children":[],"tail":", provided for final authority of Administrator in records practices, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/94/575/s2/a/4"},"text":"Pub. L. 94–575, § 2(a)(4)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2726"},"text":"90 Stat. 2726","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
