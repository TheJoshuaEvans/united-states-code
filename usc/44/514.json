{"tag":"section","attrib":{"id":"id121e294a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s514"},"text":null,"children":[{"tag":"num","attrib":{"value":"514"},"text":"§ 514.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of quality of paper","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Joint Committee on Printing shall determine differences of opinion between the Director of the Government Publishing Office and a contractor for paper respecting the paper’s quality; and the decision of the Committee is final as to the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id121e294b-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1245"},"text":"82 Stat. 1245","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/c/1"},"text":"Pub. L. 113–235, div. H, title I, § 1301(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id121e294c-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id121e294d-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 10 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s8"},"text":"Jan. 12, 1895, ch. 23, § 8","children":[],"tail":", "},{"tag":"ref",