{"tag":"section","attrib":{"id":"id122c81da-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1705"},"text":null,"children":[{"tag":"num","attrib":{"value":"1705"},"text":"§ 1705.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Printing additional copies for sale to public; regulations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director of the Government Publishing Office shall print additional copies of a Government publication, not confidential in character, required for sale to the public by the Superintendent of Documents, subject to regulation by the Joint Committee on Printing and without interference with the prompt execution of printing for the Government.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id122c81db-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1279"},"text":"82 Stat. 1279","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/c/1"},"text":"Pub. L. 113–235, div. H, title I, § 1301(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122c81dc-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122c81dd-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 72 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1922-05-11/ch189/s1"},"text":"May 11, 1922, ch. 189, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/42/541"},"text":"42 Stat. 541","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1932-06-30/ch314/s307"},"text":"June 30, 1932, ch. 314, § 307","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/409"},"text":"47 Stat. 409","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id122c81de-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id122c81df-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235"},"text":"Pub. L. 113–235","children":[],"tail":" substituted “Director of the Government Publishing Office” for “Public Printer”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
