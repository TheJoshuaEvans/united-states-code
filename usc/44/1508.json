{"tag":"section","attrib":{"id":"id122c8192-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1508"},"text":null,"children":[{"tag":"num","attrib":{"value":"1508"},"text":"§ 1508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication in Federal Register as notice of hearing","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A notice of hearing or of opportunity to be heard, required or authorized to be given by an Act of Congress, or which may otherwise properly be given, shall be deemed to have been given to all persons residing within the States of the Union and the District of Columbia, except in cases where notice by publication is insufficient in law, when the notice is published in the Federal Register at such a time that the period between the publication and the date fixed in the notice for the hearing or for the termination of the opportunity to be heard is—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id122c8193-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1508/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than the time specifically prescribed for the publication of the notice by the appropriate Act of Congress; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id122c8194-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1508/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not less than fifteen days when time for publication is not specifically prescribed by the Act, without prejudice, however, to the effectiveness of a notice of less than fifteen days where the shorter period is reasonable.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id122c8195-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1276"},"text":"82 Stat. 1276","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122c8196-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122c8197-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 308 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-07-26/ch417/s8"},"text":"July 26, 1935, ch. 417, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/502"},"text":"49 Stat. 502","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1959-06-25"},"text":"June 25, 1959","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/86/70/s34"},"text":"Pub. L. 86–70, § 34","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/73/149"},"text":"73 Stat. 149","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1960-07-12"},"text":"July 12, 1960","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/86/624/s33"},"text":"Pub. L. 86–624, § 33","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/74/421"},"text":"74 Stat. 421","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
