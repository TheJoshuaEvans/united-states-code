{"tag":"section","attrib":{"id":"id12444f21-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3102"},"text":null,"children":[{"tag":"num","attrib":{"value":"3102"},"text":"§ 3102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Establishment of program of management","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The head of each Federal agency shall establish and maintain an active, continuing program for the economical and efficient management of the records of the agency. The program, among other things, shall provide for","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id12444f22-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3102/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" effective controls over the creation and over the maintenance and use of records in the conduct of current business;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id12444f23-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3102/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" procedures for identifying records of general interest or use to the public that are appropriate for public disclosure, and for posting such records in a publicly accessible electronic format;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id12444f24-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3102/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cooperation with the Archivist in applying standards, procedures, and techniques designed to improve the management of records, promote the maintenance and security of records deemed appropriate for preservation, and facilitate the segregation and disposal of records of temporary value; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id12444f25-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3102/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" compliance with sections 2101–2117, 2501–2507, 2901–2909, and 3101–3107, of this title and the regulations issued under them.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id12444f26-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1298"},"text":"82 Stat. 1298","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/575/s3/a/1"},"text":"Pub. L. 94–575, § 3(a)(1)","children":[],"tail":", (2), "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2726"},"text":"90 Stat. 2726","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/tI/s107/b/19"},"text":"Pub. L. 98–497, title I, § 107(b)(19)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2290"},"text":"98 Stat. 2290","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/187/s9/f"},"text":"Pub. L. 113–187, § 9(f)","children":[],"tail":", formerly § 9(g), "},{"tag":"date","attrib":{"date":"2014-11-26"},"text":"Nov. 26, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2014"},"text":"128 Stat. 2014","children":[],"tail":", renumbered § 9(f), "},{"tag":"ref","attrib":{"href":"/us/pl/115/85/s2/a/5"},"text":"Pub. L. 115–85, § 2(a)(5)","children":[],"tail":", "},{"tag"