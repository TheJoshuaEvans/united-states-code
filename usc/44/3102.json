 and redesignated former pars. (2) and (3) as (3) and (4), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/187"},"text":"Pub. L. 113–187","children":[],"tail":" struck out “the Administrator of General Services and” before “the Archivist”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Pars. (2), (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" inserted “and the Archivist” after “Administrator of General Services” in par. (2), and substituted “sections 2101–2117” for “sections 2101–2113” and struck out “2701,” before “2901” in par. (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/575/s3/a/1"},"text":"Pub. L. 94–575, § 3(a)(1)","children":[],"tail":", (2), substituted in par. (1) “the creation and over the maintenance” for “the creation, maintenance,” and in par. (3) reference to sections “2901–2909” for “2901, 2903–2909” of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id12444f2b-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id12444f2c-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2016 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/114/185"},"text":"Pub. L. 114–185","children":[],"tail":" applicable to any request for records under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":" made after "},{"tag":"date","attrib":{"date":"2016