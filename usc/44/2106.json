{"tag":"section","attrib":{"id":"id12313be2-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2106"},"text":null,"children":[{"tag":"num","attrib":{"value":"2106"},"text":"§ 2106.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Archivist shall submit to the Congress, in January of each year and at such other times as the Archivist finds appropriate, a report concerning the administration of functions of the Archivist, the Administration, the National Historical Publications and Records Commission, and the National Archives Trust Fund. Such report shall describe—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id12313be3-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2106/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" program administration and expenditures of funds, both appropriated and nonappropriated, by the Administration, the Commission, and the Trust Fund Board;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id12313be4-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2106/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" research projects and publications undertaken by Commission grantees, and by Trust Fund grantees, including detailed information concerning the receipt and use of all appropriated and nonappropriated funds;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id12313be5-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2106/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" by account, the moneys, securities, and other personal property received and held by the National Archives Trust Fund Board, and of its operations, including a listing of the purposes for which funds are transferred to the National Archives and Records Administration for expenditure to other Federal agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id12313be6-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2106/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the matters specified in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s2904/c/8"},"text":"section 2904(c)(8) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id12313be7-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497/tI/s102/a/2"},"text":"Pub. L. 98–497, title I, § 102(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2282"},"text":"98 Stat. 2282","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id12313be8-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id12313be9-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id12313bea-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2106 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s2110"},"text":"section 2110 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","at