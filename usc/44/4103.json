{"tag":"section","attrib":{"id":"id126348f1-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s4103"},"text":null,"children":[{"tag":"num","attrib":{"value":"4103"},"text":"§ 4103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Biennial report","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Not later than December 31 of each odd-numbered year, the Director of the Government Publishing Office shall submit to the Congress, with respect to the two preceding fiscal years, a report on the directory, the system of access, and the electronic storage facility referred to in section 4101(a). The report shall include a description of the functions involved, including a statement of cost savings in comparison with traditional forms of information distribution.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id126348f2-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/40/s2/a"},"text":"Pub. L. 103–40, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-08"},"text":"June 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/113"},"text":"107 Stat. 113","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/c/1"},"text":"Pub. L. 113–235, div. H, title I, § 1301(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id126348f3-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id126348f4-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},