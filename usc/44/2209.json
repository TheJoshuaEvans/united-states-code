{"tag":"section","attrib":{"id":"id123d235e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2209"},"text":null,"children":[{"tag":"num","attrib":{"value":"2209"},"text":"§ 2209.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure requirement for official business conducted using non-official electronic messaging accounts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id123d235f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2209/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The President, the Vice President, or a covered employee may not create or send a Presidential or Vice Presidential record using a non-official electronic message account unless the President, Vice President, or covered employee—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id123d2360-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2209/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" copies an official electronic messaging account of the President, Vice President, or covered employee in the original creation or transmission of the Presidential record or Vice Presidential record; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id123d2361-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2209/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forwards a complete copy of the Presidential or Vice Presidential record to an official electronic messaging account of the President, Vice President, or covered employee not later than 20 days after the original creation or transmission of the Presidential or Vice Presidential record.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id123d2362-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2209/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adverse Actions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The intentional violation of subsection (a) by a covered employee (including any rules, regulations, or other implementing guidelines), as determined by the appropriate supervisor, shall be a basis for disciplinary action in accordance with subchapter I, II, or V of chapter 75 of title 5, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id123d2363-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2209/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id123d2364-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2209/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Covered employee","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The term “covered employee” means—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id123d2365-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2209/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the immediate staff of the President;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123d2366-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2209/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the immediate staff of the Vice President;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123d2367-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2209/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit or individual of the Executive Office of the President whose function is to advise and assist the President; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123d2368-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2209/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a unit or individual of the Office of the Vice President whose function is to advise and assist the Vice President.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id123d2369-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2209/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Electronic messages","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “electronic messages” means electronic mail and other electronic messaging systems that are used for purposes of communicating between individuals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id123d236a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2209/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Electronic messaging account","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “electronic messaging account” means any account that sends electronic messages.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id123d236b-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/187/s2/e/1"},"text":"Pub. L. 113–187, § 2(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-11-26"},"text":"Nov. 26, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2006"},"text":"128 Stat. 2006","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
