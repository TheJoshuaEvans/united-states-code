{"tag":"section","attrib":{"id":"id124dc5a3-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505"},"text":null,"children":[{"tag":"num","attrib":{"value":"3505"},"text":"§ 3505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Assignment of tasks and deadlines","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id124dc5a4-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out the functions under this subchapter, the Director shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id124dc5a5-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in consultation with agency heads, set an annual Governmentwide goal for the reduction of information collection burdens by at least 10 percent during each of fiscal years 1996 and 1997 and 5 percent during each of fiscal years 1998, 1999, 2000, and 2001, and set annual agency goals to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id124dc5a6-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" reduce information collection burdens imposed on the public that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id124dc5a7-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" represent the maximum practicable opportunity in each agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id124dc5a8-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are consistent with improving agency management of the process for the review of collections of information established under section 3506(c); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id124dc5a9-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" improve information resources management in ways that increase the productivity, efficiency and effectiveness of Federal programs, including service delivery to the public;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id124dc5aa-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with selected agencies and non-Federal entities on a voluntary basis, conduct pilot projects to test alternative policies, practices, regulations, and procedures to fulfill the purposes of this subchapter, particularly with regard to minimizing the Federal information collection burden; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id124dc5ab-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" in consultation with the Administrator of General Services, the Director of the National Institute of Standards and Technology, the Archivist of the United States, and the Director of the Office of Personnel Management, develop and maintain a Governmentwide strategic plan for information resources management, that shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id124dc5ac-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the objectives and the means by which the Federal Government shall apply information resources to improve agency and program performance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id124dc5ad-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" plans for—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id124dc5ae-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/a/3/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reducing information burdens on the public, including reducing such burdens through the elimination of duplication and meeting shared data needs with shared resources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id124dc5af-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/a/3/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enhancing public access to and dissemination of, information, using electronic and other formats; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id124dc5b0-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/a/3/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" meeting the information technology needs of the Federal Government in accordance with the purposes of this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id124dc5b1-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of progress in applying information resources management to improve agency performance and the accomplishment of missions.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id124dc5b2-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of any pilot project conducted under subsection (a)(2), the Director may, after consultation with the agency head, waive the application of any administrative directive issued by an agency with which the project is conducted, including any directive requiring a collection of information, after giving timely notice to the public and the Congress regarding the need for such waiver.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id124dc5b3-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"ref","attrib":{"idref":"fn002035"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002035"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Two subsecs. (c) have been enacted."}],"tail":" "},{"tag":"inline","attrib":{},"text":"Inventory of Major Information Systems","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id124dc5b4-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of each agency shall develop and maintain an inventory of major information systems (including major national security systems) operated by or under the control of such agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id124dc5b5-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The identification of information systems in an inventory under this subsection shall include an identification of the interfaces between each such system and all other systems or networks, including those not operated by or under the control of the agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id124dc5b6-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such inventory shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id124dc5b7-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" updated at least annually;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id124dc5b8-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made available to the Comptroller General; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id124dc5b9-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" used to support information resources management, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id124dc5ba-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/c/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preparation and maintenance of the inventory of information resources under section 3506(b)(4);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id124dc5bb-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/c/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information technology planning, budgeting, acquisition, and management under section 3506(h), subtitle III of title 40, and related laws and guidance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id124dc5bc-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/c/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitoring, testing, and evaluation of information security controls under subchapter II;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id124dc5bd-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/c/3/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preparation of the index of major information systems required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/g"},"text":"section 552(g) of title 5","children":[],"tail":", United States Code; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id124dc5be-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/c/3/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preparation of information system inventories required for records management under chapters 21, 29, 31, and 33.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id124dc5bf-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall issue guidance for and oversee the implementation of the requirements of this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id124dc5c0-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"sup","attrib":{},"text":"1","children":[],"tail":" "},{"tag":"inline","attrib":{},"text":"Inventory of Information Systems","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id124dc5c1-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The head of each agency shall develop and maintain an inventory of the information systems (including national security systems) operated by or under the control of such agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id124dc5c2-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The identification of information systems in an inventory under this subsection shall include an identification of the interfaces between each such system and all other systems or networks, including those not operated by or under the control of the agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id124dc5c3-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Such inventory shall be—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id124dc5c4-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" updated at least annually;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id124dc5c5-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" made available to the Comptroller General; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id124dc5c6-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" used to support information resources management, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id124dc5c7-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/c/3/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preparation and maintenance of the inventory of information resources under section 3506(b)(4);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id124dc5c8-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/c/3/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information technology planning, budgeting, acquisition, and management under section 3506(h), subtitle III of title 40, and related laws and guidance;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id124dc5c9-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/c/3/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" monitoring, testing, and evaluation of information security controls under subchapter II;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id124dc5ca-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/c/3/C/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preparation of the index of major information systems required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552/g"},"text":"section 552(g) of title 5","children":[],"tail":", United States Code; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id124dc5cb-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/c/3/C/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" preparation of information system inventories required for records management under chapters 21, 29, 31, and 33.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id124dc5cc-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3505/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"tex