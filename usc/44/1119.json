{"tag":"section","attrib":{"id":"id12255523-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1119"},"text":null,"children":[{"tag":"num","attrib":{"value":"1119"},"text":"§ 1119.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Government publications as public property","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Government publications of a permanent nature furnished by authority of law to officers other than Members of Congress of the United States Government, for their official use, shall be stamped “Property of the United States Government,” and shall be preserved by them and delivered to their successors in office as a part of the property of the office.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id12255524-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1264"},"text":"82 Stat. 1264","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id12255525-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id12255526-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 92 (part) (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s74"},"text":"Jan. 12, 1895, ch. 23, § 74","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/620"},"text":"28 Stat. 620","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1936-06-20/ch630"},"text":"June 20, 1936, ch. 630","children":[],"tail":", title VII, § 11, "},{"tag":"ref","attrib":{"href":"/us/stat/49/1552"},"text":"49 Stat. 1552","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1962-08-09"},"text":"Aug. 9, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/87/679/s8"},"text":"Pub. L. 87–679, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/355"},"text":"76 Stat. 355","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section incorporates only the first sentence of former section 92. The balance will be found in section 1911 of the revision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
