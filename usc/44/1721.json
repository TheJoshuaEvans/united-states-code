{"tag":"section","attrib":{"id":"id122ecb30-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1721"},"text":null,"children":[{"tag":"num","attrib":{"value":"1721"},"text":"§ 1721.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exchange of documents by heads of departments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Heads of departments may exchange surplus documents for other documents and books required by them, when it is to the advantage of the public service.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id122ecb31-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1282"},"text":"82 Stat. 1282","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122ecb32-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122ecb33-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 93 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s95"},"text":"Jan. 12, 1895, ch. 23, § 95","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/623"},"text":"28 Stat. 623","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
