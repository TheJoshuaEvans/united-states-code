{"tag":"section","attrib":{"id":"id12444f01-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2911"},"text":null,"children":[{"tag":"num","attrib":{"value":"2911"},"text":"§ 2911.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disclosure requirement for official business conducted using non-official electronic messaging accounts","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id12444f02-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2911/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"An officer or employee of an executive agency may not create or send a record using a non-official electronic messaging account unless such officer or employee—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id12444f03-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2911/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" copies an official electronic messaging account of the officer or employee in the original creation or transmission of the record; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id12444f04-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2911/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" forwards a complete copy of the record to an official electronic messaging account of the officer or employee not later than 20 days after the original creation or transmission of the record.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id12444f05-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2911/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Adverse Actions","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The intentional violation of subsection (a) (including any rules, regulations, or other implementing guidelines), as determined by the appropriate supervisor, shall be a basis for disciplinary action in accordance with subchapter I, II, or V of chapter 75 of title 5, as the case may be.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id12444f06-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2911/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id12444f07-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2911/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Electronic messages","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “electronic messages” means electronic mail and other electronic messaging systems that are used for purposes of communicating between individuals.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id12444f08-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2911/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Electronic messaging account","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “electronic messaging account” means any account that sends electronic messages.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id12444f09-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2911/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Executive agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “executive agency” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s105"},"text":"section 105 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id12444f0a-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/187/s10/a"},"text":"Pub. L. 113–187, § 10(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-11-26"},"text":"Nov. 26, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2014"},"text":"128 Stat. 2014","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
