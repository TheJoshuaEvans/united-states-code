{"tag":"section","attrib":{"id":"id123f9424-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2506"},"text":null,"children":[{"tag":"num","attrib":{"value":"2506"},"text":"§ 2506.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Records to be kept by grantees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id123f9425-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2506/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each recipient of grant assistance under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s2504"},"text":"section 2504 of this title","children":[],"tail":" shall keep such records as the Archivist of the United States prescribes, including records which fully disclose the amount and disposition by the recipient of the proceeds of the grants, the total cost of the project or undertaking in connection with which funds are given or used, and the amount of that portion of the cost of the project or undertaking supplied by other sources, and any other records as will facilitate an effective audit."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id123f9426-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2506/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Archivist and the Comptroller General of the United States or their authorized representatives shall have access for the purposes of audit and examination to books, documents, papers, and records of the recipients that are pertinent to the grants received under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s2504"},"text":"section 2504 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id123f9427-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"hre