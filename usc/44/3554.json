{"tag":"section","attrib":{"id":"id12576255-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554"},"text":null,"children":[{"tag":"num","attrib":{"value":"3554"},"text":"§ 3554.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal agency responsibilities","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id12576256-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of each agency shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id12576257-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" be responsible for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id12576258-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" providing information security protections commensurate with the risk and magnitude of the harm resulting from unauthorized access, use, disclosure, disruption, modification, or destruction of—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id12576259-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information collected or maintained by or on behalf of the agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1257625a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information systems used or operated by an agency or by a contractor of an agency or other organization on behalf of an agency;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1257625b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" complying with the requirements of this subchapter, subchapter III of chapter 13 of title 41, and related policies, procedures, standards, and guidelines, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id1257625c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information security standards promulgated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s11331"},"text":"section 11331 of title 40","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1257625d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operational directives developed by the Secretary under section 3553(b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1257625e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" policies and procedures issued by the Director;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1257625f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information security standards and guidelines for national security systems issued in accordance with law and as directed by the President;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id12576260-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/a/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emergency directives issued by the Secretary under section 3553(h); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id12576261-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/a/1/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" responsibilities relating to assessing and avoiding, mitigating, transferring, or accepting supply chain risks under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t41/s1326"},"text":"section 1326 of title 41","children":[],"tail":", and complying with exclusion and removal orders issued under section 1323 of such title; and"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id12576262-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensuring that information security management processes are integrated with agency strategic, operational, and budgetary planning processes;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id12576263-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure that senior agency officials provide information security for the information and information systems that support the operations and assets under their control, including through—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id12576264-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assessing the risk and magnitude of the harm that could result from the unauthorized access, use, disclosure, disruption, modification, or destruction of such information or information systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id12576265-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" determining the levels of information security appropriate to protect such information and information systems in accordance with standards promulgated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s11331"},"text":"section 11331 of title 40","children":[],"tail":", for information security classifications and related requirements;"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id12576266-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementing policies and procedures to cost-effectively reduce risks to an acceptable level; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id12576267-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/a/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" periodically testing and evaluating information security controls and techniques to ensure that they are effectively implemented;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id12576268-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" delegate to the agency Chief Information Officer established under section 3506 (or comparable official in an agency not covered by such section) the authority to ensure compliance with the requirements imposed on the agency under this subchapter, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1259d269-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" designating a senior agency information security officer who shall—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id1259d26a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/a/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out the Chief Information Officer’s responsibilities under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1259d26b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/a/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" possess professional qualifications, including training and experience, required to administer the functions described under this section;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1259d26c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/a/3/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have information security duties as that official’s primary duty; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1259d26d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/a/3/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" head an office with the mission and resources to assist in ensuring agency compliance with this section;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1259d26e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and maintaining an agencywide information security program as required by subsection (b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1259d26f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" developing and maintaining information security policies, procedures, and control techniques to address all applicable requirements, including those issued under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3553"},"text":"section 3553 of this title","children":[],"tail":" and "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s11331"},"text":"section 11331 of title 40","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1259d270-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/a/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training and overseeing personnel with significant responsibilities for information security with respect to such responsibilities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1259d271-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/a/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assisting senior agency officials concerning their responsibilities under paragraph (2);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d272-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the agency has trained personnel sufficient to assist the agency in complying with the requirements of this subchapter and related policies, procedures, standards, and guidelines;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d273-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that the agency Chief Information Officer, in coordination with other senior agency officials, reports annually to the agency head on the effectiveness of the agency information security program, including progress of remedial actions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d274-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that senior agency officials, including chief information officers of component agencies or equivalent officials, carry out responsibilities under this subchapter as directed by the official delegated authority under paragraph (3); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d275-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that all personnel are held accountable for complying with the agency-wide information security program implemented under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1259d276-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency Program","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each agency shall develop, document, and implement an agency-wide information security program to provide information security for the information and information systems that support the operations and assets of the agency, including those provided or managed by another agency, contractor, or other source, that includes—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1259d277-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" periodic assessments of the risk and magnitude of the harm that could result from the unauthorized access, use, disclosure, disruption, modification, or destruction of information and information systems that support the operations and assets of the agency, which may include using automated tools consistent with standards and guidelines promulgated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s11331"},"text":"section 11331 of title 40","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d278-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" policies and procedures that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1259d279-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" are based on the risk assessments required by paragraph (1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1259d27a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" cost-effectively reduce information security risks to an acceptable level;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1259d27b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that information security is addressed throughout the life cycle of each agency information system; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1259d27c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" ensure compliance with—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id1259d27d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/b/2/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the requirements of this subchapter;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1259d27e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/b/2/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" policies and procedures as may be prescribed by the Director, and information security standards promulgated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s11331"},"text":"section 11331 of title 40","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1259d27f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/b/2/D/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" minimally acceptable system configuration requirements, as determined by the agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1259d280-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/b/2/D/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other applicable requirements, including standards and guidelines for national security systems issued in accordance with law and as directed by the President;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d281-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" subordinate plans for providing adequate information security for networks, facilities, and systems or groups of information systems, as appropriate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d282-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" security awareness training to inform personnel, including contractors and other users of information systems that support the operations and assets of the agency, of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1259d283-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/b/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" information security risks associated with their activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1259d284-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/b/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" their responsibilities in complying with agency policies and procedures designed to reduce these risks;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d285-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/b/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" periodic testing and evaluation of the effectiveness of information security policies, procedures, and practices, to be performed with a frequency depending on risk, but no less than annually, of which such testing—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1259d286-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/b/5/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include testing of management, operational, and technical controls of every information system identified in the inventory required under section 3505(c); ","children":[{"tag":"ref","attrib":{"idref":"fn002040"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002040"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Section 3505 contains two subsecs. (c)."}],"tail":null}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1259d287-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/b/5/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include testing relied on in an evaluation under section 3555; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1259d288-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/b/5/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall include using automated tools, consistent with standards and guidelines promulgated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s11331"},"text":"section 11331 of title 40","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d289-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/b/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a process for planning, implementing, evaluating, and documenting remedial action to address any deficiencies in the information security policies, procedures, and practices of the agency;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d28a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/b/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" procedures for detecting, reporting, and responding to security incidents, which—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1259d28b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/b/7/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall be consistent with the standards and guidelines described in section 3556(b);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1259d28c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/b/7/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" may include using automated tools; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1259d28d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/b/7/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall include—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id1259d28e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/b/7/C/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" mitigating risks associated with such incidents before substantial damage is done;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1259d28f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/b/7/C/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notifying and consulting with the Federal information security incident center established in section 3556; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1259d290-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/b/7/C/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" notifying and consulting with, as appropriate—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id1259d291-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/b/7/C/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" law enforcement agencies and relevant Offices of Inspector General and Offices of General Counsel;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id1259d292-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/b/7/C/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an office designated by the President for any incident involving a national security system;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id1259d293-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/b/7/C/iii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" for a major incident, the committees of Congress described in subsection (c)(1)—","children":[],"tail":null},{"tag":"item","attrib":{"id":"id1259d294-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/b/7/C/iii/III/aa"},"text":null,"children":[{"tag":"num","attrib":{"value":"aa"},"text":"(aa)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not later than 7 days after the date on which there is a reasonable basis to conclude that the major incident has occurred; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"item","attrib":{"id":"id1259d295-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/b/7/C/iii/III/bb"},"text":null,"children":[{"tag":"num","attrib":{"value":"bb"},"text":"(bb)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after the initial notification under item (aa), within a reasonable period of time after additional information relating to the incident is discovered, including the summary required under subsection (c)(1)(A)(i); and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id1259d296-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/b/7/C/iii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other agency or office, in accordance with law or as directed by the President; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d297-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/b/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" plans and procedures to ensure continuity of operations for information systems that support the operations and assets of the agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1259d298-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency Reporting.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id1259d299-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Annual report.—","children":[],"tail":null}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1259d29a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each agency shall submit to the Director, the Secretary, the Committee on Government Reform, the Committee on Homeland Security, and the Committee on Science of the House of Representatives, the Committee on Homeland Security and Governmental Affairs and the Committee on Commerce, Science, and Transportation of the Senate, the appropriate authorization and appropriations committees of Congress, and the Comptroller General a report on the adequacy and effectiveness of information security policies, procedures, and practices, including—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id1259d29b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/c/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of each major information security incident or related sets of incidents, including summaries of—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id1259d29c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/c/1/A/i/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the threats and threat actors, vulnerabilities, and impacts relating to the incident;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id1259d29d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/c/1/A/i/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the risk assessments conducted under section 3554(a)(2)(A) of the affected information systems before the date on which the incident occurred;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id1259d29e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/c/1/A/i/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the status of compliance of the affected information systems with applicable security requirements at the time of the incident; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id1259d29f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/c/1/A/i/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the detection, response, and remediation actions;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1259d2a0-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/c/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the total number of information security incidents, including a description of incidents resulting in significant compromise of information security, system impact levels, types of incident, and locations of affected systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1259d2a1-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/c/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a description of each major information security incident that involved a breach of personally identifiable information, as defined by the Director, including—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id1259d2a2-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/c/1/A/iii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the number of individuals whose information was affected by the major information security incident; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id1259d2a3-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/c/1/A/iii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the information that was breached or exposed; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1259d2a4-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/c/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any other information as the Director or the Secretary, in consultation with the Director, may require.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1259d2a5-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Unclassified report.—","children":[],"tail":null}],"tail":null},{"tag":"clause","attrib":{"id":"id1259d2a6-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/c/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each report submitted under subparagraph (A) shall be in unclassified form, but may include a classified annex.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id1259d2a7-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/c/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Access to information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of an agency shall ensure that, to the greatest extent practicable, information is included in the unclassified version of the reports submitted by the agency under subparagraph (A).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d2a8-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Other plans and reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each agency shall address the adequacy and effectiveness of information security policies, procedures, and practices in management plans and reports.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1259d2a9-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Performance Plan","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id1259d2aa-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In addition to the requirements of subsection (c), each agency, in consultation with the Director, shall include as part of the performance plan required under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1115"},"text":"section 1115 of title 31","children":[],"tail":" a description of—"}],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1259d2ab-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the time periods; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1259d2ac-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the resources, including budget, staffing, and training,","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"that are necessary to implement the program required under subsection (b).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d2ad-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The description under paragraph (1) shall be based on the risk assessments required under subsection (b)(1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1259d2ae-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3554/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Public Notice and Comment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each agency shall provide the public with timely notice and opportunities for comment on proposed information security policies and procedures to the extent that such policies and procedures affect communication with the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1259d2af-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/283/s2/a"},"text":"Pub. L. 113–283, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3078"},"text":"128 Stat. 3078","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/114/113/dN/tII/s229/b"},"text":"Pub. L. 114–113, div. N, title II, § 229(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2015-12-18"},"text":"Dec. 18, 2015","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/129/2974"},"text":"129 Stat. 2974","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/115/390/tII/s204/a/2"},"text":"Pub. L. 115–390, title II, § 204(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-12-21"},"text":"Dec. 21, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5193"},"text":"132 Stat. 5193","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1259d2b0-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1259d2b1-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"prio