{"tag":"section","attrib":{"id":"id1260d78f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3606"},"text":null,"children":[{"tag":"num","attrib":{"value":"3606"},"text":"§ 3606.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" E-Government report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1260d790-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3606/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Not later than March 1 of each year, the Director shall submit an E-Government status report to the Committee on Governmental Affairs of the Senate and the Committee on Government Reform of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1260d791-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3606/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The report under subsection (a) shall contain—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1260d792-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3606/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the information reported by agencies under section 202(f) ","children":[{"tag":"ref","attrib":{"idref":"fn002043"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002043"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" So in original. Probably should be “section 202(g)”."}],"tail":" of the E-Government Act of 2002;"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1260d793-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3606/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the information required to be reported by section 3604(f); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1260d794-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3606/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of compliance by the Federal Government with other goals and provisions of the E-Government Act of 2002.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1260d795-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/347/tI/s101/a"},"text":"Pub. L. 107–347, title I, § 101(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/2909"},"text":"116 Stat. 2909","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1260d796-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1260d797-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id1260d798-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The E-Government Act of 2002, referred to in subsec. (b)(3), is ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/347"},"text":"Pub. L. 107–347","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-12-17"},"text":"Dec. 17, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"