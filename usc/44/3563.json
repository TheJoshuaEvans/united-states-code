{"tag":"section","attrib":{"id":"id1259d32d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3563"},"text":null,"children":[{"tag":"num","attrib":{"value":"3563"},"text":"§ 3563.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Statistical agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1259d32e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3563/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id1259d32f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3563/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Each statistical agency or unit shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1259d330-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3563/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" produce and disseminate relevant and timely statistical information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1259d331-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3563/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct credible and accurate statistical activities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1259d332-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3563/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct objective statistical activities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1259d333-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3563/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" protect the trust of information providers by ensuring the confidentiality and exclusive statistical use of their responses.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d334-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3563/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Policies, best practices, and procedures","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Each statistical agency or unit shall adopt policies, best practices, and appropriate procedures to implement the responsibilities described in paragraph (1).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1259d335-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3563/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Support From Other Agencies","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of each agency shall enable, support, and facilitate statistical agencies or units in carrying out the responsibilities described in subsection (a)(1).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1259d336-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3563/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Regulations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director shall prescribe regulations to carry out this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1259d337-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3563/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1259d338-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3563/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Accurate","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “accurate”, when used with respect to statistical activities, means statistics that consistently match the events and trends being measured.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d339-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3563/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Confidentiality","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “confidentiality” means a quality or condition accorded to information as an obligation not to disclose that information to an unauthorized party.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d33a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3563/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Objective","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “objective”, when used with respect to statistical activities, means accurate, clear, complete, and unbiased.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d33b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3563/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Relevant","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “relevant”, when used with respect to statistical information, means processes, activities, and other such matters likely to be useful to policymakers and public and private sector data users.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1259d33c-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/435/tIII/s302/a"},"text":"Pub. L. 115–435, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5546"},"text":"132 Stat. 5546","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1259d33d-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id1259d33e-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id1259d33f-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/435/s403"},"text":"section 403 of Pub. L. 115–435","children":[],"tail":", set out as an Effective Date of 2019 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s306"},"text":"section 306 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
