{"tag":"section","attrib":{"id":"id123d231c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2205"},"text":null,"children":[{"tag":"num","attrib":{"value":"2205"},"text":"§ 2205.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Exceptions to restricted access","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"Notwithstanding any restrictions on access imposed pursuant to sections 2204 and 2208 of this title—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id123d231d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2205/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Archivist and persons employed by the National Archives and Records Administration who are engaged in the performance of normal archival work shall be permitted access to Presidential records in the custody of the Archivist;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id123d231e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2205/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" subject to any rights, defenses, or privileges which the United States or any agency or person may invoke, Presidential records shall be made available—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id123d231f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2205/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" pursuant to subpoena or other judicial process issued by a court of competent jurisdiction for the purposes of any civil or criminal investigation or proceeding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123d2320-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2205/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to an incumbent President if such records contain information that is needed for the conduct of current business of the incumbent President’s office and that is not otherwise available; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123d2321-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2205/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to either House of Congress, or, to the extent of matter within its jurisdiction, to any committee or subcommittee thereof if such records contain information that is needed for the conduct of its business and that is not otherwise available; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id123d2322-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2205/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Presidential records of a former President shall be available to such former President or the former President’s designated representative.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id123d2323-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/591/s2/a"},"text":"Pub. L. 95–591, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-11-04"},"text":"Nov. 4, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/2527"},"text":"92 Stat. 2527","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/tI/s107/b/7"},"text":"Pub. L. 98–497, title I, § 107(b)(7)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2287"},"text":"98 Stat. 2287","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/187"},"text":"Pub. L. 113–187","children":[],"tail":", §§ 2(a)(2)(B), 8(5), "},{"tag":"date","attrib":{"date":"2014-11-26"},"text":"Nov. 26, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2005"},"text":"128 Stat. 2005","children":[],"tail":", 2012.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id123d2324-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id123d2325-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id123d2326-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/187/s2/a/2/B/i"},"text":"Pub. L. 113–187, § 2(a)(2)(B)(i)","children":[],"tail":", substituted “sections 2204 and 2208 of this title” for “section 2204” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(A). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/187/s2/a/2/B/ii"},"text":"Pub. L. 113–187, § 2(a)(2)(B)(ii)","children":[],"tail":", substituted “subpoena” for “subpena”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2)(B). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/187/s8/5/A"},"text":"Pub. L. 113–187, § 8(5)(A)","children":[],"tail":", substituted “the incumbent President’s” for “his”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/187/s8/5/B"},"text":"Pub. L. 113–187, § 8(5)(B)","children":[],"tail":", substituted “the former President’s” for “his”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—Par. (1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" substituted “National Archives and Records Administration” for “National Archives and Records Service of the General Services Administration”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id123d2327-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id123d2328-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-04-01"},"text":"Apr. 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/s301"},"text":"section 301 of Pub. L. 98–497","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s2102"},"text":"section 2102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id123d2329-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective with respect to Presidential records created during a term of office of President beginning on or after ","children":[{"tag":"date","attrib":{"date":"1981-01-20"},"text":"Jan. 20, 1981","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/95/591/s3"},"text":"section 3 of Pub. L. 95–591","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s2201"},"text":"section 2201 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
