{"tag":"section","attrib":{"id":"id122a0feb-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1329"},"text":null,"children":[{"tag":"num","attrib":{"value":"1329"},"text":"§ 1329.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Mint: reports of Director","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There may be printed, in the discretion of the Secretary of the Treasury, for distribution by the Treasury Department, two thousand copies of the annual report of the Director of the Mint on the operations of the mint and assay offices with appendices, and of the annual report of the Director of the Mint on the production of precious metals.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id122a0fec-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1270"},"text":"82 Stat. 1270","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122a0fed-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122a0fee-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 273 (","children":[{"tag":"date","attrib":{"date":"1907-03-04"},"text":"Mar. 4, 1907","children":[],"tail":", No. 24, "},{"tag":"ref","attrib":{"href":"/us/stat/34/1424"},"text":"34 Stat. 1424","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
