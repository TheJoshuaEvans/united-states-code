{"tag":"section","attrib":{"id":"id12209a40-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s735"},"text":null,"children":[{"tag":"num","attrib":{"value":"735"},"text":"§ 735.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Binding for Senators","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Each Senator is entitled to the binding in half morocco, or material not more expensive, of one copy of each public document to which he is entitled, an account of which shall be kept by the Secretary of the Senate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id12209a41-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1254"},"text":"82 Stat. 1254","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s223/4/A"},"text":"Pub. L. 104–186, title II, § 223(4)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1751"},"text":"110 Stat. 1751","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id12209a42-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id12209a43-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 160 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s2"},"text":"Jan. 12, 1895, ch. 23, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/601"},"text":"28 Stat. 601","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1907-03-01/ch2284/s1"},"text":"Mar. 1, 1907, ch. 2284, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/1013"},"text":"34 Stat. 1013","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id12209a44-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id12209a45-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":", in section catchline, substituted “Senators” for “Members of Congress”, and in text, substituted “Senator” for “Member of Congress” and struck out “and Clerk of the House of Representatives, respectively” after “Secretary of the Senate”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id12209a46-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id12209a47-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Written Requests for Bound Copies of Documents","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/59/tVIII"},"text":"Pub. L. 94–59, title VIII","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-07-25"},"text":"July 25, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/296"},"text":"89 Stat. 296","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/59/tVIII"},"text":"“Hereafter, notwithstanding any other provisions of law appropriations for the binding of copies of public documents by Committees for distribution to Senators and Representatives (including Delegates to Congress and the Resident Commissioner from Puerto Rico) shall not be available for a Senator or Representative unless such Senator or Representative specifically, in writing, requests that he receive bound copies of any such documents.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
