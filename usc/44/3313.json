{"tag":"section","attrib":{"id":"id1246bfc2-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3313"},"text":null,"children":[{"tag":"num","attrib":{"value":"3313"},"text":"§ 3313.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Moneys from sale of records payable into the Treasury","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Moneys derived by agencies of the Government from the sale of records disposed of under this chapter shall be paid into the Treasury of the United States unless otherwise required by law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id1246bfc3-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1302"},"text":"82 Stat. 1302","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1246bfc4-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id1246bfc5-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 379 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1943-07-07/ch192/s14"},"text":"July 7, 1943, ch. 192, § 14","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/57/383"},"text":"57 Stat. 383","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
