{"tag":"section","attrib":{"id":"id125036b0-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3508"},"text":null,"children":[{"tag":"num","attrib":{"value":"3508"},"text":"§ 3508.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Determination of necessity for information; hearing","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Before approving a proposed collection of information, the Director shall determine whether the collection of information by the agency is necessary for the proper performance of the functions of the agency, including whether the information shall have practical utility. Before making a determination the Director may give the agency and other interested persons an opportunity to be heard or to submit statements in writing. To the extent, if any, that the Director determines that the collection of information by an agency is unnecessary for any reason, the agency may not engage in the collection of information.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id125036b1-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/13/s2"},"text":"Pub. L. 104–13, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-05-22"},"text":"May 22, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/179"},"text":"109 Stat. 179","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id125036b2-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id125036b3-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id125036b4-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3508, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/511/s2/a"},"text":"Pub. L. 96–511, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-11"},"text":"Dec. 11, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2821"},"text":"94 Stat. 2821","children":[],"tail":", related to determination of whether collection of information is necessary for proper performance of functions of agency prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/104/13"},"text":"Pub. L. 104–13","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 3508, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1304"},"text":"82 Stat. 1304","children":[],"tail":", related to unlawful disclosure of information, penalties, and release of information to other agencies, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/96/511"},"text":"Pub. L. 96–511","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s3510/b"},"text":"section 3510(b) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id125036b5-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id125036b6-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading",