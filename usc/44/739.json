{"tag":"section","attrib":{"id":"id12209a5c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s739"},"text":null,"children":[{"tag":"num","attrib":{"value":"739"},"text":"§ 739.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Senate and House document rooms; superintendents","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There shall be one document room of the Senate and one of the House of Representatives, to be designated, respectively, the “Senate and House document room.” Each shall be in charge of a superintendent, who shall be appointed by the Secretary of the Senate and the Clerk of the House, respectively, together with the necessary assistants. The Senate document room shall be under the jurisdiction of the Secretary of the Senate.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id12209a5d-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1254"},"text":"82 Stat. 1254","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s223/5"},"text":"Pub. L. 104–186, title II, § 223(5)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1751"},"text":"110 Stat. 1751","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1222e44e-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id1222e44f-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. 