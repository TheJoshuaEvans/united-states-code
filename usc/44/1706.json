{"tag":"section","attrib":{"id":"id122c81e0-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1706"},"text":null,"children":[{"tag":"num","attrib":{"value":"1706"},"text":"§ 1706.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Printing and sale of extra copies of documents","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director of the Government Publishing Office shall furnish to applicants giving notice before the matter is put to press, not exceeding two hundred and fifty to any one applicant, copies of bills, reports, and documents. The applicants shall pay in advance the price of the printing. The printing of these copies for private parties may not interfere with the printing for the Government.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id122c81e1-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1279"},"text":"82 Stat. 1279","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/c/1"},"text":"Pub. L. 113–235, div. H, title I, § 1301(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122c81e2-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122c81e3-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 114 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s42"},"text":"Jan. 12, 1895, ch. 23, § 42","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/607"},"text":"28 Stat. 607","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1932-06-30/ch314/s307"},"text":"June 30, 1932, ch. 314, § 307","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/47/409"},"text":"47 Stat. 409","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id122c81e4-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id122c81e5-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235"},"text":"Pub. L. 113–235","children":[],"tail":" substituted “Director of the Government Publishing Office” for “Public Printer”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
