{"tag":"section","attrib":{"id":"id1260d828-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3615"},"text":null,"children":[{"tag":"num","attrib":{"value":"3615"},"text":"§ 3615.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports to Congress; GAO report","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1260d829-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3615/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 1 year after the date of enactment of this section, and annually thereafter, the Director shall submit to the appropriate congressional committees a report that includes the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1260d82a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3615/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" During the preceding year, the status, efficiency, and effectiveness of the General Services Administration under section 3609 and agencies under section 3613 and in supporting the speed, effectiveness, sharing, reuse, and security of authorizations to operate for secure cloud computing products and services.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1260d82b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3615/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Progress towards meeting the metrics required under section 3609(d).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1260d82c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3615/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Data on FedRAMP authorizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1260d82d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3615/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The average length of time to issue FedRAMP authorizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1260d82e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3615/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number of FedRAMP authorizations submitted, issued, and denied for the preceding year.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1260d82f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3615/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A review of progress made during the preceding year in advancing automation techniques to securely automate FedRAMP processes and to accelerate reporting under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1260d830-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3615/a/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The number and characteristics of authorized cloud computing products and services in use at each agency consistent with guidance provided by the Director under section 3614.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1260d831-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3615/a/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" A review of FedRAMP measures to ensure the security of data stored or processed by cloud service providers, which may include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1260d832-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3615/a/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" geolocation restrictions for provided products or services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1260d833-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3615/a/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disclosures of foreign elements of supply chains of acquired products or services;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1260d834-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3615/a/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" continued disclosures of ownership of cloud service providers by foreign entities; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1260d835-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3615/a/8/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" encryption for data processed, stored, or transmitted by cloud service providers.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1260d836-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3615/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"GAO Report","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Not later than 180 days after the date of enactment of this section, the Comptroller General of the United States shall report to the appropriate congressional committees an assessment of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1260d837-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3615/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The costs incurred by agencies and cloud service providers relating to the issuance of FedRAMP authorizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1260d838-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3615/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The extent to which agencies have processes in place to continuously monitor the implementation of cloud computing products and services operating as Federal information systems.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1260d839-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3615/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" How often and for which categories of products and services agencies use FedRAMP authorizations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1260d83a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3615/b/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The unique costs and potential burdens incurred by cloud computing companies that are small business concerns (as defined in section 3(a) of the Small Business Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s632/a"},"text":"15 U.S.C. 632(a)","children":[],"tail":") as a part of the FedRAMP authorization process."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1260d83b-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLIX/s5921/b"},"text":"Pub. L. 117–263, div. E, title LIX, § 5921(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3455"},"text":"136 Stat. 3455","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1260d83c-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"prospectiveAmendment","id":"id1260d83d-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Repeal of Section","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For repeal of section by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5921/d/1"},"text":"section 5921(d)(1) of Pub. L. 117–263","children":[],"tail":", see Effective Date of Repeal note below."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1260d83e-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id1260d83f-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of enactment of this section, referred to in text, is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263"},"text":"Pub. L. 117–263","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id1260d840-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id1260d841-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of Repeal","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/dE/tLIX/s5921/d/1"},"text":"Pub. L. 117–263, div. E, title LIX, § 5921(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/3458"},"text":"136 Stat. 3458","children":[],"tail":", provided that the repeal of this section is effective on the date that is 5 years after "},{"tag":"date","attrib":{"date":"2022-12-23"},"text":"Dec. 23, 2022","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id1260d842-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Construction","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For rule of construction regarding ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5921"},"text":"section 5921 of Pub. L. 117–263","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/117/263/s5921/e"},"text":"section 5921(e) of Pub. L. 117–263","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s3607"},"text":"section 3607 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
