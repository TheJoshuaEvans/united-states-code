{"tag":"section","attrib":{"id":"id121e29a9-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s711"},"text":null,"children":[{"tag":"num","attrib":{"value":"711"},"text":"§ 711.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Printing Acts, joint resolutions, and treaties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director of the Government Publishing Office, on receiving from the Archivist of the United States a copy of an Act or joint resolution, or from the Secretary of State, a copy of a treaty, shall print an accurate copy and transmit it in duplicate to the Archivist of the United States or to the Secretary of State, as the case may be, for revision. On the return of one of the revised duplicates, he shall make the marked corrections and print the number specified by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s709"},"text":"section 709 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id121e29aa-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1249"},"text":"82 Stat. 1249","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/tI/s107/b/1"},"text":"Pub. L. 98–497, title I, § 107(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2286"},"text":"98 Stat. 2286","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/c/1"},"text":"Pub. L. 113–235, div. H, title I, § 1301(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"t