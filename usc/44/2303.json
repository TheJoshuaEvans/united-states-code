{"tag":"section","attrib":{"id":"id123f9386-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2303"},"text":null,"children":[{"tag":"num","attrib":{"value":"2303"},"text":"§ 2303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Powers and obligations of the Board; liability of members","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Except as otherwise provided by this chapter, the Board shall have all the usual powers and obligations of a trustee with respect to property and funds administered by it, but the members of the Board are not personally liable, except for malfeasance.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id123f9387-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1292"},"text":"82 Stat. 1292","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/tII/s202/a"},"text":"Pub. L. 98–497, title II, § 202(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2293"},"text":"98 Stat. 2293","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id123f9388-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id123f9389-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 300ff (","children":[{"tag":"ref","attrib":{"href":"/us/act/1941-07-09/ch284/s6"},"text":"July 9, 1941, ch. 284, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/55/582"},"text":"55 Stat. 582","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id123f938a-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id123f938b-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" amended section generally, inserting “Except as otherwise provided by this chapter,”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id123f938c-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id123f938d-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1985-04-01"},"text":"Apr. 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/s301"},"text":"section 301 of Pub. L. 98–497","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s2102"},"text":"section 2102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
