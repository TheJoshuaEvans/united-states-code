{"tag":"section","attrib":{"id":"id12255550-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1302"},"text":null,"children":[{"tag":"num","attrib":{"value":"1302"},"text":"§ 1302.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Agriculture, Department of: monthly crop report and other publications","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Secretary of Agriculture may cause to be printed the number of copies of the monthly crop report, and of other reports and bulletins of not more than one hundred octavo pages, he considers necessary.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id12255551-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1266"},"text":"82 Stat. 1266","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id12255552-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id12255553-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 213 (part) (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s89"},"text":"Jan. 12, 1895, ch. 23, § 89","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/622"},"text":"28 Stat. 622","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section incorporates only the first clause of the second sentence of the second paragraph of former section 213. The balance of section 213 will be found in sections 1102, 1116, 1308, 1309, 1310, 1336.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
