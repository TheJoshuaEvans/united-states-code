{"tag":"section","attrib":{"id":"id12209a0e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s728"},"text":null,"children":[{"tag":"num","attrib":{"value":"728"},"text":"§ 728.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" United States Statutes at Large: distribution","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director of the Government Publishing Office, after the final adjournment of each regular session of Congress, shall print and bind copies of the United States Statutes at Large, to be charged to the congressional allotment for printing and binding. The Joint Committee on Printing shall control the number and distribution of the copies.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Director of the Government Publishing Office shall print and, after the end of each calendar year, bind and deliver to the Superintendent of Documents a number of copies of the United States Treaties and Other International Agreements not exceeding the number of copies of the United States Statutes at Large required for distribution in the manner provided by law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id12209a0f-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1252"},"text":"82 Stat. 1252","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/c/1"},"text":"Pub. L. 113–235, div. H, title I, § 1301(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id12209a10-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id12209a11-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 196a (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s73"},"text":"Jan. 12, 1895, ch. 23, § 73","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/615"},"text":"28 Stat. 615","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1936-06-20/ch630"},"text":"June 20, 1936, ch. 630","children":[],"tail":", title VI, § 9, "},{"tag":"ref","attrib":{"href":"/us/stat/49/1551"},"text":"49 Stat. 1551","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1938-06-16/ch477/s2"},"text":"June 16, 1938, ch. 477, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/761"},"text":"52 Stat. 761","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1950-09-23/ch1001/s4"},"text":"Sept. 23, 1950, ch. 1001, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/980"},"text":"64 Stat. 980","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1952-07-10/ch632/s2"},"text":"July 10, 1952, ch. 632, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/540"},"text":"66 Stat. 540","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id12209a12-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id12209a13-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235"},"text":"Pub. L. 113–235","children":[],"tail":" substituted “Director of the Government Publishing Office” for “Public Printer” in two places."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id12209a14-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id12209a15-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Written Requests for Copies of United States Statutes at Large","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/440/tX"},"text":"Pub. L. 94–440, title X","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-01"},"text":"Oct. 1, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/1459"},"text":"90 Stat. 1459","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/440/tX"},"text":"“Hereafter, notwithstanding any other provisions of law, appropriations for the automatic distribution to Senators and Representatives (including Delegates to Congress and the Resident Commissioner from Puerto Rico) of copies of the United States Statutes at Large shall not be available with respect to any Senator or Representative unless such Senator or Representative specifically, in writing, requests that he receive copies of such document.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
