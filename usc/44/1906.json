{"tag":"section","attrib":{"id":"id122ecb5e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1906"},"text":null,"children":[{"tag":"num","attrib":{"value":"1906"},"text":"§ 1906.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Land-grant colleges constituted depositories","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Land-grant colleges are constituted depositories to receive Government publications subject to the depository laws.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id122ecb5f-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1284"},"text":"82 Stat. 1284","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122ecb60-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122ecb61-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 85 (part) (","children":[{"tag":"ref","attrib":{"href":"/us/act/1907-03-01/ch2284/s4"},"text":"Mar. 1, 1907, ch. 2284, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/1014"},"text":"34 Stat. 1014","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1938-06-25/ch708"},"text":"June 25, 1938, ch. 708","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/52/1206"},"text":"52 Stat. 1206","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1962-08-09"},"text":"Aug. 9, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/87/579"},"text":"Pub. L. 87–579","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/354"},"text":"76 Stat. 354","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section is from the last paragraph of former section 85; the remainder of that section will be found in section 1903 of the revision.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
