{"tag":"section","attrib":{"id":"id126348da-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s4101"},"text":null,"children":[{"tag":"num","attrib":{"value":"4101"},"text":"§ 4101.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Electronic directory; online access to publications; electronic storage facility","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id126348db-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s4101/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Superintendent of Documents, under the direction of the Director of the Government Publishing Office, shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id126348dc-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s4101/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" maintain an electronic directory of Federal electronic information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id126348dd-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s4101/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" provide a system of online access to the Congressional Record, the Federal Register, and, as determined by the Superintendent of Documents, other appropriate publications distributed by the Superintendent of Documents; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id126348de-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s4101/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" operate an electronic storage facility for Federal electronic information to which online access is made available under paragraph (2).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id126348df-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s4101/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Departmental Requests","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To the extent practicable, the Superintendent of Documents shall accommodate any request by the head of a department or agency to include in the system of access referred to in subsection (a)(2) information that is under the control of the department or agency involved.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id126348e0-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s4101/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In carrying out this section, the Superintendent of Documents shall consult—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id126348e1-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s4101/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" users of the directory and the system of access provided for under subsection (a); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id126348e2-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s4101/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other providers of similar information services.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The purpose of such consultation shall be to assess the quality and value of the directory and the system, in light of user needs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id126348e3-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/40/s2/a"},"text":"Pub. L. 103–40, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-08"},"text":"June 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/112"},"text":"107 Stat. 112","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/c/1"},"text":"Pub. L. 113–235, div. H, title I, § 1301(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id126348e4-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id126348e5-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id126348e6-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235"},"text":"Pub. L. 113–235","children":[],"tail":" substituted “Director of the Government Publishing Office” for “Public Printer” in introductory provisions."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id126348e7-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id126348e8-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Status Report","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/40/s3"},"text":"Pub. L. 103–40, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-08"},"text":"June 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/113"},"text":"107 Stat. 113","children":[],"tail":", required the Public Printer to submit a report to Congress on the status of the directory, the system of access, and the electronic storage facility referred to in "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s4101"},"text":"section 4101 of this title","children":[],"tail":" by "},{"tag":"date","attrib":{"date":"1994-06-30"},"text":"June 30, 1994","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id126348e9-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Operational Deadline","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/103/40/s4/a"},"text":"Pub. L. 103–40, § 4(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-08"},"text":"June 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/113"},"text":"107 Stat. 113","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/103/40/s4/a"},"text":"“The directory, the system of access, and the electronic storage facility referred to in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s4101"},"text":"section 4101 of title 44","children":[],"tail":", United States Code, as added by section 2(a), shall be operational not later than one year after the date of the enactment of this Act ["},{"tag":"date","attrib":{"date":"1993-06-08"},"text":"June 8, 1993","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
