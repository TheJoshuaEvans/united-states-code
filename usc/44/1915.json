{"tag":"section","attrib":{"id":"id122ecb89-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1915"},"text":null,"children":[{"tag":"num","attrib":{"value":"1915"},"text":"§ 1915.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Highest State appellate court libraries as depository libraries","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Upon the request of the highest appellate court of a State, the Director of the Government Publishing Office is authorized to designate the library of that court as a depository library. The provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s1911"},"text":"section 1911 of this title","children":[],"tail":" shall not apply to any library so designated."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id122ecb8a-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/92/368/s1/a"},"text":"Pub. L. 92–368, § 1(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1972-08-10"},"text":"Aug. 10, 1972","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/86/507"},"text":"86 Stat. 507","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/c/1"},"text":"Pub. L. 113–235, div. H, title I, § 1301(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122ecb8b-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id122ecb8c-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id122ecb8d-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235"},"text":"Pub. L. 113–235","children":[],"tail":" substituted “Director of the Government Publishing Office” for “Public Printer”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
