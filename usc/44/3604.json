{"tag":"section","attrib":{"id":"id125e8e52-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604"},"text":null,"children":[{"tag":"num","attrib":{"value":"3604"},"text":"§ 3604.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" E-Government Fund","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id125e8e53-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id125e8e54-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There is established in the Treasury of the United States the E-Government Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e55-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Fund shall be administered by the Administrator of the General Services Administration to support projects approved by the Director, assisted by the Administrator of the Office of Electronic Government, that enable the Federal Government to expand its ability, through the development and implementation of innovative uses of the Internet or other electronic methods, to conduct activities electronically.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e56-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Projects under this subsection may include efforts to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id125e8e57-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/a/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make Federal Government information and services more readily available to members of the public (including individuals, businesses, grantees, and State and local governments);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e58-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/a/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" make it easier for the public to apply for benefits, receive services, pursue business opportunities, submit information, and otherwise conduct transactions with the Federal Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e59-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/a/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enable Federal agencies to take advantage of information technology in sharing information and conducting transactions with each other and with State and local governments.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id125e8e5a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id125e8e5b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Administrator shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id125e8e5c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/b/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establish procedures for accepting and reviewing proposals for funding;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e5d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/b/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" consult with interagency councils, including the Chief Information Officers Council, the Chief Financial Officers Council, and other interagency management councils, in establishing procedures and reviewing proposals; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e5e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/b/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" assist the Director in coordinating resources that agencies receive from the Fund with other resources available to agencies for similar purposes.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e5f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When reviewing proposals and managing the Fund, the Administrator shall observe and incorporate the following procedures:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id125e8e60-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/b/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A project requiring substantial involvement or funding from an agency shall be approved by a senior official with agencywide authority on behalf of the head of the agency, who shall report directly to the head of the agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e61-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/b/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Projects shall adhere to fundamental capital planning and investment control processes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e62-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/b/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Agencies shall identify in their proposals resource commitments from the agencies involved and how these resources would be coordinated with support from the Fund, and include plans for potential continuation of projects after all funds made available from the Fund are expended.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e63-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/b/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" After considering the recommendations of the interagency councils, the Director, assisted by the Administrator, shall have final authority to determine which of the candidate projects shall be funded from the Fund.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e64-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/b/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Agencies shall assess the results of funded projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id125e8e65-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In determining which proposals to recommend for funding, the Administrator—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id125e8e66-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" shall consider criteria that include whether a proposal—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id125e8e67-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies the group to be served, including citizens, businesses, the Federal Government, or other governments;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e68-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" indicates what service or information the project will provide that meets needs of groups identified under subparagraph (A);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e69-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensures proper security and protects privacy;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e6a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" is interagency in scope, including projects implemented by a primary or single agency that—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id125e8e6b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/c/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" could confer benefits on multiple agencies; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id125e8e6c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/c/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" have the support of other agencies; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e6d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/c/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has performance objectives that tie to agency missions and strategic goals, and interim results that relate to the objectives; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e6e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" may also rank proposals based on criteria that include whether a proposal—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id125e8e6f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/c/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has Governmentwide application or implications;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e70-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/c/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" has demonstrated support by the public to be served;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e71-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/c/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" integrates Federal with State, local, or tribal approaches to service delivery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e72-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/c/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies resource commitments from nongovernmental sectors;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e73-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/c/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies resource commitments from the agencies involved;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e74-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/c/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" uses web-based technologies to achieve objectives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e75-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/c/2/G"},"text":null,"children":[{"tag":"num","attrib":{"value":"G"},"text":"(G)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identifies records management and records access strategies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e76-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/c/2/H"},"text":null,"children":[{"tag":"num","attrib":{"value":"H"},"text":"(H)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supports more effective citizen participation in and interaction with agency activities that further progress toward a more citizen-centered Government;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e77-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/c/2/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" directly delivers Government information and services to the public or provides the infrastructure for delivery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e78-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/c/2/J"},"text":null,"children":[{"tag":"num","attrib":{"value":"J"},"text":"(J)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" supports integrated service delivery;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e79-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/c/2/K"},"text":null,"children":[{"tag":"num","attrib":{"value":"K"},"text":"(K)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" describes how business processes across agencies will reflect appropriate transformation simultaneous to technology implementation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e7a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/c/2/L"},"text":null,"children":[{"tag":"num","attrib":{"value":"L"},"text":"(L)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is new or innovative and does not supplant existing funding streams within agencies.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id125e8e7b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Fund may be used to fund the integrated Internet-based system under section 204 of the E-Government Act of 2002.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id125e8e7c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" None of the funds provided from the Fund may be transferred to any agency until 15 days after the Administrator of the General Services Administration has submitted to the Committees on Appropriations of the Senate and the House of Representatives, the Committee on Governmental Affairs of the Senate, the Committee on Government Reform of the House of Representatives, and the appropriate authorizing committees of the Senate and the House of Representatives, a notification and description of how the funds are to be allocated and how the expenditure will further the purposes of this chapter.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id125e8e7d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id125e8e7e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall report annually to Congress on the operation of the Fund, through the report established under section 3606.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e7f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The report under paragraph (1) shall describe—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id125e8e80-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/f/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" all projects which the Director has approved for funding from the Fund; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e81-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/f/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the results that have been achieved to date for these funded projects.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id125e8e82-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id125e8e83-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" There are authorized to be appropriated to the Fund—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id125e8e84-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/g/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $45,000,000 for fiscal year 2003;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e85-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/g/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $50,000,000 for fiscal year 2004;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e86-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/g/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $100,000,000 for fiscal year 2005;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e87-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/g/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" $150,000,000 for fiscal year 2006; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125e8e88-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/g/1/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" such sums as are necessary for fiscal year 2007.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125e8e89-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3604/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Funds appropriated under this subsection shall remain available until expended.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id