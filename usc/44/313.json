{"tag":"section","attrib":{"id":"id121bb8bc-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s313"},"text":null,"children":[{"tag":"num","attrib":{"value":"313"},"text":"§ 313.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Examining boards: paper; bindery materials; machinery","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Deputy Director of the Government Publishing Office, the superintendent of printing, and a person designated by the Joint Committee on Printing, shall constitute a board to examine and report in writing on paper delivered under contract, or by purchase or otherwise, at the Government Publishing Office.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Deputy Director of the Government Publishing Office, the superintendent of binding, and a person designated by the Joint Committee on Printing shall constitute a board to examine and report in writing on material, except paper, for the use of the bindery.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Deputy Director of the Government Publishing Office, the superintendent of printing, and a person designated by the Joint Committee on Printing shall constitute a board of condemnation, who, upon the call of the Director of the Government Publishing Office, shall determine the condition of presses and other machinery and material used in the Government Publishing Office, with a view to condemnation.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id121bb8bd-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1242"},"text":"82 Stat. 1242","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/b"},"text":"Pub. L. 113–235, div. H, title I, § 1301(b)","children":[],"tail":", (c)(1), (e)(1), "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id121bb8be-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id121bb8bf-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on U.S. Code, 1964 ed., § 49 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s20"},"text":"Jan. 12, 1895, ch. 23, § 20","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/603"},"text":"28 Stat. 603","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1908-05-27/ch200/s1"},"text":"May 27, 1908, ch. 200, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/35/382"},"text":"35 Stat. 382","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1924-06-07/ch303/s1"},"text":"June 7, 1924, ch. 303, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/509"},"text":"43 Stat. 509","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id121bb8c0-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id121bb8c1-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/e/1"},"text":"Pub. L. 113–235, § 1301(e)(1)","children":[],"tail":", substituted “Deputy Director of the Government Publishing Office” for “Deputy Public Printer” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/c/1"},"text":"Pub. L. 113–235, § 1301(c)(1)","children":[],"tail":", substituted “Director of the Government Publishing Office” for “Public Printer”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id121bb8c2-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id121bb8c3-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Government Publishing Office” substituted for “Government Printing Office” in text on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/b"},"text":"section 1301(b) of Pub. L. 113–235","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s301"},"text":"section 301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
