{"tag":"section","attrib":{"id":"id1225551f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1118"},"text":null,"children":[{"tag":"num","attrib":{"value":"1118"},"text":"§ 1118.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Documents beyond scope of ordinary departmental business","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A book or document not having to do with the ordinary business transactions of the executive departments may not be printed on the requisition of a department unless expressly authorized by Congress.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id12255520-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1264"},"text":"82 Stat. 1264","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id12255521-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id12255522-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 219a (","children":[{"tag":"ref","attrib":{"href":"/us/act/1905-03-03/ch1484/s1"},"text":"Mar. 3, 1905, ch. 1484, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/33/1249"},"text":"33 Stat. 1249","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
