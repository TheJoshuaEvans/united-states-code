{"tag":"section","attrib":{"id":"id12313bb8-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2103"},"text":null,"children":[{"tag":"num","attrib":{"value":"2103"},"text":"§ 2103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id12313bb9-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2103/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Archivist of the United States shall be appointed by the President by and with the advice and consent of the Senate. The Archivist shall be appointed without regard to political affiliations and solely on the basis of the professional qualifications required to perform the duties and responsibilities of the office of Archivist. The Archivist may be removed from office by the President. The President shall communicate the reasons for any such removal to each House of the Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id12313bba-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2103/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Archivist shall be compensated at the rate provided for level III of the Executive Schedule under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s5314"},"text":"section 5314 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id12313bbb-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2103/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" There shall be in the Administration a Deputy Archivist of the United States, who shall be appointed by and who shall serve at the pleasure of the Archivist. The Deputy Archivist shall be established as a career reserved position in the Senior Executive Service within the meaning of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3132/a/8"},"text":"section 3132(a)(8) of title 5","children":[],"tail":". The Deputy Archivist shall perform such functions as the Archivist shall designate. During any absence or disability of the Archivist, the Deputy Archivist shall act as Archivist. In the event of a vacancy in the office of the Archivist, the Deputy Archivist shall act as Archivist until an Archivist is appointed under subsection (a)."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id12313bbc-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497/tI/s102/a/2"},"text":"Pub. L. 98–497, title I, § 102(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2280"},"text":"98 Stat. 2280","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id12313bbd-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id12313bbe-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id12313bbf-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2103 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s2107"},"text":"section 2107 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id12313bc0-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id12313bc1-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1985-04-01"},"text":"Apr. 1, 1985","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/s301"},"text":"section 301 of Pub. L. 98–497","children":[],"tail":", set out as an Effective Date of 1984 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s2102"},"text":"section 2102 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
