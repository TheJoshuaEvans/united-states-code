{"tag":"section","attrib":{"id":"id123f945a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2703"},"text":null,"children":[{"tag":"num","attrib":{"value":"2703"},"text":"§ 2703.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Functions of the Committee","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"The Committee shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id123f945b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2703/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the management and preservation of the records of Congress;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id123f945c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2703/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report to and advise the Congress and the Archivist of the United States on such management and preservation; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id123f945d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2703/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id123f945e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2703/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" no later than ","children":[{"tag":"date","attrib":{"date":"1991-12-31"},"text":"December 31, 1991","children":[],"tail":", conduct a study and submit a report to the Congress on—"}],"tail":null},{"tag":"clause","attrib":{"id":"id123f945f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2703/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the effect any transfer of records of the National Archives and Records Administration from facilities located in Washington, D.C., to any location outside of Washington, D.C., shall have on the management and preservation of the records of Congress; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id123f9460-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2703/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the five year plan for the management and preservation of the records of Congress; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123f9461-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2703/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" no later than ","children":[{"tag":"date","attrib":{"date":"1995-12-31"},"text":"December 31, 1995","children":[],"tail":", conduct a study to update the report submitted under subparagraph (A)(ii), and submit a report to the Congress."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id123f9462-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509/tIV/s1/d/1"},"text":"Pub. L. 101–509, title IV, § 1(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1418"},"text":"104 Stat. 1418","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
