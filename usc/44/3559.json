{"tag":"section","attrib":{"id":"id1259d2f3-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3559"},"text":null,"children":[{"tag":"num","attrib":{"value":"3559"},"text":"§ 3559.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Federal websites required to be mobile friendly","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1259d2f4-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3559/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"If, on or after the date that is 180 days after the date of the enactment of this section, an agency creates a website that is intended for use by the public or conducts a redesign of an existing legacy website that is intended for use by the public, the agency shall ensure to the greatest extent practicable that the website is mobile friendly.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1259d2f5-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3559/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Definitions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1259d2f6-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3559/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “agency” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s551"},"text":"section 551 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d2f7-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3559/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Mobile friendly","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The term “mobile friendly” means, with respect to a website, that the website is configured in such a way that the website may be navigated, viewed, and accessed on a smartphone, tablet computer, or similar mobile device.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1259d2f8-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/114/s2/a"},"text":"Pub. L. 115–114, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2018-01-10"},"text":"Jan. 10, 2018","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/2278"},"text":"131 Stat. 2278","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1259d2f9-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1259d2fa-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id1259d2fb-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date of the enactment of this section, referred to in subsec. (a), is the date of enactment of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/114"},"text":"Pub. L. 115–114","children":[],"tail":", which was approved "},{"tag":"date","attrib":{"date":"2018-01-10"},"text":"Jan. 10, 2018","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
