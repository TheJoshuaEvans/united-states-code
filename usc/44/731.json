{"tag":"section","attrib":{"id":"id12209a24-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s731"},"text":null,"children":[{"tag":"num","attrib":{"value":"731"},"text":"§ 731.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Allotments of public documents printed after expiration of terms of Members of Congress; rights of retiring Members to documents","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Congressional allotment of public documents, other than the Congressional Record, printed after the expiration of the term of office of the Vice President of the United States, or Senator, Representative, or Resident Commissioner, shall be delivered to his successor in office.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Unless the Vice President of the United States, a Senator, Representative, or Resident Commissioner, having public documents to his credit at the expiration of his term of office takes them prior to the 30th day of June next following the date of expiration, he shall forfeit them to his successor in office.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id12209a25-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1253"},"text":"82 Stat. 1253","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id12209a26-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id12209a27-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 158 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s72"},"text":"Jan. 12, 1895, ch. 23, § 72","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/612"},"text":"28 Stat. 612","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1924-03-18/ch60"},"text":"Mar. 18, 1924, ch. 60","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/43/24"},"text":"43 Stat. 24","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1934-06-18/ch606/s1"},"text":"June 18, 1934, ch. 606, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/48/1017"},"text":"48 Stat. 1017","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Words “or her” deleted by authority of Title 1, sec. 1—“words importing masculine gender may be applied to females”.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
