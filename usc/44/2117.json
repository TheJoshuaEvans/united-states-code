{"tag":"section","attrib":{"id":"id123ab29b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2117"},"text":null,"children":[{"tag":"num","attrib":{"value":"2117"},"text":"§ 2117.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Limitation on liability","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When letters and other intellectual productions (exclusive of patented material, published works under copyright protection, and unpublished works for which copyright registration has been made) come into the custody or possession of the Archivist, the United States or its agents are not liable for infringement of copyright or analogous rights arising out of use of the materials for display, inspection, research, reproduction, or other purposes.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id123ab29c-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1291"},"text":"82 Stat. 1291","children":[],"tail":", § 2113; "},{"tag":"ref","attrib":{"href":"/us/pl/94/553/s105/b"},"text":"Pub. L. 94–553, § 105(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-19"},"text":"Oct. 19, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2599"},"text":"90 Stat. 2599","children":[],"tail":"; renumbered § 2117 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/tI"},"text":"Pub. L. 98–497, title I","children":[],"tail":", §§ 102(a)(1), 107(a)(7), "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2280"},"text":"98 Stat. 2280","children":[],"tail":", 2286.)"}],"tail":"\n"},{"tag":"notes","attrib":{"t