{"tag":"section","attrib":{"id":"id121e2944-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s513"},"text":null,"children":[{"tag":"num","attrib":{"value":"513"},"text":"§ 513.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Comparison of paper and envelopes with standard quality","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director of the Government Publishing Office shall compare every lot of paper and envelopes delivered by a contractor with the standard of quality fixed upon by the Joint Committee on Printing, and may not accept paper or envelopes which do not conform to it in every particular. A lot of delivered paper or envelopes which does not conform to the standard of quality may be accepted by the Committee at a discount that in its opinion is sufficient to protect the interests of the Government.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id121e2945-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1245"},"text":"82 Stat. 1245","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/c/1"},"text":"Pub. L. 113–235, div. H, title I, § 1301(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id121e2946-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id121e2947-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 9 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s7"},"text":"Jan. 12, 1895, ch. 23, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/602"},"text":"28 Stat. 602","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1936-06-20/ch630"},"text":"June 20, 1936, ch. 630","children":[],"tail":", title VIII, § 13, "},{"tag":"ref","attrib":{"href":"/us/stat/49/1553"},"text":"49 Stat. 1553","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id121e2948-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id121e2949-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235"},"text":"Pub. L. 113–235","children":[],"tail":" substituted “Director of the Government Publishing Office” for “Public Printer”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
