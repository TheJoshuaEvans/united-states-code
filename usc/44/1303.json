{"tag":"section","attrib":{"id":"id12255554-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1303"},"text":null,"children":[{"tag":"num","attrib":{"value":"1303"},"text":"§ 1303.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" American Historical Association: report","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In addition to the usual number of the report of the American Historical Association, five thousand five hundred copies shall be printed: one thousand for the Senate, two thousand for the House of Representatives, one thousand five hundred for distribution by the Association and the Smithsonian Institution, and one thousand copies for the use of the Association.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id12255555-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1266"},"text":"82 Stat. 1266","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id12255556-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id12255557-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 243 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s73"},"text":"Jan. 12, 1895, ch. 23, § 73","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/616"},"text":"28 Stat. 616","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1900-05-25"},"text":"May 25, 1900","children":[],"tail":", No. 27, "},{"tag":"ref","attrib":{"href":"/us/