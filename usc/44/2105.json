{"tag":"section","attrib":{"id":"id12313bd3-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2105"},"text":null,"children":[{"tag":"num","attrib":{"value":"2105"},"text":"§ 2105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Personnel and services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id12313bd4-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2105/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id12313bd5-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2105/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Archivist is authorized to select, appoint, employ, and fix the compensation of such officers and employees, pursuant to part III of title 5, as are necessary to perform the functions of the Archivist and the Administration.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id12313bd6-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2105/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding paragraph (1), the Archivist is authorized to appoint, subject to the consultation requirements set forth in paragraph (f)(2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s2203"},"text":"section 2203 of this title","children":[],"tail":","},{"tag":"ref","attrib":{"idref":"fn002014"},"text":"1","children":[],"tail":null},{"tag":"note","attrib":{"type":"footnote","id":"fn002014"},"text":null,"children":[{"tag":"num","attrib":{},"text":"1","children":[],"tail":" See References in Text note below."}],"tail":" a director at each Presidential archival depository established under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s2112"},"text":"section 2112 of this title","children":[],"tail":". The Archivist may appoint a director without regard to subchapter I and subchapter VIII of chapter 33 of title 5, United States Code, governing appointments in the competitive service and the Senior Executive Service. A director so appointed shall be responsible for the care and preservation of the Presidential records and historical materials deposited in a Presidential archival depository, shall serve at the pleasure of the Archivist and shall perform such other functions as the Archivist may specify."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id12313bd7-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2105/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Archivist is authorized to obtain the services of experts and consultants under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s3109"},"text":"section 3109 of title 5","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id12313bd8-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2105/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding the provisions of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t10/s973"},"text":"section 973 of title 10","children":[],"tail":" or any other provision of law, the Archivist, in carrying out the functions of the Archivist or the Administration, is authorized to utilize in the Administration the services of officials, officers, and other personnel in other Federal agencies, including personnel of the armed services, with the consent of the head of the agency concerned."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id12313bd9-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2105/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1342"},"text":"section 1342 of title 31","children":[],"tail":", United States Code, the Archivist is authorized to accept and utilize voluntary and uncompensated services."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id12313bda-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497/tI/s102/a/2"},"text":"Pub. L. 98–497, title I, § 102(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2281"},"text":"98 Stat. 2281","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/107/67/tVI/s649"},"text":"Pub. L. 107–67, title VI, § 649","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2001-11-12"},"text":"Nov. 12, 2001","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/115/556"},"text":"115 Stat. 556","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id12313bdb-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id12313bdc-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id12313bdd-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Paragraph (f)(2) of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s2203"},"text":"section 2203 of this title","children":[],"tail":", referred to in subsec. (a)(2), was redesignated (g)(2) of "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s2203"},"text":"section 2203 of this title","children":[],"tail":" by "},{"tag":"ref","attrib":{"href":"/us/pl/113/187/s2/c/3"},"text":"Pub. L. 113–187, § 2(c)(3)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-11-26"},"text":"Nov. 26, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2006"},"text":"128 Stat. 2006","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id12313bde-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2105 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s2109"},"text":"section 2109 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id12313bdf-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2001—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/67"},"text":"Pub. L. 107–67","children":[],"tail":" amended subsec. (a) generally, designating existing provisions as par. (1) and adding par. (2)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id12313be0-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id12313be1-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1985-04-01"},"text":"Apr. 1, 1985","ch