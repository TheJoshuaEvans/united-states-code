{"tag":"section","attrib":{"id":"id12279f8a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1312"},"text":null,"children":[{"tag":"num","attrib":{"value":"1312"},"text":"§ 1312.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director of Public Health of District of Columbia: report","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In addition to the usual number of the report of the Director of Public Health of the District of Columbia, one thousand five hundred copies shall be printed: one hundred for the Senate, three hundred and sixty for the House of Representatives, and one thousand and forty for the Director of Public Health.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id12279f8b-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1267"},"text":"82 Stat. 1267","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id12279f8c-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id12279f8d-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 263 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s73"},"text":"Jan. 12, 1895, ch. 23, § 73","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/614"},"text":"28 Stat. 614","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1950-08-01/ch513/s1"},"text":"Aug. 1, 1950, ch. 513, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/393"},"tex