{"tag":"section","attrib":{"id":"id122a0fff-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1333"},"text":null,"children":[{"tag":"num","attrib":{"value":"1333"},"text":"§ 1333.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National high school and college debate topics","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id122a1000-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1333/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Librarian of Congress shall prepare compilations of pertinent excerpts, bibliographical references, and other appropriate materials relating to:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id122a1001-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1333/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the subject selected annually by the National University Extension Association as the national high school debate topic and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id122a1002-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1333/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the subject selected annually by the American Speech Association as the national college debate topic.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"In preparing the compilations the Librarian shall include materials which in his judgment are representative of, and give equal emphasis to, the opposing points of view on the respective topics.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id122a1003-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1333/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The compilations on the high school debate topics shall be printed as Senate documents and the compilations on the college debate topics shall be printed as House of Representatives documents, the cost of which shall be charged to the congressional allotment for printing and binding. Additional copies may be printed in the quantities and distributed in the manner the Joint Committee on Printing directs.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id122a1004-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1270"},"text":"82 Stat. 1270","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122a1005-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122a1006-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., Supp. III, § 170 [§ 276a] (","children":[{"tag":"date","attrib":{"date":"1963-12-30"},"text":"Dec. 30, 1963","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/88/246"},"text":"Pub. L. 88–246","children":[],"tail":", §§ 1, 2, "},{"tag":"ref","attrib":{"href":"/us/stat/77/802"},"text":"77 Stat. 802","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
