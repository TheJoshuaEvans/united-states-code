{"tag":"section","attrib":{"id":"id122099cd-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s716"},"text":null,"children":[{"tag":"num","attrib":{"value":"716"},"text":"§ 716.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Printing of documents not provided for by law","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Either House may order the printing of a document not already provided for by law, when accompanied by an estimate from the Director of the Government Publishing Office as to the probable cost. An executive department, bureau, board, or independent office of the Government submitting reports or documents in response to inquiries from Congress shall include an estimate of the probable cost of printing to the usual number. This section does not apply to reports or documents not exceeding fifty pages.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id122099ce-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1250"},"text":"82 Stat. 1250","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/c/1"},"text":"Pub. L. 113–235, div. H, title I, § 1301(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122099cf-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122099d0-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 140 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s2"},"text":"Jan. 12, 1895, ch. 23, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/601"},"text":"28 Stat. 601","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1907-03-01/ch2284/s1"},"text":"Mar. 1, 1907, ch. 2284, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/1013"},"text":"34 Stat. 1013","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id122099d1-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id122099d2-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235"},"text":"Pub. L. 113–235","children":[],"tail":" substituted “Director of the Government Publishing Office” for “Public Printer”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
