{"tag":"section","attrib":{"id":"id122c8215-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1714"},"text":null,"children":[{"tag":"num","attrib":{"value":"1714"},"text":"§ 1714.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publications for use of National Archives and Records Administration","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director of the Government Publishing Office shall print and deliver to the National Archives and Records Administration for use by the Archivist of the United States, including use by the Presidential Library established for the President during whose term the documents were issued, which shall be chargeable to Congress three copies each of the following publications:","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"House documents and public reports, bound;","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"Senate documents and public reports, bound;","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"Senate and House journals, bound;","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"United States Code and Supplements, bound;","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"United States Statutes at Large, bound;","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"the United States Reports, bound;","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"all other documents bearing a congressional number, or printed upon order of a committee in either House of Congress, or of a department, independent agency or establishment, commission, or officer of the Government, except confidential matter, blank forms, and circular letters not of a public character; and","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"public bills and resolutions in Congress in each parliamentary stage.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The Superintendent of Documents shall furnish, without cost, copies of publications available for free distribution.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id122c8216-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1281"},"text":"82 Stat. 1281","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/tI/s107/b/6"},"text":"Pub. L. 98–497, title I, § 107(b)(6)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2287"},"text":"98 Stat. 2287","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/c/1"},"text":"Pub. L. 113–235, div. H, title I, § 1301(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122c8217-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122c8218-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 215a (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23"},"text":"Jan. 12, 1895, ch. 23","children":[],"tail":", § —, as added "},{"tag":"ref","attrib":{"href":"/us/act/1935-06-17/ch267"},"text":"June 17, 1935, ch. 267","children":[],"tail":", "},