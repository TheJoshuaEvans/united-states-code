{"tag":"section","attrib":{"id":"id12196eb1-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s310"},"text":null,"children":[{"tag":"num","attrib":{"value":"310"},"text":"§ 310.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Payments for printing, binding, blank paper, and supplies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"An executive department or independent establishment of the Government ordering printing and binding or blank paper and supplies from the Government Publishing Office shall pay promptly by check to the Director of the Government Publishing Office upon the written request of the Director, either in advance or upon completion of the work, all or part of the estimated or actual cost, as the case may be, and bills rendered by the Director of the Government Publishing Office are not subject to audit or certification in advance of payment. Adjustments on the basis of the actual cost of delivered work paid for in advance shall be made monthly or quarterly and as may be agreed by the Director of the Government Publishing Office and the department or establishment concerned.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id12196eb2-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1241"},"text":"82 Stat. 1241","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/b"},"text":"Pub. L. 113–235, div. H, title I, § 1301(b)","children":[],"tail":", (c)(1), (i)(6), "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":", 2539.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id12196eb3-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id12196eb4-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 230 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1953-08-01/ch304"},"text":"Aug. 1, 1953, ch. 304","children":[],"tail":", title I, § 101, "},{"tag":"ref","attrib":{"href":"/us/stat/67/331"},"text":"67 Stat. 331","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id12196eb5-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id12196eb6-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/i/6"},"text":"Pub. L. 113–235, § 1301(i)(6)","children":[],"tail":", substituted “the written request of the Director” for “his written request”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/c/1"},"text":"Pub. L. 113–235, § 1301(c)(1)","children":[],"tail":", substituted “Director of the Government Publishing Office” for “Public Printer” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id12196eb7-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id12196eb8-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Government Publishing Office” substituted for “Government Printing Office” in text on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/b"},"text":"section 1301(b) of Pub. L. 113–235","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s301"},"text":"section 301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
