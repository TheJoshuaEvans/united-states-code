{"tag":"section","attrib":{"id":"id122c820f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1713"},"text":null,"children":[{"tag":"num","attrib":{"value":"1713"},"text":"§ 1713.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Documents to be delivered to the Executive Mansion","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director of the Government Publishing Office shall deliver to the Executive Mansion two copies of each document, bill, and resolution as soon as printed and ready for distribution.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id122c8210-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1281"},"text":"82 Stat. 1281","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/c/1"},"text":"Pub. L. 113–235, div. H, title I, § 1301(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122c8211-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122c8212-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 80 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s88"},"text":"Jan. 12, 1895, ch. 23, § 88","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/622"},"text":"28 S