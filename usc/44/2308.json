{"tag":"section","attrib":{"id":"id123f93ac-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2308"},"text":null,"children":[{"tag":"num","attrib":{"value":"2308"},"text":"§ 2308.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Tax exemption for gifts","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Gifts and bequests received by the Board under this chapter, and the income from them are exempt from taxes.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id123f93ad-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1293"},"text":"82 Stat. 1293","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id123f93ae-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id123f93af-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 300gg (","children":[{"tag":"ref","attrib":{"href":"/us/act/1941-07-09/ch284/s7"},"text":"July 9, 1941, ch. 284, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/55/582"},"text":"55 Stat. 582","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
