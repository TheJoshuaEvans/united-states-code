{"tag":"section","attrib":{"id":"id1260d886-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3901"},"text":null,"children":[{"tag":"num","attrib":{"value":"3901"},"text":"§ 3901.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Purpose and establishment of the Office of Inspector General","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In order to create an independent and objective office—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1260d887-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3901/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct and supervise audits and investigations relating to the Government Publishing Office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1260d888-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3901/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide leadership and coordination and recommend policies to promote economy, efficiency, and effectiveness; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1260d889-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3901/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to provide a means of keeping the Director of the Government Publishing Office and the Congress fully and currently informed about problems and deficiencies relating to the administration and operations of the Government Publishing Office;","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"there is hereby established an Office of Inspector General in the Government Publishing Office.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1260d88a-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/504/tII/s202"},"text":"Pub. L. 100–504, title II, § 202","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-18"},"text":"Oct. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2530"},"text":"102 Stat. 2530","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/b"},"text":"Pub. L. 113–235, div. H, title I, § 1301(b)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1260d88b-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1260d88c-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id1260d88d-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Par. (3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/c/1"},"text":"Pub. L. 113–235, § 1301(c)(1)","children":[],"tail":", substituted “Director of the Government Publishing Office” for “Public Printer”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id1260d88e-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id1260d88f-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Government Publishing Office” substituted for “Government Printing Office” in pars. (1) and (3) and concluding provisions on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/b"},"text":"section 1301(b) of Pub. L. 113–235","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s301"},"text":"section 301 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id1260d890-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/504/tII/s206"},"text":"Pub. L. 100–504, title II, § 206","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-18"},"text":"Oct. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2532"},"text":"102 Stat. 2532","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/504/tII/s206"},"text":"“The provisions of this title and the amendments made by this title [enacting this chapter and provisions set out as notes under sections 101 and 3901 of this title] shall take effect 180 days after the date of the enactment of this title [","children":[{"tag":"date","attrib":{"date":"1988-10-18"},"text":"Oct. 18, 1988","children":[],"tail":"].”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"shortTitle","id":"id12634891-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Short Title","children":[],"tail":null},{"tag":"p","attrib":{},"text":"For short title of title II of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/100/504"},"text":"Pub. L. 100–504","children":[],"tail":", which enacted this chapter, as the “Government Printing Office Inspector General Act of 1988”, see "},{"tag":"ref","attrib":{"href":"/us/pl/100/504/s201"},"text":"section 201 of Pub. L. 100–504","children":[],"tail":", set out as a Short Title of 1988 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s101"},"text":"section 101 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id12634892-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Transfer of Office","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/504/tII/s203"},"text":"Pub. L. 100–504, title II, § 203","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-18"},"text":"Oct. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2531"},"text":"102 Stat. 2531","children":[],"tail":" transferred the office of the Government Printing Office referred to as the “Office of Inspector General”, and the functions, powers, duties, and certain personnel of that office, to the Office of Inspector General in the Government Printing Office."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id12634893-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Payment Authority Subject to Appropriations","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/100/504/tII/s205"},"text":"Pub. L. 100–504, title II, § 205","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1988-10-18"},"text":"Oct. 18, 1988","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/102/2531"},"text":"102 Stat. 2531","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/100/504/tII/s205"},"text":"“Any authority to make payments under this title [enacting this chapter and provisions set out as notes under sections 101 and 3901 of this title] shall be effective only to such extent as provided in appropriations Acts.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
