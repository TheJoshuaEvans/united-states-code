{"tag":"section","attrib":{"id":"id1241dda8-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2904"},"text":null,"children":[{"tag":"num","attrib":{"value":"2904"},"text":"§ 2904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" General responsibilities for records management","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1241dda9-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2904/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Archivist shall provide guidance and assistance to Federal agencies with respect to ensuring—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1241ddaa-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2904/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" economical and effective records management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1241ddab-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2904/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adequate and proper documentation of the policies and transactions of the Federal Government; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1241ddac-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2904/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" proper records disposition.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1241ddad-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2904/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator shall provide guidance and assistance to Federal agencies to ensure economical and effective processing of mail by Federal agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1241ddae-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2904/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" In carrying out the responsibilities under subsection (a), the Archivist shall have the responsibility—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1241ddaf-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2904/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to promulgate standards, procedures, and guidelines with respect to records management and the conduct of records management studies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1241ddb0-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2904/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct research with respect to the improvement of records management practices and programs;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1241ddb1-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2904/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to collect and disseminate information on training programs, technological developments, and other activities relating to records management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1241ddb2-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2904/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to establish such interagency committees and boards as may be necessary to provide an exchange of information among Federal agencies with respect to records management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1241ddb3-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2904/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to direct the continuing attention of Federal agencies and the Congress on the need for adequate policies governing records management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1241ddb4-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2904/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct records management studies and, in the Archivist’s discretion, designate the heads of executive agencies to conduct records management studies with respect to establishing systems and techniques designed to save time and effort in records management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1241ddb5-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2904/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to conduct inspections or surveys of the records and the records management programs and practices within and between Federal agencies;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1241ddb6-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2904/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" to report to the appropriate oversight and appropriations committees of the Congress and to the Director of the Office of Management and Budget in January of each year and at such other times as the Archivist deems desirable—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1241ddb7-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2904/c/8/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on the results of activities conducted pursuant to paragraphs (1) through (7) of this section,","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1241ddb8-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2904/c/8/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" on evaluations of responses by Federal agencies to any recommendations resulting from inspections or studies conducted under paragraphs (6) and (7) of this section, and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1241ddb9-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2904/c/8/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the extent practicable, estimates of costs to the Federal Government resulting from the failure of agencies to implement such recommendations.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1241ddba-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2904/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Archivist shall promulgate regulations requiring all Federal agencies to transfer all digital or electronic records to the National Archives of the United States in digital or electronic form to the greatest extent possible.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1241ddbb-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2904/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Administrator, in carrying out subsection (b), shall have the responsibility to promote economy and efficiency in the selection and utilization of space, staff, equipment, and supplies for processing mail at Federal facilities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1241ddbc-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/575/s2/a/2"},"text":"Pub. L. 94–575, § 2(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2725"},"text":"90 Stat. 2725","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/96/511/s2/c/1"},"text":"Pub. L. 96–511, § 2(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-11"},"text":"Dec. 11, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2825"},"text":"94 Stat. 2825","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/tI/s107/b/16"},"text":"Pub. L. 98–497, title I, § 107(b)(16)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2288"},"text":"98 Stat. 2288","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/187"},"text":"Pub. L. 113–187","children":[],"tail":", §§ 8(7), 9(c), "},{"tag":"date","attrib":{"date":"2014-11-26"},"text":"Nov. 26, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2012"},"text":"128 Stat. 2012","children":[],"tail":", 2013; "},{"tag":"ref","attrib":{"href":"/us/pl/115/85/s2/a/2"},"text":"Pub. L. 115–85, § 2(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2017-11-21"},"text":"Nov. 21, 2017","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/131/1274"},"text":"131 Stat. 1274","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1241ddbd-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1241ddbe-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id1241ddbf-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 2904, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1296"},"text":"82 Stat. 1296","children":[],"tail":", contained provisions similar to those comprising pars. (1) and (2) of this section, prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/94/575/s2/a/2"},"text":"Pub. L. 94–575, § 2(a)(2)","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Provisions similar to those comprising pars. (8) to (10) of this section were contained in section 2902, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1296"},"text":"82 Stat. 1296","children":[],"tail":", prior to repeal by "},{"tag":"ref","attrib":{"href":"/us/pl/94/575/s2/a/1"},"text":"Pub. L. 94–575, § 2(a)(1)","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id1241ddc0-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2017—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/85/s2/a/2"},"text":"Pub. L. 115–85, § 2(a)(2)","children":[],"tail":", amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/187/s9/c"},"text":"Pub. L. 113–187, § 9(c)","children":[],"tail":". See 2014 Amendment notes below."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/187/s9/c/1"},"text":"Pub. L. 113–187, § 9(c)(1)","children":[],"tail":", as amended by "},{"tag":"ref","attrib":{"href":"/us/pl/115/85/s2/a/2/A"},"text":"Pub. L. 115–85, § 2(a)(2)(A)","children":[],"tail":", amended subsec. (a) generally. Prior to amendment, subsec. (a) read as follows: “The Archivist shall provide guidance and assistance to Federal agencies with respect to ensuring adequate and proper documentation of the policies and transactions of the Federal Government and ensuring proper records disposition.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/187/s9/c/2"},"text":"Pub. L. 113–187, § 9(c)(2)","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/115/85/s2/a/2/C"},"text":"Pub. L. 115–85, § 2(a)(2)(C)","children":[],"tail":", substituted “effective processing of mail by Federal agencies” for “effective records management by such agencies”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/187/s9/c/3/A"},"text":"Pub. L. 113–187, § 9(c)(3)(A)","children":[],"tail":", formerly § 9(c)(2)(A), as renumbered and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/115/85/s2/c/2/B"},"text":"Pub. L. 115–85, § 2(c)(2)(B)","children":[],"tail":", (D)(i), substituted “the responsibilities under subsection (a), the Archivist shall have” for “their responsibilities under subsection (a) or (b), respectively, the Archivist and the Administrator shall each have” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/187/s8/7"},"text":"Pub. L. 113–187, § 8(7)","children":[],"tail":", substituted “the Archivist’s” for “his”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/187/s9/c/3/B"},"text":"Pub. L. 113–187, § 9(c)(3)(B)","children":[],"tail":", formerly § 9(c)(2)(B), as renumbered and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/115/85/s2/a/2/B"},"text":"Pub. L. 115–85, § 2(a)(2)(B)","children":[],"tail":", (D)(ii), struck out “or the Administrator (as the case may be)” after “Archivist”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/187/s9/c/4"},"text":"Pub. L. 113–187, § 9(c)(4)","children":[],"tail":", formerly § 9(c)(3), as renumbered and amended by "},{"tag":"ref","attrib":{"href":"/us/pl/115/85/s2/c/2/B"},"text":"Pub. L. 115–85, § 2(c)(2)(B)","children":[],"tail":", (E), amended subsec. (d) generally. Prior to amendment, subsec. (d) read as follows: “In addition, the Administrator, in carrying out subsection (b), shall have the responsibility to promote economy and efficiency in the selection and utilization of space, staff, equipment, and supplies for records management.”"}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (e). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/187/s9/c/5"},"text":"Pub. L. 113–187, § 9(c)(5)","children":[],"tail":", as added by "},{"tag":"ref","attrib":{"href":"/us/pl/115/85/s2/a/2/F"},"text":"Pub. L. 115–85, § 2(a)(2)(F)","children":[],"tail":", added subsec. (e)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" substituted “for records management” for “of Administrator” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" designated existing first sentence as subsec. (a) and substituted “Archivist” for “Administrator” and “ensuring adequate and proper documentation of the policies and transactions of the Federal Government and ensuring proper records disposition” for “records creation, records maintenance and use, and records disposition”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" added subsec. (b)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" designated existing second sentence as subsec. (c), substituted “In carrying out the responsibilities under subsection (a) or (b), respectively” for “In providing such guidance and assistance,”, and inserted reference to Archivist in text preceding par. (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" redesignated par. (2) as (1). Provisions contained in former par. (1) are now contained substantially in subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" redesignated par. (3) as (2). Former par. (2) redesignated (1)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(3). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" redesignated par. (6) as (3) and inserted “to collect and”, “training programs”, and “other activities”. Former par. (3) redesignated (2)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(4). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" redesignated par. (5) as (4). Former par. (4), which read “serve as a clearinghouse for information with respect to records management and as a central source for reference and training materials with respect to records management”, was struck out."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(5). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" redesignated par. (7) as (5) and struck out “the burden placed on the Federal Government by unnecessary paperwork” after “Congress on”, “creation” before “maintenance”, and “and use, and disposition” after “maintenance”. Former par. (5) redesignated (4)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(6). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" redesignated par. (8) as (6) and struck out “with particular attention given to standards and procedures governing records creation” at end. Former par. (6) redesignated (3)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(7). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" redesignated par. (9) as (7) and substituted “surveys of the records and the records management programs and practices within and between Federal agencies” for “records management studies which involve a review of the programs and practices of more than one Federal agency and which examine interaction among and relationships between Federal agencies with respect to records and records management”. Former par. (7) redesignated (5)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(8). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" redesignated par. (10) as (8) and inserted “in January of each year”, “the Archivist or”, and substituted “(7)” for “(9)” and “(6)” and “(7)” for “(8)” and “(9)”, respectively, in subpars. (A) and (B)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (c)(9), (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" redesignated pars. (9) and (10) as (7) and (8), respectively."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (d). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" added subsec. (d)."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1980—Par. (10). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/511"},"text":"Pub. L. 96–511","children":[],"tail":" prescribed that the report be to appropriate oversight and appropriations committees, incorporated existing provisions in cls. (A) and (B) and added cl. (C)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id1241ddc1-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id1241ddc2-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2017 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/85"},"text":"Pub. L. 115–85","children":[],"tail":" effective as if included in "},{"tag":"ref","attrib":{"href":"/us/pl/113/187"},"text":"Pub. L. 113–187","children":[],"tail":", see "},{"tag":