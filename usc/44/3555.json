{"tag":"section","attrib":{"id":"id1259d2b8-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3555"},"text":null,"children":[{"tag":"num","attrib":{"value":"3555"},"text":"§ 3555.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual independent evaluation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1259d2b9-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3555/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id1259d2ba-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3555/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each year each agency shall have performed an independent evaluation of the information security program and practices of that agency to determine the effectiveness of such program and practices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d2bb-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3555/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Each evaluation under this section shall include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1259d2bc-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3555/a/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" testing of the effectiveness of information security policies, procedures, and practices of a representative subset of the agency’s information systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1259d2bd-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3555/a/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an assessment of the effectiveness of the information security policies, procedures, and practices of the agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1259d2be-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3555/a/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" separate presentations, as appropriate, regarding information security relating to national security systems.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1259d2bf-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3555/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Independent Auditor","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Subject to subsection (c)—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1259d2c0-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3555/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each agency with an Inspector General appointed under chapter 4 of title 5, the annual evaluation required by this section shall be performed by the Inspector General or by an independent external auditor, as determined by the Inspector General of the agency; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d2c1-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3555/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" for each agency to which paragraph (1) does not apply, the head of the agency shall engage an independent external auditor to perform the evaluation.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1259d2c2-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3555/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"National Security Systems","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"For each agency operating or exercising control of a national security system, that portion of the evaluation required by this section directly relating to a national security system shall be performed—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1259d2c3-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3555/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" only by an entity designated by the agency head; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d2c4-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3555/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in such a manner as to ensure appropriate protection for information associated with any information security vulnerability in such system commensurate with the risk and in accordance with all applicable laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1259d2c5-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3555/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Existing Evaluations","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The evaluation required by this section may be based in whole or in part on an audit, evaluation, or report relating to programs or practices of the applicable agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1259d2c6-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3555/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Agency Reporting","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id1259d2c7-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3555/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each year, not later than such date established by the Director, the head of each agency shall submit to the Director the results of the evaluation required under this section.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d2c8-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3555/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To the extent an evaluation required under this section directly relates to a national security system, the evaluation results submitted to the Director shall contain only a summary and assessment of that portion of the evaluation directly relating to a national security system.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1259d2c9-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3555/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Protection of Information","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Agencies and evaluators shall take appropriate steps to ensure the protection of information which, if disclosed, may adversely affect information security. Such protections shall be commensurate with the risk and comply with all applicable laws and regulations.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1259d2ca-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3555/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"OMB Reports to Congress","children":[],"tail":".—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id1259d2cb-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3555/g/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall summarize the results of the evaluations conducted under this section in the report to Congress required under section 3553(c).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d2cc-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3555/g/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director’s report to Congress under this subsection shall summarize information regarding information security relating to national security systems in such a manner as to ensure appropriate protection for information associated with any information security vulnerability in such system commensurate with the risk and in accordance with all applicable laws.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d2cd-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3555/g/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Evaluations and any other descriptions of information systems under the authority and control of the Director of National Intelligence or of National Foreign Intelligence Programs systems under the authority and control of the Secretary of Defense shall be made available to Congress only through the appropriate oversight committees of Congress, in accordance with applicable laws.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1259d2ce-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3555/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Comptroller General","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Comptroller General shall periodically evaluate and report to Congress on—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1259d2cf-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3555/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the adequacy and effectiveness of agency information security policies and practices; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d2d0-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3555/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementation of the requirements of this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1259d2d1-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3555/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Assessment Technical Assistance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Comptroller General may provide technical assistance to an Inspector General or the head of an agency, as applicable, to assist the Inspector General or head of an agency in carrying out the duties under this section, including by testing information security controls and procedures.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1259d2d2-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3555/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Guidance","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Director, in consultation with the Secretary, the Chief Information Officers Council established under section 3603, the Council of the Inspectors General on Integrity and Efficiency, and other interested parties as appropriate, shall ensure the development of guidance for evaluating the effectiveness of an information security program and practices.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1259d2d3-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/283/s2/a"},"text":"Pub. L. 113–283, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-18"},"text":"Dec. 18, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/3082"},"text":"128 Stat. 3082","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/117/286/s4/b/89"},"text":"Pub. L. 117–286, § 4(b)(89)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2022-12-27"},"text":"Dec. 27, 2022","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/136/4352"},"text":"136 Stat. 4352","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1259d2d4-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1259d2d5-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id1259d2d6-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Provisions similar to this section were contained in sections 3535 and 3545 of this title prior to repeal by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/283"},"text":"Pub. L. 113–283","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id1259d2d7-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2022—Subsec. (b)(1). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/117/286"},"text":"Pub. L. 117–286","children":[],"tail":" substituted “chapter 4 of title 5,” for “the Inspector General Act of 1978,”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
