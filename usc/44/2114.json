{"tag":"section","attrib":{"id":"id123ab27d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2114"},"text":null,"children":[{"tag":"num","attrib":{"value":"2114"},"text":"§ 2114.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Preservation of audio and visual records","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Archivist may make and preserve audio and visual records, including motion-picture films, still photographs, and sound recordings, in analog, digital, or any other form, pertaining to and illustrative of the historical development of the United States Government and its activities, and provide for preparing, editing, titling, scoring, processing, duplicating, reproducing, exhibiting, and releasing for non-profit educational purposes, motion-picture films, still photographs, and sound recordings in the Archivist’s custody.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id123ab27e-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1290"},"text":"82 Stat. 1290","children":[],"tail":", § 2110; renumbered § 2114 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/tI"},"text":"Pub. L. 98–497, title I","children":[],"tail":", §§ 102(a)(1), 107(a)(7), "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2280"},"text":"98 Stat. 2280","children":[],"tail":", 2286; "},{"tag":"ref","attrib":{"href":"/us/pl/113/187/s3/c/1"},"text":"Pub. L. 113–187, § 3(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-11-26"},"text":"Nov. 26, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2008"},"text":"128 Stat. 2008","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id123ab27f-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id123ab280-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 397(i) (","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title V, § 507, as added "},{"tag":"ref","attrib":{"href":"/us/act/1950-09-05/ch849/s6/d"},"text":"Sept. 5, 1950, ch. 849, § 6(d)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/583"},"text":"64 Stat. 583","children":[],"tail":"; and amended "},{"tag":"ref","attrib":{"href":"/us/act/1952-07-12/ch703/s1"},"text":"July 12, 1952, ch. 703, § 1","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"o","children":[],"tail":"), (p), "},{"tag":"ref","attrib":{"href":"/us/stat/66/594"},"text":"66 Stat. 594","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1955-07-12/ch329"},"text":"July 12, 1955, ch. 329","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/297"},"text":"69 Stat. 297","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1955-08-12/ch859"},"text":"Aug. 12, 1955, ch. 859","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/69/695"},"text":"69 Stat. 695","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1956-07-03/ch513/s4"},"text":"July 3, 1956, ch. 513, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/70/494"},"text":"70 Stat. 494","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1957-06-13"},"text":"June 13, 1957","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/85/51"},"text":"Pub. L. 85–51","children":[]