{"tag":"section","attrib":{"id":"id121e2981-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s704"},"text":null,"children":[{"tag":"num","attrib":{"value":"704"},"text":"§ 704.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reprinting bills, laws, and reports from committees not exceeding fifty pages","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When the supply is exhausted, the Secretary of the Senate and the Clerk of the House of Representatives may order the reprinting of not more than one thousand copies of a pending bill, resolution, or public law, not exceeding fifty pages, or a report from a committee or congressional commission on pending legislation not accompanied by testimony or exhibits or other appendices and not exceeding fifty pages. The Director of the Government Publishing Office shall require each requisition for reprinting to cite the specific authority of law for its execution.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id121e2982-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1248"},"text":"82 Stat. 1248","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/c/1"},"text":"Pub. L. 113–235, div. H, title I, § 1301(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id121e2983-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id121e2984-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 137 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s2"},"text":"Jan. 12, 1895, ch. 23, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/601"},"text":"28 Stat. 601","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1907-03-01/ch2284/s1"},"text":"Mar. 1, 1907, ch. 2284, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/1012"},"text":"34 Stat. 1012","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id121e2985-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id121e2986-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235"},"text":"Pub. L. 113–235","children":[],"tail":" substituted “Director of the Government Publishing Office” for “Public Printer”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
