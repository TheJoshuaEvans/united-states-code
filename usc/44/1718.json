{"tag":"section","attrib":{"id":"id122ecb1d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1718"},"text":null,"children":[{"tag":"num","attrib":{"value":"1718"},"text":"§ 1718.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of Government publications to the Library of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There shall be printed and furnished to the Library of Congress for official use in the District of Columbia not to exceed twenty-five copies of:","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"House documents and reports, bound;","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"Senate documents and reports, bound;","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"Senate and House journals, bound;","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"public bills and resolutions;","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"the United States Code and supplements, bound; and","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"all other publications and maps which are printed, or otherwise reproduced, under authority of law, upon the requisition of a Congressional committee, executive department, bureau, independent office, establishment, commission, or officer of the Government.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Confidential matter, blank forms, and circular letters not of a public character shall be excepted.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"In addition, there shall be delivered as printed to the Library of Congress:","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"ten copies of each House document and report, unbound;","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"ten copies of each Senate document and report, unbound; and","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"ten copies of each private bill and resolution and fifty copies of the laws in slip form.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id122ecb1e-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1282"},"text":"82 Stat. 1282","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/276/s101/e"},"text":"Pub. L. 97–276, § 101(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-10-02"},"text":"Oct. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/1189"},"text":"96 Stat. 1189","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122ecb1f-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122ecb20-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 139 (","children":[{"tag":"date","attrib":{"date":"1899-01-28"},"text":"Jan. 28, 1899","children":[],"tail":", No. 12, "},{"tag":"ref","attrib":{"href":"/us/stat/30/1388"},"text":"30 Stat. 1388","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1901-03-02"},"text":"Mar. 2, 1901","children":[],"tail":", No. 16, §§ 1, 2, "},{"tag":"ref","attrib":{"href":"/us/stat/31/1464"},"text":"31 Stat. 1464","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1936-06-20/ch630"},"text":"June 20, 1936, ch. 630","children":[],"tail":", title IV, § 6, "},{"tag":"ref","attrib":{"href":"/us/stat/49/1550"},"text":"49 Stat. 1550","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Reference to the Official Register is omitted as obsolete. The authorization for its compilation was repealed by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/88/626"},"text":"Public Law 88–626","children":[],"tail":" [86–626]."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id122ecb21-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id122ecb22-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The 1982 amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/276"},"text":"Pub. L. 97–276","children":[],"tail":" is based on section 305(a) of S. 2939, Ninety-seventh Congress, 2d Session, as reported "},{"tag":"date","attrib":{"date":"1982-09-22"},"text":"Sept. 22, 1982","children":[],"tail":", and incorporated by reference in "},{"tag":"ref","attrib":{"href":"/us/pl/97/276/s101/e"},"text":"section 101(e) of Pub. L. 97–276","children":[],"tail":", to be effective as if enacted into law."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id122ecb23-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/276"},"text":"Pub. L. 97–276","children":[],"tail":" substituted “not to exceed twenty-five copies of” for “, and for international exchange as provided by "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s1719"},"text":"section 1719 of this title","children":[],"tail":", not to exceed one hundred and fifty copies of”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
