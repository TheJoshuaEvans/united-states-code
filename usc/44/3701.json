{"tag":"section","attrib":{"id":"id1260d873-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3701"},"text":null,"children":[{"tag":"num","attrib":{"value":"3701"},"text":"§ 3701.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advertisements for contracts in District of Columbia","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Advertisements for contracts for the public service may not be published in any newspaper published and printed in the District of Columbia unless the supplies or labor covered by the advertisement are to be furnished or performed in the District of Columbia or in the adjoining counties of Maryland or Virginia.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id1260d874-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1305"},"text":"82 Stat. 1305","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1260d875-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id1260d876-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 321 (R.S. § 79; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1874-06-20/ch328"},"text":"June 20, 1874, ch. 328","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/18/90"},"text":"18 Stat. 90","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1875-02-18/ch80/s1"},"text":"Feb. 18, 1875, ch. 80, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/18/317"},"te