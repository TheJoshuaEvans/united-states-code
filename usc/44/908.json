{"tag":"section","attrib":{"id":"id1222e499-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s908"},"text":null,"children":[{"tag":"num","attrib":{"value":"908"},"text":"§ 908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Congressional Record: payment for printing extracts or other documents","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"If a Member or Resident Commissioner fails to pay the cost of printing extracts from the Congressional Record or other documents ordered by him to be printed, the Director of the Government Publishing Office shall certify the amount due to the Chief Administrative Officer of the House of Representatives or the financial clerk of the Senate, as the case may be, who shall deduct from any salary due the delinquent the amount, or as much of it as the salary due may cover, and pay the amount so obtained to the Director of the Government Publishing Office, to be applied by him to the satisfaction of the indebtedness.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id1222e49a-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1260"},"text":"82 Stat. 1260","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/186/tII/s223/8"},"text":"Pub. L. 104–186, title II, § 223(8)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-08-20"},"text":"Aug. 20, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/1752"},"text":"110 Stat. 1752","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/c/1"},"text":"Pub. L. 113–235, div. H, title I, § 1301(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1222e49b-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id1222e49c-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 163 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1911-03-04/ch285/s1"},"text":"Mar. 4, 1911, ch. 285, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/36/1446"},"text":"36 Stat. 1446","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1222e49d-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id1222e49e-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235"},"text":"Pub. L. 113–235","children":[],"tail":" substituted “Director of the Government Publishing Office” for “Public Printer” in two places."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/186"},"text":"Pub. L. 104–186","children":[],"tail":" substituted “Chief Administrative Officer of the House of Representatives” for “Sergeant at Arms of the House”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
