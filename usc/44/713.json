{"tag":"section","attrib":{"id":"id122099b9-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s713"},"text":null,"children":[{"tag":"num","attrib":{"value":"713"},"text":"§ 713.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Journals of Houses of Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"There shall be printed of the Journals of the Senate and House of Representatives eight hundred and twenty copies, which shall be distributed as follows:","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"to the Senate document room, ninety copies for distribution to Senators, and twenty-five additional copies;","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"to the Senate library, ten copies;","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"to the House document room, three hundred and sixty copies for distribution to Members, and twenty-five additional copies;","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"to the Department of State, four copies;","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"to the Superintendent of Documents, one hundred and forty-four copies to be distributed to three libraries in each of the States to be designated by the Superintendent of Documents; and","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"to the Library of the House of Representatives, ten copies.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"The remaining number of the Journals of the Senate and House of Representatives, consisting of twenty-five copies, shall be furnished to the Secretary of the Senate and the Clerk of the House of Representatives, respectively, as the necessities of their respective offices require, as rapidly as signatures are completed for distribution.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id122099ba-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1249"},"text":"82 Stat. 1249","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/tI/s158"},"text":"Pub. L. 97–164, title I, § 158","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1982-04-02"},"text":"Apr. 2, 1982","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/96/47"},"text":"96 Stat. 47","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122099bb-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122099bc-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 147 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s57"},"text":"Jan. 12, 1895, ch. 23, § 57","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/609"},"text":"28 Stat. 609","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1901-03-02"},"text":"Mar. 2, 1901","children":[],"tail":", No. 16, §§ 1, 2, "},{"tag":"ref","attrib":{"href":"/us/stat/31/1464"},"text":"31 Stat. 1464","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id122099bd-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id122099be-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1982—","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164"},"text":"Pub. L. 97–164","children":[],"tail":" substituted “eight hundred and twenty” for “eight hundred and twenty-two” as total number of Journals printed and struck out provision that directed that two copies be distributed to the Court of Claims."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id122099bf-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id122099c0-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1982 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/97/164"},"text":"Pub. L. 97–164","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1982-10-01"},"text":"Oct. 1, 1982","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/97/164/s402"},"text":"section 402 of Pub. L. 97–164","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t28/s171"},"text":"section 171 of Title 28","children":[],"tail":", Judiciary and Judicial Procedure."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
