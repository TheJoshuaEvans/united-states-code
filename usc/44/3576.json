{"tag":"section","attrib":{"id":"id125c1c6d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3576"},"text":null,"children":[{"tag":"num","attrib":{"value":"3576"},"text":"§ 3576.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designated statistical agencies","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id125c1c6e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3576/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Purposes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The purposes of this section are the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id125c1c6f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3576/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To authorize the sharing of business data among the Bureau of the Census, the Bureau of Economic Analysis, and the Bureau of Labor Statistics for exclusively statistical purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125c1c70-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3576/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To reduce the paperwork burdens imposed on businesses that provide requested information to the Federal Government.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125c1c71-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3576/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To improve the comparability and accuracy of Federal economic statistics by allowing the Bureau of the Census, the Bureau of Economic Analysis, and the Bureau of Labor Statistics to update sample frames, develop consistent classifications of establishments and companies into industries, improve coverage, and reconcile significant differences in data produced by the three agencies.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125c1c72-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3576/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" To increase understanding of the United States economy, especially for key industry and regional statistics, to develop more accurate measures of the impact of technology on productivity growth, and to enhance the reliability of the Nation’s most important economic indicators, such as the National Income and Product Accounts.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id125c1c73-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3576/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities of Designated Statistical Agencies","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The head of each of the Designated Statistical Agencies shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id125c1c74-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3576/b/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify opportunities to eliminate duplication and otherwise reduce reporting burden and cost imposed on the public in providing information for statistical purposes;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125c1c75-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3576/b/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" enter into joint statistical projects to improve the quality and reduce the cost of statistical programs; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125c1c76-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3576/b/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" protect the confidentiality of individually identifiable information acquired for statistical purposes by adhering to safeguard principles, including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id125c1c77-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3576/b/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" emphasizing to their officers, employees, and agents the importance of protecting the confidentiality of information in cases where the identity of individual respondents can reasonably be inferred by either direct or indirect means;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125c1c78-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3576/b/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" training their officers, employees, and agents in their legal obligations to protect the confidentiality of individually identifiable information and in the procedures that must be followed to provide access to such information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125c1c79-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3576/b/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" implementing appropriate measures to assure the physical and electronic security of confidential data;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125c1c7a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3576/b/3/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" establishing a system of records that identifies individuals accessing confidential data and the project for which the data were required; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125c1c7b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3576/b/3/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" being prepared to document their compliance with safeguard principles to other agencies authorized by law to monitor such compliance.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id125c1c7c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3576/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Sharing of Business Data Among Designated Statistical Agencies.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id125c1c7d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3576/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"A Designated Statistical Agency may provide business data in an identifiable form to another Designated Statistical Agency under the terms of a written agreement among the agencies sharing the business data that specifies—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id125c1c7e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3576/c/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the business data to be shared;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125c1c7f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3576/c/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the statistical purposes for which the business data are to be used;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125c1c80-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3576/c/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the officers, employees, and agents authorized to examine the business data to be shared; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125c1c81-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3576/c/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" appropriate security procedures to safeguard the confidentiality of the business data.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125c1c82-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3576/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities of agencies under other laws","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The provision of business data by an agency to a Designated Statistical Agency under this section shall in no way alter the responsibility of the agency providing the data under other statutes (including sections 552 and 552b of title 5) with respect to the provision or withholding of such information by the agency providing the data.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125c1c83-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3576/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Responsibilities of officers, employees, and agents","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Examination of business data in identifiable form shall be limited to the officers, employees, and agents authorized to examine the individual reports in accordance with written agreements pursuant to this section. Officers, employees, and agents of a Designated Statistical Agency who receive data pursuant to this section shall be subject to all provisions of law, including penalties, that relate—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id125c1c84-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3576/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the unlawful provision of the business data that would apply to the officers, employees, and agents of the agency that originally obtained the information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125c1c85-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3576/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" to the unlawful disclosure of the business data that would apply to officers, employees, and agents of the agency that originally obtained the information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125c1c86-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3576/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Notice","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Whenever a written agreement concerns data that respondents were required by law to report and the respondents were not informed that the data could be shared among the Designated Statistical Agencies, for exclusively statistical purposes, the terms of such agreement shall be described in a public notice issued by the agency that intends to provide the data. Such notice shall allow a minimum of 60 days for public comment.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id125c1c87-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3576/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Limitations on Use of Business Data Provided by Designated Statistical Agencies.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id125c1c88-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3576/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"General use","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Business data provided by a Designated Statistical Agency pursuant to this section shall be used exclusively for statistical purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125c1c89-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3576/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Publication","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Publication of business data acquired by a Designated Statistical Agency shall occur in a manner whereby the data furnished by any particular respondent are not in identifiable form.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id125c1c8a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3576/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Designated Statistical Agency Defined","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"In this section, the term “Designated Statistical Agency” means each of the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id125c1c8b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3576/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Census Bureau of the Department of Commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125c1c8c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3576/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Bureau of Economic Analysis of the Department of Commerce.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125c1c8d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3576/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Bureau of Labor Statistics of the Department of Labor.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id125c1c8e-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/435/tIII/s302/a"},"text":"Pub. L. 115–435, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5550"},"text":"132 Stat. 5550","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id125c1c8f-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id125c1c90-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id125c1c91-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/435/s403"},"text":"section 403 of Pub. L. 115–435","children":[],"tail":", set out as an Effective Date of 2019 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s306"},"text":"section 306 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
