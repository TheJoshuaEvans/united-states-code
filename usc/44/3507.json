{"tag":"section","attrib":{"id":"id1250365c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507"},"text":null,"children":[{"tag":"num","attrib":{"value":"3507"},"text":"§ 3507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public information collection activities; submission to Director; approval and delegation","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1250365d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An agency shall not conduct or sponsor the collection of information unless in advance of the adoption or revision of the collection of information—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1250365e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the agency has—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1250365f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conducted the review established under section 3506(c)(1);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id12503660-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" evaluated the public comments received under section 3506(c)(2);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id12503661-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" submitted to the Director the certification required under section 3506(c)(3), the proposed collection of information, copies of pertinent statutory authority, regulations, and other related materials as the Director may specify; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id12503662-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/a/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" published a notice in the Federal Register—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id12503663-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/a/1/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" stating that the agency has made such submission; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id12503664-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/a/1/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" setting forth—","children":[],"tail":null},{"tag":"subclause","attrib":{"id":"id12503665-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/a/1/D/ii/I"},"text":null,"children":[{"tag":"num","attrib":{"value":"I"},"text":"(I)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a title for the collection of information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id12503666-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/a/1/D/ii/II"},"text":null,"children":[{"tag":"num","attrib":{"value":"II"},"text":"(II)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a summary of the collection of information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id12503667-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/a/1/D/ii/III"},"text":null,"children":[{"tag":"num","attrib":{"value":"III"},"text":"(III)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a brief description of the need for the information and the proposed use of the information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id12503668-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/a/1/D/ii/IV"},"text":null,"children":[{"tag":"num","attrib":{"value":"IV"},"text":"(IV)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a description of the likely respondents and proposed frequency of response to the collection of information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id12503669-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/a/1/D/ii/V"},"text":null,"children":[{"tag":"num","attrib":{"value":"V"},"text":"(V)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an estimate of the burden that shall result from the collection of information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subclause","attrib":{"id":"id1250366a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/a/1/D/ii/VI"},"text":null,"children":[{"tag":"num","attrib":{"value":"VI"},"text":"(VI)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notice that comments may be submitted to the agency and Director;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1250366b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director has approved the proposed collection of information or approval has been inferred, under the provisions of this section; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1250366c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency has obtained from the Director a control number to be displayed upon the collection of information.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1250366d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall provide at least 30 days for public comment prior to making a decision under subsection (c), (d), or (h), except as provided under subsection (j).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1250366e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1250366f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For any proposed collection of information not contained in a proposed rule, the Director shall notify the agency involved of the decision to approve or disapprove the proposed collection of information.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id12503670-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall provide the notification under paragraph (1), within 60 days after receipt or publication of the notice under subsection (a)(1)(D), whichever is later.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id12503671-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If the Director does not notify the agency of a denial or approval within the 60-day period described under paragraph (2)—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id12503672-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/c/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the approval may be inferred;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id12503673-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/c/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" a control number shall be assigned without further delay; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id12503674-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/c/3/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency may collect the information for not more than 1 year.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id12503675-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id12503676-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" For any proposed collection of information contained in a proposed rule—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id12503677-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/d/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" as soon as practicable, but no later than the date of publication of a notice of proposed rulemaking in the Federal Register, each agency shall forward to the Director a copy of any proposed rule which contains a collection of information and any information requested by the Director necessary to make the determination required under this subsection; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id12503678-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/d/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" within 60 days after the notice of proposed rulemaking is published in the Federal Register, the Director may file public comments pursuant to the standards set forth in section 3508 on the collection of information contained in the proposed rule;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id12503679-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" When a final rule is published in the Federal Register, the agency shall explain—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1250367a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/d/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" how any collection of information contained in the final rule responds to the comments, if any, filed by the Director or the public; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1250367b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/d/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the reasons such comments were rejected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1250367c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Director has received notice and failed to comment on an agency rule within 60 days after the notice of proposed rulemaking, the Director may not disapprove any collection of information specifically contained in an agency rule.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1250367d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/d/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" No provision in this section shall be construed to prevent the Director, in the Director’s discretion—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1250367e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/d/4/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from disapproving any collection of information which was not specifically required by an agency rule;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1250367f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/d/4/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from disapproving any collection of information contained in an agency rule, if the agency failed to comply with the requirements of paragraph (1) of this subsection;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id12503680-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/d/4/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" from disapproving any collection of information contained in a final agency rule, if the Director finds within 60 days after the publication of the final rule that the agency’s response to the Director’s comments filed under paragraph (2) of this subsection was unreasonable; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id12503681-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/d/4/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" from disapproving any collection of information contained in a final rule, if—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id12503682-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/d/4/D/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Director determines that the agency has substantially modified in the final rule the collection of information contained in the proposed rule; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id12503683-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/d/4/D/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency has not given the Director the information required under paragraph (1) with respect to the modified collection of information, at least 60 days before the issuance of the final rule.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id12503684-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/d/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" This subsection shall apply only when an agency publishes a notice of proposed rulemaking and requests public comments.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id12503685-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/d/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The decision by the Director to approve or not act upon a collection of information contained in an agency rule shall not be subject to judicial review.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id12503686-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id12503687-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/e/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any decision by the Director under subsection (c), (d), (h), or (j) to disapprove a collection of information, or to instruct the agency to make substantive or material change to a collection of information, shall be publicly available and include an explanation of the reasons for such decision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id12503688-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/e/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any written communication between the Administrator of the Office of Information and Regulatory Affairs, or any employee of the Office of Information and Regulatory Affairs, and an agency or person not employed by the Federal Government concerning a proposed collection of information shall be made available to the public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id12503689-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/e/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" This subsection shall not require the disclosure of—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1250368a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/e/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any information which is protected at all times by procedures established for information which has been specifically authorized under criteria established by an Executive order or an Act of Congress to be kept secret in the interest of national defense or foreign policy; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1250368b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/e/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any communication relating to a collection of information which is not approved under this subchapter, the disclosure of which could lead to retaliation or discrimination against the communicator.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1250368c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1250368d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/f/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" An independent regulatory agency which is administered by 2 or more members of a commission, board, or similar body, may by majority vote void—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1250368e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/f/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any disapproval by the Director, in whole or in part, of a proposed collection of information of that agency; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id1250368f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/f/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an exercise of authority under subsection (d) of section 3507 concerning that agency.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id12503690-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/f/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The agency shall certify each vote to void such disapproval or exercise to the Director, and explain the reasons for such vote. The Director shall without further delay assign a control number to such collection of information, and such vote to void the disapproval or exercise shall be valid for a period of 3 years.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id12503691-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director may not approve a collection of information for a period in excess of 3 years.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id12503692-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id12503693-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/h/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If an agency decides to seek extension of the Director’s approval granted for a currently approved collection of information, the agency shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id12503694-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/h/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" conduct the review established under section 3506(c), including the seeking of comment from the public on the continued need for, and burden imposed by the collection of information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id12503695-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/h/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" after having made a reasonable effort to seek public comment, but no later than 60 days before the expiration date of the control number assigned by the Director for the currently approved collection of information, submit the collection of information for review and approval under this section, which shall include an explanation of how the agency has used the information that it has collected.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id12503696-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/h/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" If under the provisions of this section, the Director disapproves a collection of information contained in an existing rule, or recommends or instructs the agency to make a substantive or material change to a collection of information contained in an existing rule, the Director shall—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id12503697-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/h/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" publish an explanation thereof in the Federal Register; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id12503698-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/h/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" instruct the agency to undertake a rulemaking within a reasonable time limited to consideration of changes to the collection of information contained in the rule and thereafter to submit the collection of information for approval or disapproval under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id12503699-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/h/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An agency may not make a substantive or material modification to a collection of information after such collection has been approved by the Director, unless the modification has been submitted to the Director for review and approval under this subchapter.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1250369a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1250369b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/i/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" If the Director finds that a senior official of an agency designated under section 3506(a) is sufficiently independent of program responsibility to evaluate fairly whether proposed collections of information should be approved and has sufficient resources to carry out this responsibility effectively, the Director may, by rule in accordance with the notice and comment provisions of chapter 5 of title 5, United States Code, delegate to such official the authority to approve proposed collections of information in specific program areas, for specific purposes, or for all agency purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1250369c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/i/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A delegation by the Director under this section shall not preclude the Director from reviewing individual collections of information if the Director determines that circumstances warrant such a review. The Director shall retain authority to revoke such delegations, both in general and with regard to any specific matter. In acting for the Director, any official to whom approval authority has been delegated under this section shall comply fully with the rules and regulations promulgated by the Director.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1250369d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/j"},"text":null,"children":[{"tag":"num","attrib":{"value":"j"},"text":"(j)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1250369e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/j/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The agency head may request the Director to authorize a collection of information, if an agency head determines that—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id1250369f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/j/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" a collection of information—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id125036a0-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/j/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is needed prior to the expiration of time periods established under this subchapter; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id125036a1-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/j/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" is essential to the mission of the agency; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125036a2-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/j/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the agency cannot reasonably comply with the provisions of this subchapter because—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id125036a3-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/j/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" public harm is reasonably likely to result if normal clearance procedures are followed;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id125036a4-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/j/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" an unanticipated event has occurred; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id125036a5-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/j/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the use of normal clearance procedures is reasonably likely to prevent or disrupt the collection of information or is reasonably likely to cause a statutory or court ordered deadline to be missed.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125036a6-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3507/j/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Director shall approve or disapprove any such authorization request within the time requested by the agency head and, if approved, shall assign the collection of information a control number. Any collection of information conducted under this subsection may be conducted without compliance with the provisions of this subchapter for a maximum of 180 days after the date on which the Director received the request to authorize such collection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id125036a7-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/13/s2"},"text":"Pub. L. 104–13, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-05-22"},"text":"May 22, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/176"},"text":"109 Stat. 176","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dE/tLVI/s5605/d"},"text":"Pub. L. 104–106, div. E, title LVI, § 5605(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/700"},"text":"110 Stat. 700","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title X, § 1064(b)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–275.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id125036a8-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id125036a9-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id125036aa-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3507, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/511/s2/a"},"text":"Pub. L. 96–511, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-11"},"text":"Dec. 11, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2819"},"text":"94 Stat. 2819","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/m/tVIII/s817"},"text":"Pub. L. 99–500, § 101(m) [title VIII, § 817]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-308"},"text":"100 Stat. 1783–308","children":[],"tail":", 1783–338, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/m/tVIII/s817"},"text":"Pub. L. 99–591, § 101(m) [title VIII, § 817]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-308"},"text":"100 Stat. 3341–308","children":[],"tail":", 3341–338, related to submission to Director of public information collection request for an approval or delegation to a senior official of an agency prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/104/13"},"text":"Pub. L. 104–13","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 3507, ","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1304"},"text":"82 Stat. 1304","children":[],"tail":", provided for cooperation of agencies in making information available, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/96/511"},"text":"Pub. L. 96–511","children":[],"tail":". See "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s3510/a"},"text":"section 3510(a) of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id125036ab-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsecs. (e)(3)(B), (h), (j). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" substituted “subchapter” for “chapter” wherever appearing."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—Subsec. (j)(2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" substituted “180 days” for “90 days”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id125036ac-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id125036ad-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" effective 30 days after "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", see section 1 [[div. A], title X, § 1065] of "},{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", formerly set out as an Effective Date note under former "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s3531"},"text":"section 3531 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id125036ae-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/106"},"text":"Pub. L. 104–106","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/s5701"},"text":"section 5701 of Pub. L. 104–106","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/702"},"text":"110 Stat. 702","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id125036af-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective ","children":[{"tag":"date","attrib":{"date":"1995-10-01"},"text":"Oct. 1, 1995","children":[],"tail":", except as otherwise provided, see "},{"tag":"ref","attrib":{"href":"/us/pl/104/13/s4/a"},"text":"section 4(a) of Pub. L. 104–13","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s3501"},"text":"section 3501 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
