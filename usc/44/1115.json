{"tag":"section","attrib":{"id":"id12255511-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1115"},"text":null,"children":[{"tag":"num","attrib":{"value":"1115"},"text":"§ 1115.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports: time of delivery by Director of the Government Publishing Office to Congress","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The annual reports of the Executive Departments and the accompanying documents shall be delivered by the Director of the Government Publishing Office to the proper officer of each House of Congress at its first meeting. Other reports of the Executive Departments shall be so delivered on or before the third Wednesday next after the meeting of Congress or as soon after as may be practicable.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id12255512-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1263"},"text":"82 Stat. 1263","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/c"},"text":"Pub. L. 113–235, div. H, title I, § 1301(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id12255513-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id12255514-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code 1964 ed., § 212 (part) (R.S. 3810).","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section incorporates only the first sentence of former section 212. The balance will be found in section 1114 of this revision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id12255515-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id12255516-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235"},"text":"Pub. L. 113–235","children":[],"tail":" substituted “Director of the Government Publishing Office” for “Public Printer” in section catchline and text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
