{"tag":"section","attrib":{"id":"id121e2940-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s512"},"text":null,"children":[{"tag":"num","attrib":{"value":"512"},"text":"§ 512.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Approval of paper contracts; time for performance; bonds","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"A contract for furnishing paper is not valid until approved by the Joint Committee on Printing. The award of a contract for furnishing paper shall designate a reasonable time for its performance. The contractor shall give bond in an amount fixed and approved by the Committee.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id121e2941-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1244"},"text":"82 Stat. 1244","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id121e2942-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id121e2943-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 8 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s6"},"text":"Jan. 12, 1895, ch. 23, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/602"},"text":"28 Stat. 602","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1917-03-03/ch163/s6"},"text":"Mar. 3, 1917, ch. 163, § 6","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/1121"},"text":"39 Stat. 1121","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
