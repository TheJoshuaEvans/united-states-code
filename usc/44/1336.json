{"tag":"section","attrib":{"id":"id122a100f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1336"},"text":null,"children":[{"tag":"num","attrib":{"value":"1336"},"text":"§ 1336.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Geospatial-Intelligence Agency: special publications","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director of the National Geospatial-Intelligence Agency may authorize the printing of notices to mariners, light lists, sailing directions, bulletins, and other special publications of the National Geospatial-Intelligence Agency in editions the interests of the Government and of the public may require.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id122a1010-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1271"},"text":"82 Stat. 1271","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/dA/tXI"},"text":"Pub. L. 104–201, div. A, title XI","children":[],"tail":", §§ 1112(e)(2), 1123(b)(1), "},{"tag":"date","attrib":{"date":"1996-09-23"},"text":"Sept. 23, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/2684"},"text":"110 Stat. 2684","children":[],"tail":", 2688; "},{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":", [div. A], title IX, § 931(a)(2), "},{"tag":"date","attrib":{"date":"2008-10-14"},"text":"Oct. 14, 2008","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/122/4575"},"text":"122 Stat. 4575","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122a1011-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122a1012-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 213 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s89"},"text":"Jan. 12, 1895, ch. 23, § 89","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/622"},"text":"28 Stat. 622","children":[],"tail":"; "},{"tag":"date","attrib":{"date":"1896-03-13"},"text":"Mar. 13, 1896","children":[],"tail":", No. 23, "},{"tag":"ref","attrib":{"href":"/us/stat/29/466"},"text":"29 Stat. 466","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1925-03-03/ch421/s4"},"text":"Mar. 3, 1925, ch. 421, § 4","children":[],"tail":", 43, Stat. 1106; "},{"tag":"date","attrib":{"date":"1962-07-10"},"text":"July 10, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/87/533"},"text":"Pub. L. 87–533","children":[],"tail":", §§ 1, 2, "},{"tag":"ref","attrib":{"href":"/us/stat/76/154"},"text":"76 Stat. 154","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section incorporates only part of the third sentence, second paragraph of former section 213. The balance will be found in sections 1102, 1116, 1302, 1308, 1309, 1310, of the revision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id122a1013-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id122a1014-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2008—","children":[{"tag":"ref","attrib":{"href":"/us/pl/110/417"},"text":"Pub. L. 110–417","children":[],"tail":" substituted “National Geospatial-Intelligence Agency” for “National Imagery and Mapping Agency” in section catchline and two places in text."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1996—","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1123/b/1"},"text":"Pub. L. 104–201, § 1123(b)(1)","children":[],"tail":", substituted “National Imagery and Mapping Agency” for “Naval Oceanographic Office” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1112/e/2"},"text":"Pub. L. 104–201, § 1112(e)(2)","children":[],"tail":", substituted “Director of the National Imagery and Mapping Agency” for “Secretary of the Navy” and “National Imagery and Mapping Agency” for “United States Naval Oceanographic Office”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id122a1015-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id122a1016-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1996 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/201"},"text":"Pub. L. 104–201","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1996-10-01"},"text":"Oct. 1, 1996","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/104/201/s1124"},"text":"section 1124 of Pub. L. 104–201","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t10/s193"},"text":"section 193 of Title 10","children":[],"tail":", Armed Forces."}],"tail":"\n"}],"