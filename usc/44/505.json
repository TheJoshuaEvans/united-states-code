{"tag":"section","attrib":{"id":"id121bb916-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s505"},"text":null,"children":[{"tag":"num","attrib":{"value":"505"},"text":"§ 505.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Sale of duplicate plates","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director of the Government Publishing Office shall sell, under regulations of the Joint Committee on Printing to persons who may apply, additional or duplicate stereotype or electrotype plates from which a Government publication is printed, at a price not to exceed the cost of composition, the metal, and making to the Government, plus 10 per centum, and the full amount of the price shall be paid when the order is filed.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id121bb917-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1244"},"text":"82 Stat. 1244","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/553/s105/a/1"},"text":"Pub. L. 94–553, § 105(a)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-19"},"text":"Oct. 19, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2599"},"text":"90 Stat. 2599","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/c/1"},"text":"Pub. L. 113–235, div. H, title I, § 1301(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id121bb918-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id121bb919-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 58 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s52"},"text":"Jan. 12, 1895, ch. 23, § 52","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/608"},"text":"28 Stat. 608","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id121bb91a-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id121bb91b-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235"},"text":"Pub. L. 113–235","children":[],"tail":" substituted “Director of the Government Publishing Office” for “Public Printer”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/553"},"text":"Pub. L. 94–553","children":[],"tail":" struck out provision that a publication could not be copyrighted if it was reprinted from additional or duplicate plates purchased from the Government from which Government publications had been printed or if it was reprinted from other Government publications."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id121bb91c-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id121bb91d-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1976 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/553"},"text":"Pub. L. 94–553","children":[],"tail":" effective "},{"tag":"date","attrib":{"date":"1978-01-01"},"text":"Jan. 1, 1978","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/94/553/s102"},"text":"section 102 of Pub. L. 94–553","children":[],"tail":", set out as an Effective Date note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t17/s101"},"text":"section 101 of Title 17","children":[],"tail":", Copyrights."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
