{"tag":"section","attrib":{"id":"id123f943e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2702"},"text":null,"children":[{"tag":"num","attrib":{"value":"2702"},"text":"§ 2702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Membership; chairman; meetings","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id123f943f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2702/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id123f9440-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2702/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Committee shall consist of the eleven members including—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id123f9441-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2702/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id123f9442-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2702/a/1/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id123f9443-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2702/a/1/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Clerk of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id123f9444-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2702/a/1/A/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Archivist of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id123f9445-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2702/a/1/A/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Historian of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id123f9446-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2702/a/1/A/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Historian of the House of Representatives; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id123f9447-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2702/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" six members of whom one shall be appointed by each of the following:","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id123f9448-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2702/a/1/B/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Speaker of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id123f9449-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2702/a/1/B/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Minority Leader of the House of Representatives;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id123f944a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2702/a/1/B/iii"},"text":null,"children":[{"tag":"num","attrib":{"value":"iii"},"text":"(iii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Majority Leader of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id123f944b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2702/a/1/B/iv"},"text":null,"children":[{"tag":"num","attrib":{"value":"iv"},"text":"(iv)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Minority Leader of the Senate;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id123f944c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2702/a/1/B/v"},"text":null,"children":[{"tag":"num","attrib":{"value":"v"},"text":"(v)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Secretary of the Senate; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id123f944d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2702/a/1/B/vi"},"text":null,"children":[{"tag":"num","attrib":{"value":"vi"},"text":"(vi)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Clerk of the House of Representatives.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id123f944e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2702/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each member appointed under paragraph (1)(B) shall have knowledge or expertise in United States history, archival management, publishing, library science, or use of legislative records.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id123f944f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2702/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of the Senate shall serve as Chairman during the two-year period beginning on ","children":[{"tag":"date","attrib":{"date":"1991-01-01"},"text":"January 1, 1991","children":[],"tail":", and the Clerk of the House of Representatives shall serve as Chairman during the two-year period beginning on "},{"tag":"date","attrib":{"date":"1993-01-01"},"text":"January 1, 1993","children":[],"tail":". Thereafter, such members shall alternate serving as Chairman for a term of two years."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id123f9450-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2702/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id123f9451-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2702/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Members of the Committee referred to in subsection (a)(1)(A) shall serve only while holding such offices. Members appointed to the Committee under subsection (a)(1)(B) shall serve for a term of two years, and may be reappointed without limitation. The initial appointments for such terms shall begin on ","children":[{"tag":"date","attrib":{"date":"1991-01-01"},"text":"January 1, 1991","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id123f9452-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2702/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any vacancy on the Committee shall not affect the powers of the Committee. Any vacancy in an appointed position on the Committee shall be filled in the same manner in which the original appointment was made.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id123f9453-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2702/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id123f9454-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2702/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" No later than thirty days after the date on which the first session of the 102d Congress begins, the Committee shall hold its first meeting. Thereafter, the Committee shall meet semiannually or at the call of a majority of its members.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id123f9455-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2702/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Seven members of the Committee shall constitute a quorum, but a lesser number may hold hearings.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id123f9456-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/101/509/tIV/s1/d/1"},"text":"Pub. L. 101–509, title IV, § 1(d)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1990-11-05"},"text":"Nov. 5, 1990","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/104/1417"},"text":"104 Stat. 1417","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id123f9457-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id123f9458-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id123f9459-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"The date on which the first session of the 102d Congress begins, referred to in subsec. (d)(1), is ","children":[{"tag":"date","attrib":{"date":"1991-01-03"},"text":"Jan. 3, 1991","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
