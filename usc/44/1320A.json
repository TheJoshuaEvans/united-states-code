{"tag":"section","attrib":{"id":"id12279fbd-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1320A"},"text":null,"children":[{"tag":"num","attrib":{"value":"1320A"},"text":"§ 1320A.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Historical societies’ publications","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Notwithstanding any other provision of law, and with the approval of the Joint Committee on Printing, the Director of the Government Publishing Office shall provide for such printing services and distribution with respect to publications of the United States Capitol Historical Society, the Supreme Court Historical Society, or the White House Historical Association as such Society or Association may request: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That such Society or Association reimburses the Director of the Government Publishing Office for the actual expenses incurred by him in providing for such services and distribution."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id12279fbe-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/536/s101/c"},"text":"Pub. L. 96–536, § 101(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-16"},"text":"Dec. 16, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/3167"},"text":"94 Stat. 3167","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/c/1"},"text":"Pub. L. 113–235, div. H, title I, § 1301(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id12279fbf-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id12279fc0-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"codification","id":"id12279fc1-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Codification","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section is based on section 304(a) of H.R. 7593, as passed the House of Representatives, ","children":[{"tag":"date","attrib":{"date":"1980-07-21"},"text":"July 21, 1980","children":[],"tail":", and incorporated by reference in "},{"tag":"ref","attrib":{"href":"/us/pl/96/536/s101/c"},"text":"section 101(c) of Pub. L. 96–536","children":[],"tail":", to be effective as if enacted into law."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id12279fc2-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235"},"text":"Pub. L. 113–235","children":[],"tail":" substituted “Director of the Government Publishing Office” for “Public Printer” in two places."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
