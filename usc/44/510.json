{"tag":"section","attrib":{"id":"id121e2938-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s510"},"text":null,"children":[{"tag":"num","attrib":{"value":"510"},"text":"§ 510.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Specifications in advertisements for paper","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The advertisements for proposals shall specify the minimum portion of each quality of paper required for either three months, six months, or one year, as the Joint Committee on Printing determines; but when the minimum portion so specified exceeds, in any case, one thousand reams, it shall state that proposals will be received for one thousand reams or more.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id121e2939-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1244"},"text":"82 Stat. 1244","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id121e293a-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id121e293b-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1954 ed., § 6 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s4"},"text":"Jan. 12, 1895, ch. 23, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/601"},"text":"28 Stat. 601","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
