{"tag":"section","attrib":{"id":"id122ecb8e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1916"},"text":null,"children":[{"tag":"num","attrib":{"value":"1916"},"text":"§ 1916.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Designation of libraries of accredited law schools as depository libraries","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id122ecb8f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1916/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Upon the request of any accredited law school, the Director of the Government Publishing Office shall designate the library of such law school as a depository library. The Director of the Government Publishing Office may not make such designation unless he determines that the library involved meets the requirements of this chapter, other than those requirements of the first undesignated paragraph of ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s1909"},"text":"section 1909 of this title","children":[],"tail":" which relate to the location of such library."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id122ecb90-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1916/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" For purposes of this section, the term “accredited law school” means any law school which is accredited by a nationally recognized accrediting agency or association approved by the Commissioner of Education for such purpose or accredited by the highest appellate court of the State in which the law school is located.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id122ecb91-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/95/261/s1"},"text":"Pub. L. 95–261, 