{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/261/s3"},"text":"Pub. L. 95–261, § 3","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-04-17"},"text":"Apr. 17, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/199"},"text":"92 Stat. 199","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/261/s3"},"text":"“The amendments made by this Act [enacting this section] shall take effect on ","children":[{"tag":"date","attrib":{"date":"1978-10-01"},"text":"October 1, 1978","children":[],"tail":".”"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"transferOfFunctions","id":"id122ecb97-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Transfer of Functions","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Functions of Commissioner of Education transferred to Secretary of Education pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t20/s3441/a/1"},"text":"section 3441(a)(1) of Title 20","children":[],"tail":", Education."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
