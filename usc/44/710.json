{"tag":"section","attrib":{"id":"id121e29a1-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s710"},"text":null,"children":[{"tag":"num","attrib":{"value":"710"},"text":"§ 710.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Copies of Acts furnished to Director of the Government Publishing Office","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Archivist of the United States shall furnish to the Director of the Government Publishing Office a copy of every Act and joint resolution, as soon as possible after its approval by the President, or after it has become a law under the Constitution without his approval.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id121e29a2-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1249"},"text":"82 Stat. 1249","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/tI/s107/b/1"},"text":"Pub. L. 98–497, title I, § 107(b)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2286"},"text":"98 Stat. 2286","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/c"},"text":"Pub. L. 113–235, div. H, title I, § 1301(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id121e29a3-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"