{"tag":"section","attrib":{"id":"id124b7b04-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502"},"text":null,"children":[{"tag":"num","attrib":{"value":"3502"},"text":"§ 3502.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Definitions","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"As used in this subchapter—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id124b7b05-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “agency” means any executive department, military department, Government corporation, Government controlled corporation, or other establishment in the executive branch of the Government (including the Executive Office of the President), or any independent regulatory agency, but does not include—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id124b7b06-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the Government Accountability Office;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id124b7b07-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Federal Election Commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id124b7b08-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the governments of the District of Columbia and of the territories and possessions of the United States, and their various subdivisions; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id124b7b09-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/1/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Government-owned contractor-operated facilities, including laboratories engaged in national defense research and production activities;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id124b7b0a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “burden” means time, effort, or financial resources expended by persons to generate, maintain, or provide information to or for a Federal agency, including the resources expended for—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id124b7b0b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/2/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" reviewing instructions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id124b7b0c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/2/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" acquiring, installing, and utilizing technology and systems;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id124b7b0d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/2/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" adjusting the existing ways to comply with any previously applicable instructions and requirements;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id124b7b0e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/2/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" searching data sources;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id124b7b0f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/2/E"},"text":null,"children":[{"tag":"num","attrib":{"value":"E"},"text":"(E)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" completing and reviewing the collection of information; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id124b7b10-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/2/F"},"text":null,"children":[{"tag":"num","attrib":{"value":"F"},"text":"(F)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" transmitting, or otherwise disclosing the information;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id124b7b11-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “collection of information”—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id124b7b12-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/3/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" means the obtaining, causing to be obtained, soliciting, or requiring the disclosure to third parties or the public, of facts or opinions by or for an agency, regardless of form or format, calling for either—","children":[],"tail":null},{"tag":"clause","attrib":{"id":"id124b7b13-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/3/A/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" answers to identical questions posed to, or identical reporting or recordkeeping requirements imposed on, ten or more persons, other than agencies, instrumentalities, or employees of the United States; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"clause","attrib":{"id":"id124b7b14-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/3/A/ii"},"text":null,"children":[{"tag":"num","attrib":{"value":"ii"},"text":"(ii)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" answers to questions posed to agencies, instrumentalities, or employees of the United States which are to be used for general statistical purposes; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id124b7b15-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/3/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" shall not include a collection of information described under section 3518(c)(1);","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id124b7b16-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “Director” means the Director of the Office of Management and Budget;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id124b7b17-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “independent regulatory agency” means the Board of Governors of the Federal Reserve System, the Commodity Futures Trading Commission, the Consumer Product Safety Commission, the Federal Communications Commission, the Federal Deposit Insurance Corporation, the Federal Energy Regulatory Commission, the Federal Housing Finance Agency, the Federal Maritime Commission, the Federal Trade Commission, the Interstate Commerce Commission, the Mine Enforcement Safety and Health Review Commission, the National Labor Relations Board, the Nuclear Regulatory Commission, the Occupational Safety and Health Review Commission, the Postal Regulatory Commission, the Securities and Exchange Commission, the Bureau of Consumer Financial Protection, the Office of Financial Research, Office of the Comptroller of the Currency, and any other similar agency designated by statute as a Federal independent regulatory agency or commission;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id124b7b18-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “information resources” means information and related resources, such as personnel, equipment, funds, and information technology;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id124b7b19-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “information resources management” means the process of managing information resources to accomplish agency missions and to improve agency performance, including through the reduction of information collection burdens on the public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id124b7b1a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “information system” means a discrete set of information resources organized for the collection, processing, maintenance, use, sharing, dissemination, or disposition of information;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id124b7b1b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “information technology” has the meaning given that term in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t40/s11101"},"text":"section 11101 of title 40","children":[],"tail":" but does not include national security systems as defined in "},{"tag":"ref","attrib":{"href":"/us/usc/t40/s11103"},"text":"section 11103 of title 40","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id124b7b1c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “person” means an individual, partnership, association, corporation, business trust, or legal representative, an organized group of individuals, a State, territorial, tribal, or local government or branch thereof, or a political subdivision of a State, territory, tribal, or local government or a branch of a political subdivision;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id124b7b1d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “practical utility” means the ability of an agency to use information, particularly the capability to process such information in a timely and useful fashion;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id124b7b1e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “public information” means any information, regardless of form or format, that an agency discloses, disseminates, or makes available to the public;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id124b7b1f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “recordkeeping requirement” means a requirement imposed by or for an agency on persons to maintain specified records, including a requirement to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id124b7b20-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/13/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" retain such records;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id124b7b21-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/13/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" notify third parties, the Federal Government, or the public of the existence of such records;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id124b7b22-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/13/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" disclose such records to third parties, the Federal Government, or the public; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id124b7b23-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/13/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" report to third parties, the Federal Government, or the public regarding such records;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id124b7b24-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “penalty” includes the imposition by an agency or court of a fine or other punishment; a judgment for monetary damages or equitable relief; or the revocation, suspension, reduction, or denial of a license, privilege, right, grant, or benefit;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id124b7b25-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/15"},"text":null,"children":[{"tag":"num","attrib":{"value":"15"},"text":"(15)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “comprehensive data inventory” means the inventory created under section 3511(a), but does not include any underlying data asset listed on the inventory;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id124b7b26-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/16"},"text":null,"children":[{"tag":"num","attrib":{"value":"16"},"text":"(16)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “data” means recorded information, regardless of form or the media on which the data is recorded;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id124b7b27-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/17"},"text":null,"children":[{"tag":"num","attrib":{"value":"17"},"text":"(17)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “data asset” means a collection of data elements or data sets that may be grouped together;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id124b7b28-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/18"},"text":null,"children":[{"tag":"num","attrib":{"value":"18"},"text":"(18)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “machine-readable”, when used with respect to data, means data in a format that can be easily processed by a computer without human intervention while ensuring no semantic meaning is lost;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id124b7b29-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/19"},"text":null,"children":[{"tag":"num","attrib":{"value":"19"},"text":"(19)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “metadata” means structural or descriptive information about data such as content, format, source, rights, accuracy, provenance, frequency, periodicity, granularity, publisher or responsible party, contact information, method of collection, and other descriptions;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id124b7b2a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/20"},"text":null,"children":[{"tag":"num","attrib":{"value":"20"},"text":"(20)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “open Government data asset” means a public data asset that is—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id124b7b2b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/20/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" machine-readable;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id124b7b2c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/20/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" available (or could be made available) in an open format;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id124b7b2d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/20/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" not encumbered by restrictions, other than intellectual property rights, including under titles 17 and 35, that would impede the use or reuse of such asset; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id124b7b2e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/20/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" based on an underlying open standard that is maintained by a standards organization;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id124b7b2f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/21"},"text":null,"children":[{"tag":"num","attrib":{"value":"21"},"text":"(21)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" the term “open license” means a legal guarantee that a data asset is made available—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id124b7b30-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/21/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" at no cost to the public; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id124b7b31-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/21/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" with no restrictions on copying, publishing, distributing, transmitting, citing, or adapting such asset;","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id124b7b32-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/22"},"text":null,"children":[{"tag":"num","attrib":{"value":"22"},"text":"(22)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “public data asset” means a data asset, or part thereof, maintained by the Federal Government that has been, or may be, released to the public, including any data asset, or part thereof, subject to disclosure under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s552"},"text":"section 552 of title 5","children":[],"tail":"; and"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id124b7b33-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3502/23"},"text":null,"children":[{"tag":"num","attrib":{"value":"23"},"text":"(23)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the term “statistical laws” means subchapter III of this chapter and other laws pertaining to the protection of information collected for statistical purposes as designated by the Director.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id124b7b34-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/13/s2"},"text":"Pub. L. 104–13, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-05-22"},"text":"May 22, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/164"},"text":"109 Stat. 164","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/104/106/dE/tLVI/s5605/a"},"text":"Pub. L. 104–106, div. E, title LVI, § 5605(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1996-02-10"},"text":"Feb. 10, 1996","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/110/700"},"text":"110 Stat. 700","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/105/85/dA/tX/s1073/h/5/A"},"text":"Pub. L. 105–85, div. A, title X, § 1073(h)(5)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1997-11-18"},"text":"Nov. 18, 1997","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/111/1907"},"text":"111 Stat. 1907","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title X, § 1064(b)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–275; "},{"tag":"ref","attrib":{"href":"/us/pl/107/217/s3"},"text":"Pub. L. 107–217, § 3","children":[],"tail":"("},{"tag":"i","attrib":{},"text":"l","children":[],"tail":")(4), "},{"tag":"date","attrib":{"date":"2002-08-21"},"text":"Aug. 21, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/1301"},"text":"116 Stat. 1301","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/271/s8/b"},"text":"Pub. L. 108–271, § 8(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-07-07"},"text":"July 7, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/814"},"text":"118 Stat. 814","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/109/435/tVI/s604/e"},"text":"Pub. L. 109–435, title VI, § 604(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2006-12-20"},"text":"Dec. 20, 2006","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/120/3242"},"text":"120 Stat. 3242","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/110/289/dA/tII/s1216/e"},"text":"Pub. L. 110–289, div. A, title II, § 1216(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2008-07-