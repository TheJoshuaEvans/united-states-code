{"tag":"section","attrib":{"id":"id1260d877-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3702"},"text":null,"children":[{"tag":"num","attrib":{"value":"3702"},"text":"§ 3702.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Advertisements not to be published without written authority","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Advertisements, notices, or proposals for an executive department of the Government, or for a bureau or office connected with it, may not be published in a newspaper except under written authority from the head of the department; and a bill for advertising or publication may not be paid unless there is presented with the bill a copy of the written authority.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id1260d878-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1305"},"text":"82 Stat. 1305","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1260d879-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id1260d87a-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 324 (R.S. § 3828).","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
