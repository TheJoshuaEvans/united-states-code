{"tag":"section","attrib":{"id":"id122ecb69-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1908"},"text":null,"children":[{"tag":"num","attrib":{"value":"1908"},"text":"§ 1908.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" American Antiquarian Society to receive certain publications","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"One copy of the public journals of the Senate and of the House of Representatives, and of the documents published under the orders of the Senate and House of Representatives, respectively, shall be transmitted to the Executive of the Commonwealth of Massachusetts for the use and benefit of the American Antiquarian Society of the Commonwealth.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id122ecb6a-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1285"},"text":"82 Stat. 1285","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122ecb6b-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122ecb6c-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 88 (","children":[{"tag":"date","attrib":{"date":"1814-12-01"},"text":"Dec. 1, 1814","children":[],"tail":", No. 7, "},{"tag":"ref","attrib":{"href":"/us/stat/3/248"},"text":"3 Stat. 248","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
