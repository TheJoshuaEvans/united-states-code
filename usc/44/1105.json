{"tag":"section","attrib":{"id":"id122554d3-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1105"},"text":null,"children":[{"tag":"num","attrib":{"value":"1105"},"text":"§ 1105.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Form and style of work for departments","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director of the Government Publishing Office shall determine the form and style in which the printing or binding ordered by a department is executed, and the material and the size of type used, having proper regard to economy, workmanship, and the purposes for which the work is needed.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id122554d4-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1261"},"text":"82 Stat. 1261","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/c/1"},"text":"Pub. L. 113–235, div. H, title I, § 1301(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122554d5-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122554d6-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 216 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s51"},"text":"Jan. 12, 1895, ch. 23, § 51","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/608"},"text":"28 Stat. 608","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id122554d7-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id122554d8-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235"},"text":"Pub. L. 113–235","children":[],"tail":" substituted “Director of the Government Publishing Office” for “Public Printer”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
