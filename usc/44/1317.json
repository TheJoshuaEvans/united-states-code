{"tag":"section","attrib":{"id":"id12279fa4-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1317"},"text":null,"children":[{"tag":"num","attrib":{"value":"1317"},"text":"§ 1317.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Foreign Relations","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In addition to the usual number of Foreign Relations, three thousand copies of each shall be printed: one thousand for the Senate and two thousand for the House of Representatives.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id12279fa5-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1268"},"text":"82 Stat. 1268","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id12279fa6-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id12279fa7-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 250 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s73"},"text":"Jan. 12, 1895, ch. 23, § 73","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/613"},"text":"28 Stat. 613","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id12279fa8-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id12279fa9-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Publication of “Foreign Relations of the United States” at Continuing High Standard of Documentation","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/95/426/tI/s120"},"text":"Pub. L. 95–426, title I, § 120","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1978-10-07"},"text":"Oct. 7, 1978","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/92/970"},"text":"92 Stat. 970","children":[],"tail":", provided that:"},{"tag":"quotedContent","attrib":{"origin":"/us/pl/95/426/tI/s120"},"text":"\n","children":[{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"“(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Congress finds that the Department of State publication ‘Foreign Relations of the United States’ plays an important role in making the documentary record of United States foreign relations available to the Congress and the American public.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"“(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Secretary of State shall therefore insure that publication of the ‘Foreign Relations of the United States’ volumes is continued in such a manner as will maintain the high standard of comprehensive documentation already established by past volumes.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"miscellaneous","id":"id12279faa-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Written Requests for Documents","children":[],"tail":null},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/94/59/tVIII"},"text":"Pub. L. 94–59, title VIII","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1975-07-25"},"text":"July 25, 1975","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/89/296"},"text":"89 Stat. 296","children":[],"tail":", provided that: "},{"tag":"quotedContent","attrib":{"origin":"/us/pl/94/59/tVIII"},"text":"“Hereafter, notwithstanding any other provisions of law, appropriations for the automatic distribution to Senators and Representatives (including Delegates to Congress and the Resident Commissioner from Puerto Rico) of copies of the Foreign Relations of the United States, the United States Treaties and Other International Agreements, the District of Columbia Code and Supplements, and more than one bound set of the United States Code and Supplements shall not be available with respect to any Senator or Representative unless such Senator or Representative specifically, in writing, requests that he receive copies of such documents.”","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
