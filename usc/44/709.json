{"tag":"section","attrib":{"id":"id121e299b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s709"},"text":null,"children":[{"tag":"num","attrib":{"value":"709"},"text":"§ 709.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public and private laws, postal conventions, and treaties","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director of the Government Publishing Office shall print in slip form copies of public and private laws, postal conventions, and treaties, to be charged to the congressional allotment for printing and binding. The Joint Committee on Printing shall control the number and distribution of copies.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id121e299c-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1249"},"text":"82 Stat. 1249","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/c/1"},"text":"Pub. L. 113–235, div. H, title I, § 1301(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id121e299d-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id121e299e-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 191 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s56"},"text":"Jan. 12, 1895, ch. 23, § 56","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/609"},"text":"28 Stat. 609","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1952-07-10/ch632/s7"},"text":"July 10, 1952, ch. 632, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/66/541"},"text":"66 Stat. 541","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id121e299f-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id121e29a0-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235"},"text":"Pub. L. 113–235","children":[],"tail":" substituted “Director of the Government Publishing Office” for “Public Printer”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
