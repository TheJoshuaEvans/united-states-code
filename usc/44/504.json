{"tag":"section","attrib":{"id":"id121bb90e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s504"},"text":null,"children":[{"tag":"num","attrib":{"value":"504"},"text":"§ 504.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Direct purchase of printing, binding, and blank-book work by Government agencies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Joint Committee on Printing may permit the Director of the Government Publishing Office to authorize an executive department, independent office, or establishment of the Government to purchase direct for its use such printing, binding, and blank-book work, otherwise authorized by law, as the Government Publishing Office is not able or suitably equipped to execute or as may be more economically or in the better interest of the Government executed elsewhere.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id121bb90f-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1243"},"text":"82 Stat. 1243","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/b"},"text":"Pub. L. 113–235, div. H, title I, § 1301(b)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id121bb910-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id121bb911-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 14 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s12"},"text":"Jan. 12, 1895, ch. 23, § 12","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/602"},"text":"28 Stat. 602","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1935-07-08/ch374/s1"},"text":"July 8, 1935, ch. 374, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/475"},"text":"49 Stat. 475","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1951-10-31/ch654/s3/10"},"text":"Oct. 31, 1951, ch. 654, § 3(10)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/65/708"},"text":"65 Stat. 708","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id121bb912-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id121bb913-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/c/1"},"text":"Pub. L. 113–235, § 1301(c)(1)","children":[],"tail":", substituted “Director of the Government Publishing Office” for “Public Printer”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id121bb914-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id121bb915-e3ef-11ef-8e9f