{"tag":"section","attrib":{"id":"id122554f8-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1111"},"text":null,"children":[{"tag":"num","attrib":{"value":"1111"},"text":"§ 1111.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Annual reports: time for furnishing manuscript and proofs to Director of the Government Publishing Office","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The appropriations made for printing and binding may not be used for an annual report or the accompanying documents unless the manuscript and proof is furnished to the Director of the Government Publishing Office in the following manner:","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"manuscript of the documents accompanying annual reports on or before February 1, each year;","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"manuscript of the annual report on or before February 15, each year;","children":[],"tail":"\n"},{"tag":"p","attrib":{"role":"listItem"},"text":"complete revised proofs of the accompanying documents on March 1, each year, and of the annual reports on March 10, each year.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Annual reports and accompanying documents shall be printed, made public, and available for distribution not later than within the first five days after the assembling of each regular session of Congress.","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section does not apply to the annual reports of the Smithsonian Institution, the Comptroller of the Currency, or the Secretary of the Treasury.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id122554f9-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1263"},"text":"82 Stat. 1263","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/94/273/s28"},"text":"Pub. L. 94–273, § 28","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-04-21"},"text":"Apr. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/380"},"text":"90 Stat. 380","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/106/113/dB/s1000/a/9/tIV/s4732/b/22"},"text":"Pub. L. 106–113, div. B, § 1000(a)(9) [title IV, § 4732(b)(22)]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1999-11-29"},"text":"Nov. 29, 1999","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/113/1536"},"text":"113 Stat. 1536","children":[],"tail":", 1501A–585; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/c"},"text":"Pub. L. 113–235, div. H, title I, § 1301(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122554fa-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122554fb-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., Supp. II, § 121 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1916-07-01/ch209/s3"},"text":"July 1, 1916, ch. 209, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/39/336"},"text":"39 Stat. 336","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1936-06-20/ch630/s8"},"text":"June 20, 1936, ch. 630, § 8","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/1550"},"text":"49 Stat. 1550","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id122554fc-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id122554fd-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235"},"text":"Pub. L. 113–235","children":[],"tail":" substituted “Director of the Government Publishing Office” for “Public Printer” in section catchline and introductory provisions of first undesignated par."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1999—","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/113"},"text":"Pub. L. 106–113","children":[],"tail":" struck out “the Commissioner of Patents,” after “Smithsonian Institution,” in last par."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/273"},"text":"Pub. L. 94–273","children":[],"tail":" substituted “February” for “November” and “March” for “December” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id122554fe-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id122554ff-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1999 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":