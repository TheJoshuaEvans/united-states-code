{"tag":"section","attrib":{"id":"id122554be-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1102"},"text":null,"children":[{"tag":"num","attrib":{"value":"1102"},"text":"§ 1102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Printing to be authorized by law and necessary to the public business, not in excess of appropriation, and on special requisition filed with the Director of the Government Publishing Office","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id122554bf-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A head of an executive department, or of an independent agency or establishment of the Government may not cause to be printed, and the Director of the Government Publishing Office may not print, a document or matter unless it is authorized by law and necessary to the public business.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id122554c0-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Printing may not be done for an executive department, independent agency or establishment in a fiscal year in excess of the amount of the appropriation.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id122554c1-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1102/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Printing may not be done without a special requisition signed by the chief of the department, independent agency or establishment and filed with the Director of the Government Publishing Office.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id122554c2-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1261"},"text":"82 Stat. 1261","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/c"},"text":"Pub. L. 113–235, div. H, title I, § 1301(c)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122554c3-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122554c4-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., §§ 213, 219 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s89"},"text":"Jan. 12, 1895, ch. 23, § 89","children":[],"tail":", 94, "},{"tag":"ref","attrib":{"href":"/us/stat/28/622"},"text":"28 Stat. 622","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"This section incorporates the first paragraph of former section 213 and the first clause of former section 219. The balance of former section 213 will be found in sections 1116, 1302, 1308, 1309, 1310, 1336 of the revision; that of former section 219 in section 1113 of the revision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id122554c5-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id122554c6-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/c/2"},"text":"Pub. L. 113–235, § 1301(c)(2)","children":[],"tail":", substituted “Director of the Government Publishing Office” for “Public Printer” in section catchline."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsecs. (a), (c). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/c/1"},"text":"Pub. L. 113–235, § 1301(c)(1)","children":[],"tail":", substituted “Director of the Government Publishing Office” for “Public Printer”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
