{"tag":"section","attrib":{"id":"id122099d7-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s718"},"text":null,"children":[{"tag":"num","attrib":{"value":"718"},"text":"§ 718.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Lapse of authority to print","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The authority to print a document or report, or a publication authorized by law to be printed, for distribution by Congress, shall lapse when the whole number of copies has not been ordered within two years from the date of the original order, except orders for subsequent editions, approved by the Joint Committee on Printing, in which case the whole number may not exceed that originally authorized by law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id122099d8-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1250"},"text":"82 Stat. 1250","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122099d9-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122099da-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 141 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1907-03-01/ch2284/s5"},"text":"Mar. 1, 1907, ch. 2284, § 5","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/1014"},"text":"34 Stat. 1014","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
