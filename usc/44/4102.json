{"tag":"section","attrib":{"id":"id126348ea-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s4102"},"text":null,"children":[{"tag":"num","attrib":{"value":"4102"},"text":"§ 4102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Fees","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id126348eb-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s4102/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In General","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Superintendent of Documents, under the direction of the Director of the Government Publishing Office, may charge reasonable fees for use of the directory and the system of access provided for under section 4101, except that use of the directory and the system shall be made available to depository libraries without charge. The fees received shall be treated in the same manner as moneys received from sale of documents under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s1702"},"text":"section 1702 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id126348ec-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s4102/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Cost Recovery","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The fees charged under this section shall be set so as to recover the incremental cost of dissemination of the information involved, with the cost to be computed without regard to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s1708"},"text":"section 1708 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id126348ed-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/103/40/s2/a"},"text":"Pub. L. 103–40, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1993-06-08"},"text":"June 8, 1993","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/107/113"},"text":"107 Stat. 113","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/c/1"},"text":"Pub. L. 113–235, div. H, title I, § 1301(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id126348ee-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id126348ef-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id126348f0-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235"},"text":"Pub. L. 113–235","children":[],"tail":" substituted “Director of the Government Publishing Office” for “Public Printer”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
