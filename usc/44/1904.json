{"tag":"section","attrib":{"id":"id122ecb52-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1904"},"text":null,"children":[{"tag":"num","attrib":{"value":"1904"},"text":"§ 1904.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Classified list of Government publications for selection by depositories","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Superintendent of Documents shall currently issue a classified list of Government publications in suitable form, containing annotations of contents and listed by item identification numbers to facilitate the selection of only those publications needed by depository libraries. The selected publications shall be distributed to depository libraries in accordance with regulations of the Superintendent of Documents, as long as they fulfill the conditions provided by law.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id122ecb53-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1284"},"text":"82 Stat. 1284","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122ecb54-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122ecb55-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964, ed. § 83 (R.S. § 502; ","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23"},"text":"Jan. 12, 1895, ch. 23","children":[],"tail":", §§ 53, 61, "},{"tag":"ref","attrib":{"href":"/us/stat/28/608"},"text":"28 Stat. 608","children":[],"tail":", 610; "},{"tag":"date","attrib":{"date":"1962-08-09"},"text":"Aug. 9, 1962","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/pl/87/579/s3"},"text":"Pub. L. 87–579, § 3","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/76/353"},"text":"76 Stat. 353","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
