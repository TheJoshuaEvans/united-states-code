{"tag":"section","attrib":{"id":"id125c1cb8-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3583"},"text":null,"children":[{"tag":"num","attrib":{"value":"3583"},"text":"§ 3583.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Application to access data assets for developing evidence","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id125c1cb9-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3583/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Standard Application Process","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Director shall establish a process through which agencies, the Congressional Budget Office, State, local, and Tribal governments, researchers, and other individuals, as appropriate, may apply to access the data assets accessed or acquired under this subchapter by a statistical agency or unit for purposes of developing evidence. The process shall include the following:","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id125c1cba-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3583/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Sufficient detail to ensure that each statistical agency or unit establishes an identical process.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125c1cbb-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3583/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" A common application form.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125c1cbc-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3583/a/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Criteria for statistical agencies and units to determine whether to grant an applicant access to a data asset.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125c1cbd-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3583/a/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Timeframes for prompt determinations by each statistical agency or unit.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125c1cbe-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3583/a/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" An appeals process for adverse decisions and noncompliance with the process established under this subsection.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id125c1cbf-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3583/a/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Standards for transparency, including requirements to make the following information publicly available:","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id125c1cc0-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3583/a/6/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Each application received.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125c1cc1-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3583/a/6/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The status of each application.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125c1cc2-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3583/a/6/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The determination made for each application.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id125c1cc3-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3583/a/6/D"},"text":null,"children":[{"tag":"num","attrib":{"value":"D"},"text":"(D)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Any other information, as appropriate, to ensure full transparency of the process established under this subsection.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id125c1cc4-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3583/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"In establishing the process required under subsection (a), the Director shall consult with stakeholders, including the public, agencies, State and local governments, and representatives of non-governmental researchers.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id125c1cc5-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3583/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Implementation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of each statistical agency or unit shall implement the process established under subsection (a).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id125c1cc6-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/435/tIII/s303/a"},"text":"Pub. L. 115–435, title III, § 303(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5555"},"text":"132 Stat. 5555","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id125c1cc7-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id125c1cc8-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id125c1cc9-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/435/s403"},"text":"section 403 of Pub. L. 115–435","children":[],"tail":", set out as an Effective Date of 2019 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s306"},"text":"section 306 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
