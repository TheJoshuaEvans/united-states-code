{"tag":"section","attrib":{"id":"id1246bfaa-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3310"},"text":null,"children":[{"tag":"num","attrib":{"value":"3310"},"text":"§ 3310.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Disposal of records constituting menace to health, life, or property","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When the Archivist and the head of the agency that has custody of them jointly determine that records in the custody of an agency of the United States Government are a continuing menace to human health or life or to property, the Archivist shall eliminate the menace immediately by any method he considers necessary. When records in the custody of the Archivist are disposed of under this section, the Archivist shall report their disposal to the agency from which they were transferred.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id1246bfab-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1301"},"text":"82 Stat. 1301","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/tI/s107/b/24"},"text":"Pub. L. 98–497, title I, § 107(b)(24)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2290"},"text":"98 Stat. 2290","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1246bfac-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id1246bfad-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 375 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1943-07-07/ch192/s10"},"text":"July 7, 1943, ch. 192, § 10","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/57/382"},"text":"57 Stat. 382","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title I, § 104(a), "},{"tag":"ref","attrib":{"href":"/us/stat/63/381"},"text":"63 Stat. 381","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1246bfae-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id1246bfaf-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" substituted “Archivist” for “Administrator of General Services” and “Archivist” for “Administrator” wherever appearing."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id1246bfb0-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id1246bfb1-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[