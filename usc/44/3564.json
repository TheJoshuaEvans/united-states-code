{"tag":"section","attrib":{"id":"id1259d340-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3564"},"text":null,"children":[{"tag":"num","attrib":{"value":"3564"},"text":"§ 3564.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Effect on other laws","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1259d341-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3564/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Title","children":[],"tail":" 44, "},{"tag":"inline","attrib":{},"text":"United States Code","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subchapter does not diminish the authority under section 3510 of the Director to direct, and of an agency to make, disclosures that are not inconsistent with any applicable law.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1259d342-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3564/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Title","children":[],"tail":" 13 "},{"tag":"inline","attrib":{},"text":"and Title","children":[],"tail":" 44, "},{"tag":"inline","attrib":{},"text":"United States Code","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subchapter does not diminish the authority of the Bureau of the Census to provide information in accordance with sections 8, 16, 301, and 401 of title 13 and ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s2108"},"text":"section 2108 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1259d343-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3564/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Title","children":[],"tail":" 13, "},{"tag":"inline","attrib":{},"text":"United States Code","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subchapter shall not be construed as authorizing the disclosure for nonstatistical purposes of demographic data or information collected by the Bureau of the Census pursuant to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t13/s9"},"text":"section 9 of title 13","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1259d344-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3564/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Various Energy Statutes","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"Data or information acquired by the Energy Information Administration under a pledge of confidentiality and designated by the Energy Information Administration to be used for exclusively statistical purposes shall not be disclosed in identifiable form for nonstatistical purposes under—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1259d345-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3564/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 12, 20, or 59 of the Federal Energy Administration Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s771"},"text":"15 U.S.C. 771","children":[],"tail":", 779, 790h);"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d346-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3564/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 11 of the Energy Supply and Environmental Coordination Act of 1974 (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t15/s796"},"text":"15 U.S.C. 796","children":[],"tail":"); or"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1259d347-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3564/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" section 205 or 407 of the Department of Energy Organization Act (","children":[{"tag":"ref","attrib":{"href":"/us/usc/t42/s7135"},"text":"42 U.S.C. 7135","children":[],"tail":", 7177)."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1259d348-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3564/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Section","children":[],"tail":" 201 "},{"tag":"inline","attrib":{},"text":"of Congressional Budget Act of","children":[],"tail":" 1974.—"}],"tail":null},{"tag":"content","attrib":{},"text":"This subchapter shall not be construed to limit any authorities of the Congressional Budget Office to work (consistent with laws governing the confidentiality of information the disclosure of which would be a violation of law) with databases of Designated Statistical Agencies (as defined in section 3576(e)), either separately or, for data that may be shared pursuant to section 3576(c) or other authority, jointly in order to improve the general utility of these databases for the statistical purpose of analyzing pension and health care financing issues.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1259d349-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3564/f"},"text":null,"children":[{"tag":"num","attrib":{"value":"f"},"text":"(f)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Preemption of State Law","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this subchapter shall preempt applicable State law regarding the confidentiality of data collected by the States.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1259d34a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3564/g"},"text":null,"children":[{"tag":"num","attrib":{"value":"g"},"text":"(g)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Statutes Regarding False Statements","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Notwithstanding section 3572, information collected by an agency for exclusively statistical purposes under a pledge of confidentiality may be provided by the collecting agency to a law enforcement agency for the prosecution of submissions to the collecting agency of false statistical information under statutes that authorize criminal penalties (such as ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t13/s221"},"text":"section 221 of title 13","children":[],"tail":") or civil penalties for the provision of false statistical information, unless such disclosure or use would otherwise be prohibited under Federal law."}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id125c1c3b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3564/h"},"text":null,"children":[{"tag":"num","attrib":{"value":"h"},"text":"(h)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Construction","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this subchapter shall be construed as restricting or diminishing any confidentiality protections or penalties for unauthorized disclosure that otherwise apply to data or information collected for statistical purposes or nonstatistical purposes, including, but not limited to, section 6103 of the Internal Revenue Code of 1986.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id125c1c3c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3564/i"},"text":null,"children":[{"tag":"num","attrib":{"value":"i"},"text":"(i)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Authority of Congress","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"Nothing in this subchapter shall be construed to affect the authority of the Congress, including its committees, members, or agents, to obtain data or information for a statistical purpose, including for oversight of an agency’s statistical activities.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id125c1c3d-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/435/tIII/s302/a"},"text":"Pub. L. 115–435, title III, § 302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5547"},"text":"132 Stat. 5547","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id125c1c3e-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id125c1c3f-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"referencesInText","id":"id125c1c40-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"References in Text","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section 201 of the Congressional Budget Act of 1974, referred to in subsec. (e), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t2/s601"},"text":"section 601 of Title 2","children":[],"tail":", The Congress."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Section 6103 of the Internal Revenue Code of 1986, referred to in subsec. (h), is classified to ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t26/s6103"},"text":"section 6103 of Title 26","children":[],"tail":", Internal Revenue Code."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id125c1c41-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDate","id":"id125c1c42-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Section effective 180 days after ","children":[{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/435/s403"},"text":"section 403 of Pub. L. 115–435","children":[],"tail":", set out as an Effective Date of 2019 Amendment note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s306"},"text":"section 306 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
