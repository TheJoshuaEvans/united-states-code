{"tag":"section","attrib":{"id":"id122c8188-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1507"},"text":null,"children":[{"tag":"num","attrib":{"value":"1507"},"text":"§ 1507.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Filing document as constructive notice; publication in Federal Register as presumption of validity; judicial notice; citation","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"A document required by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s1505/a"},"text":"section 1505(a) of this title","children":[],"tail":" to be published in the Federal Register is not valid as against a person who has not had actual knowledge of it until the document has been filed with the Office of the Federal Register and a copy made available for public inspection as provided by "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s1503"},"text":"section 1503 of this title","children":[],"tail":". Unless otherwise specifically provided by statute, filing of a document, required or authorized to be published by "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s1505"},"text":"section 1505 of this title","children":[],"tail":", except in cases where notice by publication is insufficient in law, is sufficient to give notice of the contents of the document to a person subject to or affected by it. The publication in the Federal Register of a document creates a rebuttable presumption—"}],"tail":null},{"tag":"paragraph","attrib":{"id":"id122c8189-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1507/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that it was duly issued, prescribed, or promulgated;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id122c818a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1507/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that it was filed with the Office of the Federal Register and made available for public inspection at the day and hour stated in the published notation;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id122c818b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1507/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that the copy contained in the Federal Register is a true copy of the original; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id122c818c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1507/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" that all requirements of this chapter and the regulations prescribed under it relative to the document have been complied with.","children":[],"tail":"\n"}],"tail":"\n\n"},{"tag":"continuation","attrib":{},"text":"The contents of the Federal Register shall be judicially noticed and without prejudice to any other mode of citation, may be cited by volume and page number.","children":[],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id122c818d-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1276"},"text":"82 Stat. 1276","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/118/267/s2/a/2"},"text":"Pub. L. 118–267, § 2(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2025-01-04"},"text":"Jan. 4, 2025","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/138/2983"},"text":"138 Stat. 2983","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122c818e-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122c818f-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 307 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1935-07-26/ch417/s7"},"text":"July 26, 1935, ch. 417, § 7","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/49/502"},"text":"49 Stat. 502","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id122c8190-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id122c8191-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2025—","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/267/s2/a/2/A"},"text":"Pub. L. 118–267, § 2(a)(2)(A)","children":[],"tail":", substituted “the document has been filed” for “the duplicate originals or certified copies of the document have been filed” in introductory provisions."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Par. (2). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/118/267/s2/a/2/B"},"text":"Pub. L. 118–267, § 2(a)(2)(B)","children":[],"tail":", substituted “published” for “printed”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
