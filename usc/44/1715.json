{"tag":"section","attrib":{"id":"id122c821d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1715"},"text":null,"children":[{"tag":"num","attrib":{"value":"1715"},"text":"§ 1715.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publications for department or officer or for congressional committees","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"When printing not bearing a congressional number, except confidential matter, blank forms, and circular letters not of a public character, is done for a department or officer of the Government, or not of a confidential character, is done for use of congressional committees, two copies shall be sent, unless withheld by order of the committee, by the Director of the Government Publishing Office to the Senate and House of Representatives libraries, respectively, and one copy each to the document rooms of the Senate and House of Representatives, for reference; and these copies may not be removed.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id122c821e-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1281"},"text":"82 Stat. 1281","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/c/1"},"text":"Pub. L. 113–235, div. H, title I, § 1301(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122ecb0f-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122ecb10-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 217 (part) (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s58"},"text":"Jan. 12, 1895, ch. 23, § 58","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/610"},"text":"28 Stat. 610","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1907-03-01/ch2284/s4"},"text":"Mar. 1, 1907, ch. 2284, § 4","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/34/1014"},"text":"34 Stat. 1014","children":[],"tail":")."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"The last clause of this section is eliminated, as superseded by former section 85, now found in section 1903 of the revision.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id122ecb11-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id122ecb12-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235"},"text":"Pub. L. 113–235","children":[],"tail":" substituted “Director of the Government Publishing Office” for “Public Printer”."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
