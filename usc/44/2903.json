{"tag":"section","attrib":{"id":"id1241dd9e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2903"},"text":null,"children":[{"tag":"num","attrib":{"value":"2903"},"text":"§ 2903.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Custody and control of property","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1241dd9f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2903/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The Archivist shall have immediate custody and control of the National Archives Building and its contents, and may design, construct, purchase, lease, maintain, operate, protect, and improve buildings used by him for the storage of records of Federal agencies in the District of Columbia and elsewhere.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1241dda0-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2903/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the Archivist considers it to be in the public interest, the Archivist may charge and collect reasonable fees from the public for the occasional, non-official use of rooms and spaces, and services related to such use, in the buildings subject to this section. Fees collected under this subsection shall be paid into an account in the National Archives Trust Fund and shall be held, administered, and expended for the benefit and in the interest of the national archival and records activities administered by the National Archives and Records Administration, including educational and public program purposes.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1241dda1-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1296"},"text":"82 Stat. 1296","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/tI/s107/b/15/A"},"text":"Pub. L. 98–497, title I, § 107(b)(15)(A)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2288"},"text":"98 Stat. 2288","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/108/383/s4/b"},"text":"Pub. L. 108–383, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2004-10-30"},"text":"Oct. 30, 2004","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/118/2218"},"text":"118 Stat. 2218","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1241dda2-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id1241dda3-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 392 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title V, § 502, as added "},{"tag":"ref","attrib":{"href":"/us/act/1950-09-05/ch849/s6/d"},"text":"Sept. 5, 1950, ch. 849, § 6(d)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/583"},"text":"64 Stat. 583","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1241dda4-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","at