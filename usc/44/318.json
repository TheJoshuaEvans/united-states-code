{"tag":"section","attrib":{"id":"id121bb8dd-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s318"},"text":null,"children":[{"tag":"num","attrib":{"value":"318"},"text":"§ 318.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Transfer of surplus property; acceptance of voluntary services","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id121bb8de-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s318/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" The Director of the Government Publishing Office may—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id121bb8df-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s318/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" transfer or donate surplus Government publications and condemned Government Publishing Office machinery, material, equipment, and supplies to—","children":[],"tail":null},{"tag":"subparagraph","attrib":{"id":"id121bb8e0-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s318/a/1/A"},"text":null,"children":[{"tag":"num","attrib":{"value":"A"},"text":"(A)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" other Federal entities;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id121bb8e1-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s318/a/1/B"},"text":null,"children":[{"tag":"num","attrib":{"value":"B"},"text":"(B)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" any organization described under section 501(c)(3) or (4) of the Internal Revenue Code of 1986 and exempt from taxation under 501(a) of such Code; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subparagraph","attrib":{"id":"id121bb8e2-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s318/a/1/C"},"text":null,"children":[{"tag":"num","attrib":{"value":"C"},"text":"(C)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" State or local governments; and","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id121bb8e3-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s318/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" accept voluntary and uncompensated services, notwithstanding ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1342"},"text":"section 1342 of title 31","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id121bb8e4-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s318/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" Individuals providing voluntary and uncompensated services under subsection (a)(2) shall not be considered Federal employees, except for purposes of chapter 81 of title 5 (relating to compensation for work injuries) and chapter 171 of title 28 (relating to tort claims).","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id121bb8e5-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/108/83/tI/s1302/a"},"text":"Pub. L. 108–83, title I, § 1302(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2003-09-30"},"text":"Sept. 30, 2003","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/117/1033"},"text":"117 Stat. 1033","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/b"},"text":"Pub. L. 113–235, div. H, title I, § 1301(b)","children":[],"tail":", (c)(1), "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 