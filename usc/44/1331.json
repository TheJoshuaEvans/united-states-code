{"tag":"section","attrib":{"id":"id122a0ff5-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1331"},"text":null,"children":[{"tag":"num","attrib":{"value":"1331"},"text":"§ 1331.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" National Academy of Sciences: report","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In addition to the usual number of the report of the National Academy of Sciences, two thousand copies shall be printed: five hundred for the Senate, one thousand for the House of Representatives, and five hundred for distribution by the National Academy of Sciences.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id122a0ff6-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1270"},"text":"82 Stat. 1270","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122a0ff7-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122a0ff8-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 275 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s73"},"text":"Jan. 12, 1895, ch. 23, § 73","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/616"},"text":"28 Stat. 616","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
