{"tag":"section","attrib":{"id":"id1252a775-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3520"},"text":null,"children":[{"tag":"num","attrib":{"value":"3520"},"text":"§ 3520.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Chief Data Officers","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1252a776-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3520/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Establishment","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The head of each agency shall designate a nonpolitical appointee employee in the agency as the Chief Data Officer of the agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1252a777-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3520/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Qualifications","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chief Data Officer of an agency shall be designated on the basis of demonstrated training and experience in data management, governance (including creation, application, and maintenance of data standards), collection, analysis, protection, use, and dissemination, including with respect to any statistical and related techniques to protect and de-identify confidential data.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1252a778-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3520/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Functions","children":[],"tail":".—"}],"tail":null},{"tag":"chapeau","attrib":{},"text":"The Chief Data Officer of an agency shall—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1252a779-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3520/c/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" be responsible for lifecycle data management;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1252a77a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3520/c/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" coordinate with any official in the agency responsible for using, protecting, disseminating, and generating data to ensure that the data needs of the agency are met;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1252a77b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3520/c/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" manage data assets of the agency, including the standardization of data format, sharing of data assets, and publication of data assets in accordance with applicable law;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1252a77c-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3520/c/4"},"text":null,"children":[{"tag":"num","attrib":{"value":"4"},"text":"(4)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" in carrying out the requirements under paragraphs (3) and (5), consult with any statistical official of the agency (as designated under ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s314"},"text":"section 314 of title 5","children":[],"tail":");"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1252a77d-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3520/c/5"},"text":null,"children":[{"tag":"num","attrib":{"value":"5"},"text":"(5)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" carry out the requirements of the agency under subsections (b) through (d), (f), and (i) of section 3506, section 3507, and section 3511;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1252a77e-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3520/c/6"},"text":null,"children":[{"tag":"num","attrib":{"value":"6"},"text":"(6)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that, to the extent practicable, agency data conforms with data management best practices;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1252a77f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3520/c/7"},"text":null,"children":[{"tag":"num","attrib":{"value":"7"},"text":"(7)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" engage agency employees, the public, and contractors in using public data assets and encourage collaborative approaches on improving data use;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1252a780-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3520/c/8"},"text":null,"children":[{"tag":"num","attrib":{"value":"8"},"text":"(8)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the Performance Improvement Officer of the agency in identifying and using data to carry out the functions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t31/s1124/a/2"},"text":"section 1124(a)(2) of title 31","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1252a781-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3520/c/9"},"text":null,"children":[{"tag":"num","attrib":{"value":"9"},"text":"(9)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" support the Evaluation Officer of the agency in obtaining data to carry out the functions described in ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t5/s313/d"},"text":"section 313(d) of title 5","children":[],"tail":";"}],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1252a782-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3520/c/10"},"text":null,"children":[{"tag":"num","attrib":{"value":"10"},"text":"(10)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" review the impact of the infrastructure of the agency on data asset accessibility and coordinate with the Chief Information Officer of the agency to improve such infrastructure to reduce barriers that inhibit data asset accessibility;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1252a783-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3520/c/11"},"text":null,"children":[{"tag":"num","attrib":{"value":"11"},"text":"(11)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" ensure that, to the extent practicable, the agency maximizes the use of data in the agency, including for the production of evidence (as defined in section 3561), cybersecurity, and the improvement of agency operations;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1252a784-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3520/c/12"},"text":null,"children":[{"tag":"num","attrib":{"value":"12"},"text":"(12)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" identify points of contact for roles and responsibilities related to open data use and implementation (as required by the Director);","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1252a785-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3520/c/13"},"text":null,"children":[{"tag":"num","attrib":{"value":"13"},"text":"(13)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" serve as the agency liaison to other agencies and the Office of Management and Budget on the best way to use existing agency data for statistical purposes (as defined in section 3561); and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1252a786-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3520/c/14"},"text":null,"children":[{"tag":"num","attrib":{"value":"14"},"text":"(14)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" comply with any regulation and guidance issued under subchapter III, including the acquisition and maintenance of any required certification and training.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1252a787-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3520/d"},"text":null,"children":[{"tag":"num","attrib":{"value":"d"},"text":"(d)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Delegation of Responsibilities.—","children":[],"tail":null}],"tail":null},{"tag":"paragraph","attrib":{"id":"id1252a788-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3520/d/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"In general","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To the extent necessary to comply with statistical laws, the Chief Data Officer of an agency shall delegate any responsibility under subsection (c) to the head of a statistical agency or unit (as defined in section 3561) within the agency.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1252a789-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3520/d/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Consultation","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"To the extent permissible under law, the individual to whom a responsibility has been delegated under paragraph (1) shall consult with the Chief Data Officer of the agency in carrying out such responsibility.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1252a78a-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3520/d/3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"(3)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Deference","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chief Data Officer of the agency shall defer to the individual to whom a responsibility has been delegated under paragraph (1) regarding the necessary delegation of such responsibility with respect to any data acquired, maintained, or disseminated by the agency under applicable statistical law.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1252a78b-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3520/e"},"text":null,"children":[{"tag":"num","attrib":{"value":"e"},"text":"(e)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" ","children":[{"tag":"inline","attrib":{},"text":"Reports","children":[],"tail":".—"}],"tail":null},{"tag":"content","attrib":{},"text":"The Chief Data Officer of an agency shall submit to the Committee on Homeland Security and Governmental Affairs of the Senate and the Committee on Oversight and Government Reform of the House of Representatives an annual report on the compliance of the agency with the requirements of this subchapter, including information on each requirement that the agency could not carry out and, if applicable, what the agency needs to carry out such requirement.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1252a78c-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/107/198/s3/a/2"},"text":"Pub. L. 107–198, § 3(a)(2)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2002-06-28"},"text":"June 28, 2002","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/116/730"},"text":"116 Stat. 730","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/115/435/tII/s202/e/1"},"text":"Pub. L. 115–435, title II, § 202(e)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/132/5541"},"text":"132 Stat. 5541","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1252a78d-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1252a78e-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id1252a78f-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3520 was renumbered ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s3521"},"text":"section 3521 of this title","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 3520, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/511/s2/a"},"text":"Pub. L. 96–511, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-11"},"text":"Dec. 11, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2825"},"text":"94 Stat. 2825","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/99/500/s101/m/tVIII/s820"},"text":"Pub. L. 99–500, § 101(m) [title VIII, § 820]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-18"},"text":"Oct. 18, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/1783-308"},"text":"100 Stat. 1783–308","children":[],"tail":", 1783–340, and "},{"tag":"ref","attrib":{"href":"/us/pl/99/591/s101/m/tVIII/s820"},"text":"Pub. L. 99–591, § 101(m) [title VIII, § 820]","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1986-10-30"},"text":"Oct. 30, 1986","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/100/3341-308"},"text":"100 Stat. 3341–308","children":[],"tail":", 3341–340, related to authorization of appropriations prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/104/13"},"text":"Pub. L. 104–13","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id1252a790-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2019—","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/435"},"text":"Pub. L. 115–435","children":[],"tail":" amended section generally. Prior to amendment, section related to establishment of task force on information collection and dissemination."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id1252a791-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"id1252a792-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Committee on Oversight and Government Reform of House of Representatives changed to Committee on Oversight and Reform of House of Representatives by House Resolution No. 6, One Hundred Sixteenth Congress, ","children":[{"tag":"date","attrib":{"date":"2019-01-09"},"text":"Jan. 9, 2019","children":[],"tail":". Committee on Oversight and Reform of House of Representatives changed to Committee on Oversight and Accountability of House of Representatives by House Resolution No. 5, One Hundred Eighteenth Congress, "},{"tag":"date","attrib":{"date":"2023-01-09"},"text":"Jan. 9, 2023","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id1252a793-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2019 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib":{"href":"/us/pl/115/435"},"text":"Pub. L. 115–435","children":[],"tail":" effective 180 days after "},{"tag":"date","attrib":{"date":"2019-01-14"},"text":"Jan. 14, 2019","children":[],"tail":", see "},{"tag":"ref","attrib":{"href":"/us/pl/115/435/s403"},"text":"section 403 of Pub. L. 115–435","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t5/s306"},"text":"section 306 of Title 5","children":[],"tail":", Government Organization and Employees."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
