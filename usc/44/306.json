{"tag":"section","attrib":{"id":"id12196e7f-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s306"},"text":null,"children":[{"tag":"num","attrib":{"value":"306"},"text":"§ 306.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Director of the Government Publishing Office: employment of skilled workmen; trial of skill","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director of the Government Publishing Office shall employ workmen who are thoroughly skilled in their respective branches of industry, as shown by trial of their skill under the direction of the Director.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id12196e80-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1240"},"text":"82 Stat. 1240","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/c"},"text":"Pub. L. 113–235, div. H, title I, § 1301(c)","children":[],"tail":", (i)(3), "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":", 2538.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id12196e81-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id12196e82-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 41 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1895-01-12/ch23/s45"},"text":"Jan. 12, 1895, ch. 23, § 45","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/28/607"},"text":"28 Stat. 607","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id12196e83-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id12196e84-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/i/3"},"text":"Pub. L. 113–235, § 1301(i)(3)","children":[],"tail":", substituted “the direction of the Director” for “his direction”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":null,"children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/c"},"text":"Pub. L. 113–235, § 1301(c)","children":[],"tail":", substituted “Director of the Government Publishing Office” for “Public Printer” in section catchline and text."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
