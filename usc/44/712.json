{"tag":"section","attrib":{"id":"id121e29b1-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s712"},"text":null,"children":[{"tag":"num","attrib":{"value":"712"},"text":"§ 712.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Printing of postal conventions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director of the Government Publishing Office, on receiving from the Postmaster General a copy of a postal convention between the Postmaster General, on the part of the United States, and an equivalent officer of a foreign government, shall print an accurate copy and transmit it in duplicate to the Postmaster General. On the return of one of the revised duplicates, he shall make the marked corrections and print the number specified by ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s709"},"text":"section 709 of this title","children":[],"tail":"."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id122099b2-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1249"},"text":"82 Stat. 1249","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/c/1"},"text":"Pub. L. 113–235, div. H, title I, § 1301(c)(1)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122099b3-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122099b4-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","at