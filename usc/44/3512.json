{"tag":"section","attrib":{"id":"id1252a703-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3512"},"text":null,"children":[{"tag":"num","attrib":{"value":"3512"},"text":"§ 3512.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Public protection","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id1252a704-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3512/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"chapeau","attrib":{},"text":" Notwithstanding any other provision of law, no person shall be subject to any penalty for failing to comply with a collection of information that is subject to this subchapter if—","children":[],"tail":null},{"tag":"paragraph","attrib":{"id":"id1252a705-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3512/a/1"},"text":null,"children":[{"tag":"num","attrib":{"value":"1"},"text":"(1)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the collection of information does not display a valid control number assigned by the Director in accordance with this subchapter; or","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"paragraph","attrib":{"id":"id1252a706-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3512/a/2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"(2)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" the agency fails to inform the person who is to respond to the collection of information that such person is not required to respond to the collection of information unless it displays a valid control number.","children":[],"tail":"\n"}],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id1252a707-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s3512/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" The protection provided by this section may be raised in the form of a complete defense, bar, or otherwise at any time during the agency administrative process or judicial action applicable thereto.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id1252a708-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(Added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/104/13/s2"},"text":"Pub. L. 104–13, § 2","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1995-05-22"},"text":"May 22, 1995","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/109/181"},"text":"109 Stat. 181","children":[],"tail":"; amended "},{"tag":"ref","attrib":{"href":"/us/pl/106/398/s1/dA"},"text":"Pub. L. 106–398, § 1 [[div. A]","children":[],"tail":", title X, § 1064(b)], "},{"tag":"date","attrib":{"date":"2000-10-30"},"text":"Oct. 30, 2000","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/114/1654"},"text":"114 Stat. 1654","children":[],"tail":", 1654A–275.)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id1252a709-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id1252a70a-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"priorProvisions","id":"id1252a70b-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Prior Provisions","children":[],"tail":null},{"tag":"p","attrib":{},"text":"A prior section 3512, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/96/511/s2/a"},"text":"Pub. L. 96–511, § 2(a)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1980-12-11"},"text":"Dec. 11, 1980","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/94/2822"},"text":"94 Stat. 2822","children":[],"tail":", related to protection of persons failing to maintain or provide information if information collection request did not display current control number prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/104/13"},"text":"Pub. L. 104–13","children":[],"tail":"."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Another prior section 3512, added ","children":[{"tag":"ref","attrib":{"href":"/us/pl/93/153/tIV/s409/b"},"text":"Pub. L. 93–153, title IV, § 409(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1973-11-16"},"text":"Nov. 16, 1973","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/87/593"},"text":"87 Stat. 593","children":[],"tail":", related to information for independent regulatory agencies, prior to the general amendment of this chapter by "},{"tag":"ref","attrib":{"href":"/us/pl/96/511"},"text":"Pub. L. 96–511","children":[],"tail":"."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id1252a70c-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2000—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/106/398"},"text":"Pub. L. 106–398","children":[],"tail":" substituted “subchapter” for “chapter” in introductory provisions and par. (1)."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id1252a70d-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id1252a70e-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 2000 Amendment","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Amendment by ","children":[{"tag":"ref","attrib"