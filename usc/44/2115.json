{"tag":"section","attrib":{"id":"id123ab286-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2115"},"text":null,"children":[{"tag":"num","attrib":{"value":"2115"},"text":"§ 2115.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Reports; correction of violations","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"id123ab287-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2115/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" In carrying out the duties and responsibilities under chapters 21, 25, 29, 31, and 33 of this title, the Archivist may obtain reports from any Federal agency on such agency’s activities under such chapters.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"id123ab288-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s2115/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"content","attrib":{},"text":" When the Archivist finds that a provision of any such chapter has been or is being violated, the Archivist shall (1) inform in writing the head of the agency concerned of the violation and make recommendations for its correction; and (2) unless satisfactory corrective measures are demonstrably commenced within a reasonable time, submit a written report of the matter to the President and the Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"id123ab289-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1290"},"text":"82 Stat. 1290","children":[],"tail":", § 2111; "},{"tag":"ref","attrib":{"href":"/us/pl/94/575/s4/b"},"text":"Pub. L. 94–575, § 4(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1976-10-21"},"text":"Oct. 21, 1976","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/90/2727"},"text":"90 Stat. 2727","children":[],"tail":"; renumbered § 2115 and amended "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/tI"},"text":"Pub. L. 98–497, title I","children":[],"tail":", §§ 102(a)(1), 107(a)(8), "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2280"},"text":"98 Stat. 2280","children":[],"tail":", 2286; "},{"tag":"ref","attrib":{"href":"/us/pl/113/187/s9/e"},"text":"Pub. L. 113–187, § 9(e)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-11-26"},"text":"Nov. 26, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2014"},"text":"128 Stat. 2014","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id123ab28a-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id123ab28b-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 398 (","children":[{"tag":"ref","attrib":{"href":"/us/act/1949-06-30/ch288"},"text":"June 30, 1949, ch. 288","children":[],"tail":", title V, § 508, as added "},{"tag":"ref","attrib":{"href":"/us/act/1950-09-05/ch849/s6/d"},"text":"Sept. 5, 1950, ch. 849, § 6(d)","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/64/583"},"text":"64 Stat. 583","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"id123ab28c-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"id123ab28d-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"2014—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/187/s9/e/1"},"text":"Pub. L. 113–187, § 9(e)(1)","children":[],"tail":", substituted “the duties” for “their respective duties” and struck out “and the Administrator” after “the Archivist” and “each” before “obtain reports”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/187/s9/e/2"},"text":"Pub. L. 113–187, § 9(e)(2)","children":[],"tail":", struck out “either” after “When”, struck out “or the Administrator” after “the Archivist” in two places, and substituted “demonstrably commenced” for “inaugurated”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1984—","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497/s107/a/8"},"text":"Pub. L. 98–497, § 107(a)(8)","children":[],"tail":", amended section generally, inserting reference to Archivist and striking out reference to chapter 27 of this title."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1976—Subsec. (b). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/94/575"},"text":"Pub. L. 94–575","children":[],"tail":" inserted reference to chapter 33 of this title."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"id123ab28e-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"effectiveDateOfAmendment","id":"id123ab28f-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Effective Date of 1984 Amendment","children":[],"tail":null}