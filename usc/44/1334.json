{"tag":"section","attrib":{"id":"id122a1007-e3ef-11ef-8e9f-f6e47fd25777","identifier":"/us/usc/t44/s1334"},"text":null,"children":[{"tag":"num","attrib":{"value":"1334"},"text":"§ 1334.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Naval Intelligence Office: additional copies of publications","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"In addition to one thousand copies previously authorized, the Secretary of the Navy may print extra copies of the publications of the Office of Naval Intelligence necessary for distribution to the naval service and to meet other official demands. The edition of any one publication may not exceed two thousand copies.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"id122a1008-e3ef-11ef-8e9f-f6e47fd25777"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/pl/90/620"},"text":"Pub. L. 90–620","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1968-10-22"},"text":"Oct. 22, 1968","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/82/1271"},"text":"82 Stat. 1271","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"id122a1009-e3ef-11ef-8e9f-f6e47fd25777"},"text":"\n","children":[{"tag":"note","attrib":{"topic":"historicalAndRevision","id":"id122a100a-e3ef-11ef-8e9f-f6e47fd25777"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Historical and Revision Notes","children":[],"tail":null},{"tag":"p","attrib":{},"text":"Based on 44 U.S. Code, 1964 ed., § 278 (","children":[{"tag":"date","attrib":{"date":"1900-03-21"},"text":"Mar. 21, 1900","children":[],"tail":", No. 14, "},{"tag":"ref","attrib":{"href":"/us/stat/31/713"},"text":"31 Stat. 713","children":[],"tail":")."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
