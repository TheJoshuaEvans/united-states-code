{"tag":"section","attrib":{"id":"idac501f63-47c4-11f1-8df3-c75a02f6a58e","identifier":"/us/usc/t1/s107"},"text":null,"children":[{"tag":"num","attrib":{"value":"107"},"text":"§ 107.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Parchment or paper for printing enrolled bills or resolutions","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Enrolled bills and resolutions of either House of Congress shall be printed on parchment or paper of suitable quality as shall be determined by the Joint Committee on Printing.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idac501f64-47c4-11f1-8df3-c75a02f6a58e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-30/ch388"},"text":"July 30, 1947, ch. 388","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/635"},"text":"61 Stat. 635","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
