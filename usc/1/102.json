{"tag":"section","attrib":{"id":"idac4dae3e-47c4-11f1-8df3-c75a02f6a58e","identifier":"/us/usc/t1/s102"},"text":null,"children":[{"tag":"num","attrib":{"value":"102"},"text":"§ 102.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Resolving clause","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The resolving clause of all joint resolutions shall be in the following form: “Resolved by the Senate and House of Representatives of the United States of America in Congress assembled.”","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idac4dae3f-47c4-11f1-8df3-c75a02f6a58e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-30/ch388"},"text":"July 30, 1947, ch. 388","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/634"},"text":"61 Stat. 634","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
