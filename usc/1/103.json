{"tag":"section","attrib":{"id":"idac4dae40-47c4-11f1-8df3-c75a02f6a58e","identifier":"/us/usc/t1/s103"},"text":null,"children":[{"tag":"num","attrib":{"value":"103"},"text":"§ 103.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Enacting or resolving words after first section","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"No enacting or resolving words shall be used in any section of an Act or resolution of Congress except in the first.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idac4dae41-47c4-11f1-8df3-c75a02f6a58e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-30/ch388"},"text":"July 30, 1947, ch. 388","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/634"},"text":"61 Stat. 634","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
