{"tag":"section","attrib":{"id":"idac501f65-47c4-11f1-8df3-c75a02f6a58e","identifier":"/us/usc/t1/s108"},"text":null,"children":[{"tag":"num","attrib":{"value":"108"},"text":"§ 108.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Repeal of repealing act","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Whenever an Act is repealed, which repealed a former Act, such former Act shall not thereby be revived, unless it shall be expressly so provided.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idac501f66-47c4-11f1-8df3-c75a02f6a58e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-30/ch388"},"text":"July 30, 1947, ch. 388","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/635"},"text":"61 Stat. 635","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
