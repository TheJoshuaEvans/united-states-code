{"tag":"section","attrib":{"id":"idac4b642d-47c4-11f1-8df3-c75a02f6a58e","identifier":"/us/usc/t1/s3"},"text":null,"children":[{"tag":"num","attrib":{"value":"3"},"text":"§ 3.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “Vessel” as including all means of water transportation","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The word “vessel” includes every description of watercraft or other artificial contrivance used, or capable of being used, as a means of transportation on water.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idac4b642e-47c4-11f1-8df3-c75a02f6a58e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-30/ch388"},"text":"July 30, 1947, ch. 388","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/633"},"text":"61 Stat. 633","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
