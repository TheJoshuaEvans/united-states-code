{"tag":"section","attrib":{"id":"idac574b11-47c4-11f1-8df3-c75a02f6a58e","identifier":"/us/usc/t1/s210"},"text":null,"children":[{"tag":"num","attrib":{"value":"210"},"text":"§ 210.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Distribution of Supplements to Code of Laws of United States and of District of Columbia Code and Supplements; slip and pamphlet copies","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Copies of the Code of Laws relating to the District of Columbia, and of the supplements provided for by sections 202, 203 of this title shall be distributed by the Superintendent of Documents in the same manner as bound volumes of the Statutes at Large: ","children":[{"tag":"i","attrib":{},"text":"Provided","children":[],"tail":", That no slip or pamphlet copies of the Code of Laws relating to the District of Columbia, and of the supplements provided for by sections 202, 203 of this title need be printed or distributed."}],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idac574b12-47c4-11f1-8df3-c75a02f6a58e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-30/ch388"},"text":"July 30, 1947, ch. 388","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/640"},"text":"61 Stat. 640","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idac574b13-47c4-11f1-8df3-c75a02f6a58e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idac574b14-47c4-11f1-8df3-c75a02f6a58e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"crossReferences","id":"idac574b15-47c4-11f1-8df3-c75a02f6a58e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Cross References","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"Distribution of Statutes at Large, see ","children":[{"tag":"ref","attrib":{"href":"/us/usc/t44/s728"},"text":"section 728 of Title 44","children":[],"tail":", Public Printing and Documents."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
