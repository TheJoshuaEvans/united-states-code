{"tag":"section","attrib":{"id":"idac574b0a-47c4-11f1-8df3-c75a02f6a58e","identifier":"/us/usc/t1/s209"},"text":null,"children":[{"tag":"num","attrib":{"value":"209"},"text":"§ 209.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Copies of Supplements to Code of Laws of United States and of District of Columbia Code and Supplements; conclusive evidence of original","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"Copies of the Code of Laws relating to the District of Columbia and copies of the supplements provided for by sections 202 and 203 of this title printed at the Government Publishing Office and bearing its imprint, shall be conclusive evidence of the original of such code and supplements in the custody of the Administrator of General Services.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idac574b0b-47c4-11f1-8df3-c75a02f6a58e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-30/ch388"},"text":"July 30, 1947, ch. 388","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/639"},"text":"61 Stat. 639","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-09-03/ch1263/s2"},"text":"Sept. 3, 1954, ch. 1263, § 2","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/1226"},"text":"68 Stat. 1226","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/b"},"text":"Pub. L. 113–235, div. H, title I, § 1301(b)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idac574b0c-47c4-11f1-8df3-c75a02f6a58e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idac574b0d-47c4-11f1-8df3-c75a02f6a58e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idac574b0e-47c4-11f1-8df3-c75a02f6a58e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1954—Act ","children":[{"tag":"date","attrib":{"date":"1954-09-03"},"text":"Sept. 3, 1954","children":[],"tail":", substituted “Administrator of General Services” for “Secretary of State”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idac574b0f-47c4-11f1-8df3-c75a02f6a58e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idac574b10-47c4-11f1-8df3-c75a02f6a58e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Government Publishing Office” substituted for “Government Printing Office” in text on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/b"},"text":"section 1301(b) of Pub. L. 113–235","children":[],"tail":", set out as a note preceding "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s301"},"text":"section 301 of Title 44","children":[],"tail":", Public Printing and Documents."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
