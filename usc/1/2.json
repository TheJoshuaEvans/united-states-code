{"tag":"section","attrib":{"id":"idac4b642b-47c4-11f1-8df3-c75a02f6a58e","identifier":"/us/usc/t1/s2"},"text":null,"children":[{"tag":"num","attrib":{"value":"2"},"text":"§ 2.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" “County” as including “parish”, and so forth","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The word “county” includes a parish, or any other equivalent subdivision of a State or Territory of the United States.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idac4b642c-47c4-11f1-8df3-c75a02f6a58e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-30/ch388"},"text":"July 30, 1947, ch. 388","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/633"},"text":"61 Stat. 633","children":[],"tail":".)"}],"tail":"\n"}],"tail":null}
