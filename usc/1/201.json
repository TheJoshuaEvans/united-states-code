{"tag":"section","attrib":{"id":"idac54d9d8-47c4-11f1-8df3-c75a02f6a58e","identifier":"/us/usc/t1/s201"},"text":null,"children":[{"tag":"num","attrib":{"value":"201"},"text":"§ 201.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publication and distribution of Code of Laws of United States and Supplements and District of Columbia Code and Supplements","children":[],"tail":"\n"},{"tag":"chapeau","attrib":{},"text":"In order to avoid duplication and waste—","children":[],"tail":null},{"tag":"subsection","attrib":{"id":"idac54d9d9-47c4-11f1-8df3-c75a02f6a58e","identifier":"/us/usc/t1/s201/a"},"text":null,"children":[{"tag":"num","attrib":{"value":"a"},"text":"(a)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Publishing in slip or pamphlet form or in Statutes at Large.—","children":[],"tail":null},{"tag":"content","attrib":{},"text":"Publication in slip or pamphlet form or in the Statutes at Large of any of the volumes or publications enumerated in sections 202 and 203 of this title, shall, in event of enactment, be dispensed with whenever the Committee on the Judiciary of the House of Representatives so directs the Archivist of the United States;","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idac54d9da-47c4-11f1-8df3-c75a02f6a58e","identifier":"/us/usc/t1/s201/b"},"text":null,"children":[{"tag":"num","attrib":{"value":"b"},"text":"(b)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Curtailing number of copies published.—","children":[],"tail":null},{"tag":"content","attrib":{},"text":"Curtailment of the number provided by law to be printed and distributed of the volumes or publications enumerated in sections 202 and 203 of this title may be directed by such committee, except that the Director of the Government Publishing Office shall print such numbers as are necessary for depository library distribution and for sale; and","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"subsection","attrib":{"id":"idac54d9db-47c4-11f1-8df3-c75a02f6a58e","identifier":"/us/usc/t1/s201/c"},"text":null,"children":[{"tag":"num","attrib":{"value":"c"},"text":"(c)","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Dispensing with publication of more than one Supplement for each Congress.—","children":[],"tail":null},{"tag":"content","attrib":{},"text":"Such committee may direct that the printing and distribution of any supplement to the Code of Laws of the United States or to the Code of the District of Columbia be dispensed with entirely, except that there shall be printed and distributed for each Congress at least one supplement to each such code, containing the legislation of such Congress.","children":[],"tail":"\n"}],"tail":"\n"},{"tag":"sourceCredit","attrib":{"id":"idac54d9dc-47c4-11f1-8df3-c75a02f6a58e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-30/ch388"},"text":"July 30, 1947, ch. 388","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/637"},"text":"61 Stat. 637","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/act/1954-09-03/ch1263/s1"},"text":"Sept. 3, 1954, ch. 1263, § 1","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/68/1226"},"text":"68 Stat. 1226","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/98/497/tI/s107/d"},"text":"Pub. L. 98–497, title I, § 107(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"1984-10-19"},"text":"Oct. 19, 1984","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/98/2291"},"text":"98 Stat. 2291","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/d"},"text":"Pub. L. 113–235, div. H, title I, § 1301(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idac54d9dd-47c4-11f1-8df3-c75a02f6a58e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"editorialNotes","id":"idac54d9de-47c4-11f1-8df3-c75a02f6a58e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Editorial Notes","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"amendments","id":"idac54d9df-47c4-11f1-8df3-c75a02f6a58e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":"Amendments","children":[],"tail":null},{"tag":"p","attrib":{},"text":"1984—Subsec. (a). ","children":[{"tag":"ref","attrib":{"href":"/us/pl/98/497"},"text":"Pub. L. 98–497","children":[],"tail":" substituted “Archivist of the United States” for “Administrator of General Services”."}],"tail":"\n"},{"tag":"p","attrib":{},"text":"1954—Subsec. (a). Act ","children":[{"tag":"date","attrib":{"date":"1954-09-03"},"text":"Sept. 3, 1954","children":[],"tail":", substituted “Administrator of General Services” for “Secretary of State”."}],"tail":"\n"}],"tail":"\n"},{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idac54d9e0-47c4-11f1-8df3-c75a02f6a58e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idac54d9e1-47c4-11f1-8df3-c75a02f6a58e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Director of the Government Publishing Office” substituted for “Public Printer” in subsec. (b) on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/d"},"text":"section 1301(d) of Pub. L. 113–235","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s301"},"text":"section 3