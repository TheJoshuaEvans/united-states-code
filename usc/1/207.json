{"tag":"section","attrib":{"id":"idac574b03-47c4-11f1-8df3-c75a02f6a58e","identifier":"/us/usc/t1/s207"},"text":null,"children":[{"tag":"num","attrib":{"value":"207"},"text":"§ 207.","children":[],"tail":null},{"tag":"heading","attrib":{},"text":" Copies of acts and resolutions in slip form; additional number printed for Committee on the Judiciary of House of Representatives","children":[],"tail":null},{"tag":"content","attrib":{},"text":"\n","children":[{"tag":"p","attrib":{},"text":"The Director of the Government Publishing Office is directed to print, in addition to the number provided by existing law, and, as soon as printed, to distribute in such manner as the Committee on the Judiciary of the House of Representatives shall determine, twenty copies in slip form of each public Act and joint resolution.","children":[],"tail":"\n"}],"tail":null},{"tag":"sourceCredit","attrib":{"id":"idac574b04-47c4-11f1-8df3-c75a02f6a58e"},"text":"(","children":[{"tag":"ref","attrib":{"href":"/us/act/1947-07-30/ch388"},"text":"July 30, 1947, ch. 388","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/61/639"},"text":"61 Stat. 639","children":[],"tail":"; "},{"tag":"ref","attrib":{"href":"/us/pl/113/235/dH/tI/s1301/d"},"text":"Pub. L. 113–235, div. H, title I, § 1301(d)","children":[],"tail":", "},{"tag":"date","attrib":{"date":"2014-12-16"},"text":"Dec. 16, 2014","children":[],"tail":", "},{"tag":"ref","attrib":{"href":"/us/stat/128/2537"},"text":"128 Stat. 2537","children":[],"tail":".)"}],"tail":"\n"},{"tag":"notes","attrib":{"type":"uscNote","id":"idac574b05-47c4-11f1-8df3-c75a02f6a58e"},"text":"\n","children":[{"tag":"note","attrib":{"role":"crossHeading","topic":"statutoryNotes","id":"idac574b06-47c4-11f1-8df3-c75a02f6a58e"},"text":null,"children":[{"tag":"heading","attrib":{},"text":null,"children":[{"tag":"b","attrib":{},"text":"Statutory Notes and Related Subsidiaries","children":[],"tail":null}],"tail":null}],"tail":"\n"},{"tag":"note","attrib":{"topic":"changeOfName","id":"idac574b07-47c4-11f1-8df3-c75a02f6a58e"},"text":"\n","children":[{"tag":"heading","attrib":{},"text":"Change of Name","children":[],"tail":"\n"},{"tag":"p","attrib":{},"text":"“Director of the Government Publishing Office” substituted for “Public Printer” in text on authority of ","children":[{"tag":"ref","attrib":{"href":"/us/pl/113/235/s1301/d"},"text":"section 1301(d) of Pub. L. 113–235","children":[],"tail":", set out as a note under "},{"tag":"ref","attrib":{"href":"/us/usc/t44/s301"},"text":"section 301 of Title 44","children":[],"tail":", Public Printing and Documents."}],"tail":"\n"}],"tail":"\n"}],"tail":"\n"}],"tail":null}
